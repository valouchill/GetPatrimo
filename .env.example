PORT=3000

# --- JWT ---
JWT_SECRET=change-moi-avec-une-grande-chaine-aleatoire

# --- MongoDB ---
# IMPORTANT: Utiliser un mot de passe fort, ne JAMAIS commit le .env
MONGO_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongodb:27017/doc2loc?authSource=admin
MONGO_USER=admin
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Brevo (SMTP) ---
BREVO_USER=your-brevo-user@smtp-brevo.com
BREVO_PASS=xsmtpsib-your-brevo-key

# --- Admin ---
ADMIN_EMAILS=admin@doc2loc.com
MAIL_FROM="Doc2Loc <no-reply@doc2loc.com>"
MAIL_REPLY_TO="contact@doc2loc.com"

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-your-openai-key

# --- NextAuth (connexion plateforme) ---
NEXTAUTH_URL=https://doc2loc.com
NEXTAUTH_SECRET=change-moi-avec-une-grande-chaine-aleatoire
NEXT_PUBLIC_BASE_URL=https://doc2loc.com

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret
PRICE_ID_ONESHOT=price_xxx
PRICE_ID_RECURRING=price_xxx

# --- Didit Identity Verification ---
# Obtenir ces cles sur https://business.didit.me
DIDIT_API_KEY=your-didit-api-key
DIDIT_WORKFLOW_ID=your-workflow-id
DIDIT_WEBHOOK_URL=https://doc2loc.com/api/webhooks/didit
DIDIT_ISSUER_URL=https://apx.didit.me
DIDIT_CLIENT_ID=your-client-id
DIDIT_CLIENT_SECRET=your-client-secret
DIDIT_REDIRECT_URI=https://verify.didit.me/u/your-redirect

# --- Phase 1 Auditeur Forensic ---
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-3.1-pro-preview

MISTRAL_API_KEY=your-mistral-key
MISTRAL_OCR_MODEL=mistral-ocr-latest

FORENSIC_METADATA_COMMAND=/opt/doc2loc/scripts/extract-metadata.js

FORENSIC_THRESHOLD_TRUST_MAX=20
FORENSIC_THRESHOLD_DOUBT_MAX=80

FORENSIC_METADATA_TIMEOUT_MS=15000
MISTRAL_TIMEOUT_MS=45000
GEMINI_TIMEOUT_MS=45000
FORENSIC_MATH_TOLERANCE=1

FORENSIC_SUSPICIOUS_SOFTWARE=Adobe Photoshop,Canva,GIMP,Paint,Illustrator,InDesign,ImageMagick,ILovePDF,Smallpdf,Sejda
FORENSIC_LEGITIMATE_SOFTWARE=Payfit,Sage,Cegid,Silae,ADP,Lucca,Microsoft,LibreOffice,Apache,iText,PDFKit
