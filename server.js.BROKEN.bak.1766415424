app.delete('/api/properties/:id', auth, async (req, res) => {
  try {
    const deleted = await Property.findOneAndDelete({ _id: req.params.id, user: req.user.id });
    if (!deleted) return res.status(404).json({ msg: 'Bien introuvable' });
    return res.json({ msg: 'Supprimé' });
  } catch (e) {
    console.error(e);
    return res.status(500).json({ msg: 'Erreur serveur' });
  }
});

// =====================
// TENANTS (ownership + 1 bien = 1 locataire côté API)
// =====================
app.post('/api/tenants', auth, async (req, res) => {
  try {
    const { firstName, lastName, email, property } = req.body;

    if (!firstName || !lastName || !email) {
      return res.status(400).json({ msg: 'Champs manquants' });
    }

    if (property) {
      const p = await Property.findOne({ _id: property, user: req.user.id });
      if (!p) return res.status(400).json({ msg: 'Bien invalide (ou pas à toi)' });

      const existing = await Tenant.findOne({ user: req.user.id, property });
      if (existing) return res.status(400).json({ msg: 'Ce bien a déjà un locataire' });
    }

    const t = new Tenant({
      user: req.user.id,
      firstName,
      lastName,
      email,
      property: property || undefined
    });

    await t.save();
    return res.json(t);
  } catch (e) {
    if (e && e.code === 11000) {
      return res.status(400).json({ msg: 'Ce bien a déjà un locataire' });
    }
    console.error(e);
    return res.status(500).json({ msg: 'Erreur serveur' });
  }
});

app.get('/api/tenants', auth, async (req, res) => {
  return res.json(await Tenant.find({ user: req.user.id }).populate('property'));
});

app.delete('/api/tenants/:id', auth, async (req, res) => {
  try {
    const deleted = await Tenant.findOneAndDelete({ _id: req.params.id, user: req.user.id });
    if (!deleted) return res.status(404).json({ msg: 'Locataire introuvable' });
    return res.json({ msg: 'Supprimé' });
  } catch (e) {
    console.error(e);
    return res.status(500).json({ msg: 'Erreur serveur' });
  }
});

// =====================
// PDF & EMAIL (ownership)
// =====================
app.get('/api/documents/quittance/:id', auth, async (req, res) => {
  try {
    const p = await Property.findOne({ _id: req.params.id, user: req.user.id });
    if (!p) return res.status(404).json({ msg: 'Bien introuvable' });

    const t = await Tenant.findOne({ user: req.user.id, property: p._id });
    const u = await User.findById(req.user.id);

    const buffer = await createPdfBuffer(p, t, u);
    res.setHeader('Content-Type', 'application/pdf');
    return res.send(buffer);
  } catch (e) {
    console.error(e);
    return res.status(500).json({ msg: 'Erreur PDF' });
  }
});

app.post('/api/documents/email/:id', auth, async (req, res) => {
  try {
    const p = await Property.findOne({ _id: req.params.id, user: req.user.id });
    if (!p) return res.status(404).json({ msg: 'Bien introuvable' });

    const t = await Tenant.findOne({ user: req.user.id, property: p._id });
    if (!t) return res.status(400).json({ msg: 'Aucun locataire lié à ce bien' });
    if (!t.email) return res.status(400).json({ msg: "Le locataire n'a pas d'email" });

    const u = await User.findById(req.user.id);

    const pdfBuffer = await createPdfBuffer(p, t, u);
    const mailOptions = {
      from: '"Doc2Loc" <no-reply@doc2loc.com>',
      to: t.email,
      subject: 'Quittance de loyer - ' + p.name,
      text:
        'Bonjour ' +
        t.firstName +
        ',\n\nVeuillez trouver ci-joint votre quittance de loyer.\n\nCordialement,\n' +
        ((u && u.firstName) ? u.firstName : 'Votre Bailleur'),
      attachments: [{ filename: 'Quittance.pdf', content: pdfBuffer }]
    };

    await transporter.sendMail(mailOptions);
    return res.json({ msg: 'Email envoyé avec succès !' });
  } catch (err) {
    console.error("❌ EMAIL ERROR:", err);
    return res.status(500).json({ msg: 'Erreur envoi email', detail: err.message });
  }
});

// --- ADMIN: LEADS (liste + export CSV) ---
function csvEscape(v) {
  const s = (v === null || v === undefined) ? '' : String(v);
  // double quotes -> ""
  const escaped = s.replace(/"/g, '""');
  return `"${escaped}"`;
}

app.get('/api/admin/leads', auth, requireAdmin, async (req, res) => {
  try {
    const limit = Math.min(parseInt(req.query.limit || '200', 10), 1000);
    const skip = Math.max(parseInt(req.query.skip || '0', 10), 0);

    const [total, items] = await Promise.all([
      Lead.countDocuments({}),
      Lead.find({})
        .sort({ createdAt: -1 })
        .skip(skip)
        .limit(limit)
        .select('email source utm ip userAgent createdAt')
        .lean()
    ]);

    return res.json({ total, limit, skip, items });
  } catch (e) {
    console.error('ADMIN LEADS ERROR:', e);
    return res.status(500).json({ msg: 'Erreur serveur' });
  }
});

app.get('/api/admin/leads.csv', auth, requireAdmin, async (req, res) => {
  try {
    const limit = Math.min(parseInt(req.query.limit || '5000', 10), 20000);
    const skip = Math.max(parseInt(req.query.skip || '0', 10), 0);

    const items = await Lead.find({})
      .sort({ createdAt: -1 })
      .skip(skip)
      .limit(limit)
      .select('email source utm ip userAgent createdAt')
      .lean();

    const header = [
      'createdAt',
      'email',
      'source',
      'utm',
      'ip',
      'userAgent'
    ].join(',');

    const rows = items.map(x => [
      csvEscape(x.createdAt ? new Date(x.createdAt).toISOString() : ''),
      csvEscape(x.email || ''),
      csvEscape(x.source || ''),
      csvEscape(x.utm ? (typeof x.utm === 'string' ? x.utm : JSON.stringify(x.utm)) : ''),
      csvEscape(x.ip || ''),
      csvEscape(x.userAgent || '')
    ].join(','));

    const csv = [header, ...rows].join('\n');

    res.setHeader('Content-Type', 'text/csv; charset=utf-8');
    res.setHeader('Content-Disposition', 'attachment; filename="doc2loc-leads.csv"');
    return res.send(csv);
  } catch (e) {
    console.error('ADMIN LEADS CSV ERROR:', e);
    return res.status(500).send('Erreur serveur');
  }
});



