// --- ADMIN GUARD (emails autorisés via .env ADMIN_EMAILS) ---
async function requireAdmin(req, res, next) {
  try {
    const me = await User.findById(req.user.id).select('email');
    const allowed = (process.env.ADMIN_EMAILS || '')
      .split(',')
      .map(s => s.trim().toLowerCase())
      .filter(Boolean);

    const myEmail = (me && me.email ? me.email : '').toLowerCase();

    if (!myEmail || allowed.length === 0 || !allowed.includes(myEmail)) {
      return res.status(403).json({ msg: 'Accès refusé' });
    }

    return next();
  } catch (e) {
    console.error('ADMIN GUARD ERROR:', e);
    return res.status(500).json({ msg: 'Erreur serveur' });
  }
}



