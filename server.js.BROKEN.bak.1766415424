// =====================
// PDF
// =====================
function createPdfBuffer(property, tenant, owner) {
  return new Promise((resolve, reject) => {
    try {
      const doc = new PDFDocument({ size: 'A4', margin: 40 });
      const buffers = [];
      doc.on('data', buffers.push.bind(buffers));
      doc.on('end', () => resolve(Buffer.concat(buffers)));

      const formatName = (email) => (email || '').split('@')[0].toUpperCase();
      const ownerName =
        (owner.firstName && owner.lastName)
          ? (owner.firstName + ' ' + owner.lastName)
          : formatName(owner.email);

      const ownerAddr = owner.address || 'Adresse à compléter';
      const ownerCity = (owner.zipCode && owner.city) ? (owner.zipCode + ' ' + owner.city) : '';

      const date = new Date();
      const f = new Date(date.getFullYear(), date.getMonth(), 1).toLocaleDateString('fr-FR');
      const l = new Date(date.getFullYear(), date.getMonth() + 1, 0).toLocaleDateString('fr-FR');
      const today = date.toLocaleDateString('fr-FR');

      // Header
      doc.rect(0, 0, 600, 120).fill('#f8f9fa');
      doc.fillColor('#333');
      doc.fontSize(22).font('Helvetica-Bold').text('QUITTANCE DE LOYER', 40, 40);
      doc.fontSize(10).font('Helvetica').text('Période du ' + f + ' au ' + l, 40, 70);
      doc.fontSize(10).font('Helvetica-Bold').text('DOC2LOC', 450, 40, { align: 'right' });

      // Adresses
      const y = 150;
      doc.font('Helvetica-Bold').fontSize(9).text('BAILLEUR', 40, y);
      doc.font('Helvetica').fontSize(10).text(ownerName, 40, y + 15);
      doc.text(ownerAddr, 40, y + 30);
      doc.text(ownerCity, 40, y + 45);

      doc.font('Helvetica-Bold').fontSize(9).text('LOCATAIRE', 350, y);
      doc.font('Helvetica').fontSize(10);

      if (tenant) {
        doc.text(tenant.firstName + ' ' + tenant.lastName, 350, y + 15);
        doc.text('Bien : ' + property.name, 350, y + 30);
        doc.text(property.address, 350, y + 45, { width: 200 });
      } else {
        doc.text('---', 350, y + 15);
      }

      // Tableau
      const yt = 260;
      doc.rect(40, yt, 515, 25).fill('#333');
      doc.fillColor('#fff').font('Helvetica-Bold').text('DÉSIGNATION', 50, yt + 8);
      doc.text('MONTANT', 450, yt + 8, { align: 'right', width: 60 });

      doc.fillColor('#333').font('Helvetica');
      let cy = yt + 40;
      doc.text('Loyer mensuel', 50, cy);
      doc.text(Number(property.rentAmount || 0).toFixed(2) + ' EUR', 450, cy, { align: 'right', width: 60 });
      doc.moveTo(40, cy + 15).lineTo(555, cy + 15).strokeColor('#e0e0e0').stroke();

      cy += 25;
      doc.text('Provision charges', 50, cy);
      doc.text('0.00 EUR', 450, cy, { align: 'right', width: 60 });

      cy += 35;
      doc.font('Helvetica-Bold').fontSize(12).text('TOTAL PAYÉ', 50, cy);
      doc.text(Number(property.rentAmount || 0).toFixed(2) + ' EUR', 450, cy, { align: 'right', width: 60 });

      // Footer
      doc.font('Helvetica').fontSize(10).text(
        'Je soussigné(e) ' + ownerName + ', certifie avoir reçu le montant total.',
        40,
        460,
        { align: 'justify', width: 515 }
      );
      doc.text('Fait à ' + (owner.city || 'Lyon') + ', le ' + today, 40, 530);
      doc.rect(380, 520, 150, 60).strokeColor('#333').stroke();
      doc.fontSize(8).text('Signature', 390, 525);
      doc.end();
    } catch (e) {
      reject(e);
    }
  });
}

// =====================
// ROUTES AUTH
// =====================
app.post('/api/auth/register', async (req, res) => {
  try {
    const { email, password } = req.body;

    let u = await User.findOne({ email });
    if (u) return res.status(400).json({ msg: 'Pris' });

    const s = await bcrypt.genSalt(10);
    u = new User({
      email,
      password: await bcrypt.hash(password, s),
      plan: 'FREE',
      credits: 0,
      usage: { receipts: { month: monthKey(), sent: 0 } }
    });
    await u.save();

    return res.json({ msg: 'OK' });
  } catch (e) {
    console.error(e);
    return res.status(500).send('Err');
  }
});

app.post('/api/auth/login', async (req, res) => {
  try {
    const { email, password } = req.body;
    const u = await User.findOne({ email });

    // ✅ si email inconnu => pas de crash
    if (!u) return res.status(400).json({ msg: 'Identifiants invalides' });

    const isMatch = await bcrypt.compare(password, u.password);
    if (!isMatch) return res.status(400).json({ msg: 'Identifiants invalides' });

    const t = jwt.sign({ user: { id: u.id } }, JWT_SECRET, { expiresIn: '24h' });
    return res.json({ token: t });
  } catch (e) {
    console.error(e);
    return res.status(500).send('Err');
  }
});

app.get('/api/auth/profile', auth, async (req, res) => {
  try {
    return res.json(await User.findById(req.user.id).select('-password'));
  } catch (e) {
    console.error(e);
    return res.status(500).send('Err');
  }
});


// =====================
// BILLING STATUS (Sprint 0)
// =====================
function monthKey(d = new Date()) {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  return `${y}-${m}`;
}

app.get('/api/billing/status', auth, async (req, res) => {
  try {
    const u = await User.findById(req.user.id);

    const plan = (u && u.plan) ? u.plan : 'FREE';
    const credits = Number((u && u.credits) || 0);

    const current = monthKey();
    const storedMonth = u?.usage?.receipts?.month || '';
    let sent = Number(u?.usage?.receipts?.sent || 0);

    // reset auto au changement de mois
    if (storedMonth !== current) {
      if (!u.usage) u.usage = {};
      if (!u.usage.receipts) u.usage.receipts = {};
      u.usage.receipts.month = current;
      u.usage.receipts.sent = 0;
      sent = 0;
      await u.save();
    }

    const limits = {
      receiptEmailPerMonth: { FREE: 3, PRO: -1 } // -1 = illimité
    };

    const canSendReceiptEmail = (plan === 'PRO') ? true : (sent < limits.receiptEmailPerMonth.FREE);

    return res.json({
      plan,
      credits,
      usage: { receiptsMonth: current, receiptsSent: sent },
      limits,
      can: { sendReceiptEmail: canSendReceiptEmail }
    });
  } catch (e) {
    console.error(e);
    return res.status(500).json({ msg: 'Erreur billing/status' });
  }
});


app.put('/api/auth/profile', auth, async (req, res) => {
  try {
    const u = await User.findById(req.user.id);
    if (u) {
      Object.assign(u, req.body);
      await u.save();
      return res.json(u);
    }
    return res.status(404).json({ msg: 'Utilisateur introuvable' });
  } catch (e) {
    console.error(e);
    return res.status(500).send('Err');
  }
});

