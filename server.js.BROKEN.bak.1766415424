// --- LEADS (landing) ---
// stockage email + anti-spam basique par IP (mémoire) pour éviter les floods
const leadRate = new Map(); // key=ip, value={count, ts}
function tooManyLeads(ip) {
  const now = Date.now();
  const windowMs = 60 * 1000; // 1 minute
  const max = 10; // 10 req/min/IP
  const cur = leadRate.get(ip) || { count: 0, ts: now };
  if (now - cur.ts > windowMs) {
    leadRate.set(ip, { count: 1, ts: now });
    return false;
  }
  cur.count += 1;
  leadRate.set(ip, cur);
  return cur.count > max;
}

app.post('/api/public/lead', async (req, res) => {
  try {
    const ip =
      (req.headers['x-forwarded-for'] || '').split(',')[0].trim() ||
      req.socket?.remoteAddress ||
      '';

    if (tooManyLeads(ip)) {
      // on ne donne pas trop d'info aux bots
      return res.status(429).json({ msg: 'Trop de tentatives, réessaie plus tard.' });
    }

    const { email, source, utm } = req.body || {};
    const normalizedEmail = (email || '').toString().trim().toLowerCase();

    if (!normalizedEmail || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(normalizedEmail)) {
      return res.status(400).json({ msg: 'Email invalide' });
    }

    // upsert : si le lead existe déjà -> on met à jour source/utm
    await Lead.findOneAndUpdate(
      { email: normalizedEmail },
      {
        $set: {
          email: normalizedEmail,
          source: (source || '').toString().slice(0, 120),
          utm: utm ? utm : null,
          ip: ip.toString().slice(0, 80),
          userAgent: (req.headers['user-agent'] || '').toString().slice(0, 200)
        }
      },
      { upsert: true, new: true }
    );

    // Toujours OK (simple)
    return res.json({ msg: 'OK' });
  } catch (e) {
    // si l’index unique déclenche un duplicate key: on renvoie OK
    if (e && e.code === 11000) return res.json({ msg: 'OK' });
    console.error('LEAD ERROR:', e);
    return res.status(500).json({ msg: 'Erreur serveur' });
  }
});


