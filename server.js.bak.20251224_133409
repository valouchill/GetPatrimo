async function validateFrenchCommune(zipCode, city) {
  // Validation via API officielle : https://geo.api.gouv.fr
  // Retourne true/false. Si l’API est KO, on renvoie false (strict).
  const z = String(zipCode || '').trim();
  const c = String(city || '').trim();
  if (!/^\d{5}$/.test(z)) return false;
  if (!c) return false;

  const url =
    "https://geo.api.gouv.fr/communes?nom=" +
    encodeURIComponent(c) +
    "&codePostal=" +
    encodeURIComponent(z) +
    "&fields=nom,codesPostaux&limit=5";

  const ctrl = new AbortController();
  const t = setTimeout(() => ctrl.abort(), 3500);

  try {
    const r = await fetch(url, { signal: ctrl.signal, headers: { "accept": "application/json" } });
    if (!r.ok) return false;
    const arr = await r.json();
    return Array.isArray(arr) && arr.length > 0;
  } catch (e) {
    return false;
  } finally {
    clearTimeout(t);
  }
}


