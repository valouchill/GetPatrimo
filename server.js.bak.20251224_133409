// --- PAYWALL HELPERS ---
const PLAN_LIMITS = {
  FREE: { receiptEmailPerMonth: 3 },
  PRO:  { receiptEmailPerMonth: 999999 }
};

function monthKey(d = new Date()) {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  return `${y}-${m}`;
}

async function ensureUsageMonth(userDoc) {
  if (!userDoc) return null;
  const key = monthKey();
  if (!userDoc.usage) userDoc.usage = {};
  if (!userDoc.usage.receipts) userDoc.usage.receipts = { month: key, sent: 0 };

  // reset monthly counter
  if (userDoc.usage.receipts.month !== key) {
    userDoc.usage.receipts.month = key;
    userDoc.usage.receipts.sent = 0;
    await userDoc.save();
  }
  return userDoc;
}

function getPlan(u) {
  const p = String(u?.plan || 'FREE').toUpperCase();
  return (p === 'PRO') ? 'PRO' : 'FREE';
}

function receiptLimitFor(plan) {
  const lim = PLAN_LIMITS[plan]?.receiptEmailPerMonth;
  return Number.isFinite(lim) ? lim : PLAN_LIMITS.FREE.receiptEmailPerMonth;
}

async function requireReceiptEmailQuota(req, res, next) {
  try {
    const u = await User.findById(req.user.id).select('plan usage');
    if (!u) return res.status(401).json({ msg: 'Utilisateur introuvable' });
    await ensureUsageMonth(u);

    const plan = getPlan(u);
    const sent = Number(u?.usage?.receipts?.sent || 0) || 0;
    const limit = receiptLimitFor(plan);

    if (sent >= limit) {
      return res.status(402).json({
        msg: `Limite atteinte : ${limit} email(s) de quittance / mois sur le plan ${plan}.`,
        code: 'PAYWALL_LIMIT',
        plan,
        usage: { receiptsSent: sent, month: u?.usage?.receipts?.month || monthKey() },
        limits: { receiptEmailPerMonth: limit },
        upgradeUrl: '/pricing.html'
      });
    }

    req.billing = { plan, sent, limit, remaining: Math.max(0, limit - sent) };
    return next();
  } catch (e) {
    console.error('requireReceiptEmailQuota error:', e && e.message);
    return res.status(500).json({ msg: 'Erreur serveur' });
  }
}

async function markReceiptEmailSent(userId) {
  try {
    const u = await User.findById(userId);
    if (!u) return;
    await ensureUsageMonth(u);
    const cur = Number(u?.usage?.receipts?.sent || 0) || 0;
    u.usage.receipts.sent = cur + 1;
    await u.save();
  } catch (e) {
    console.error('markReceiptEmailSent error:', e && e.message);
  }
}


