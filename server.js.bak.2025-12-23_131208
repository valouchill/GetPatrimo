app.put('/api/tenants/:id', auth, async (req, res) => {
  try {
    const t = await Tenant.findOne({ _id: req.params.id, user: req.user.id });
    if (!t) return res.status(404).json({ msg: 'Locataire introuvable' });

    const { firstName, lastName, email, property } = req.body || {};

    if (typeof firstName === 'string') t.firstName = firstName.trim();
    if (typeof lastName === 'string') t.lastName = lastName.trim();
    if (typeof email === 'string') t.email = email.trim().toLowerCase();

    // property: ""/null -> unlink
    if (property === '' || property === null) {
      t.property = undefined;
    } else if (property) {
      const p = await Property.findOne({ _id: property, user: req.user.id });
      if (!p) return res.status(404).json({ msg: 'Bien introuvable' });

      const other = await Tenant.findOne({ user: req.user.id, property: p._id, _id: { $ne: t._id } });
      if (other) return res.status(409).json({ msg: 'Ce bien a déjà un locataire' });

      t.property = p._id;
    }

    await t.save();
    const populated = await Tenant.findById(t._id).populate('property');
    return res.json(populated);
  } catch (e) {
    if (e && e.code === 11000) return res.status(409).json({ msg: 'Ce bien a déjà un locataire' });
    console.error(e);
    return res.status(500).json({ msg: 'Erreur serveur' });
  }
});

