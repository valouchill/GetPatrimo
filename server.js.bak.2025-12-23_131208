    if (!t.property) return res.status(400).json({ msg: "Aucun bien associé au locataire" });

    const pty = t.property;

    const fullName = [t.firstName, t.lastName].filter(Boolean).join(" ").trim() || "Bonjour";
    const propName = pty.name || "votre logement";
    const addr = [pty.addressLine, pty.zipCode, pty.city].filter(Boolean).join(", ") || (pty.address || "");

    const subjects = {
      rent_reminder: "Rappel — Quittance / loyer",
      missing_docs: "Rappel — Documents à fournir",
      late_payment: "Relance — Paiement en attente"
    };

    const bodies = {
      rent_reminder:
`Bonjour ${fullName},

Petit rappel concernant la quittance / le loyer pour ${propName}${addr ? " ("+addr+")" : ""}.
Si vous avez déjà effectué le règlement, vous pouvez ignorer ce message.

Cordialement,
Doc2Loc`,
      missing_docs:
`Bonjour ${fullName},

Pour finaliser votre dossier concernant ${propName}${addr ? " ("+addr+")" : ""}, il nous manque certains documents.
Pouvez-vous les transmettre dès que possible ?

Cordialement,
Doc2Loc`,
      late_payment:
`Bonjour ${fullName},

Nous n'avons pas constaté le règlement attendu pour ${propName}${addr ? " ("+addr+")" : ""}.
Merci de nous indiquer votre situation ou de procéder au paiement dès que possible.

Cordialement,
Doc2Loc`
    };

    const subject = subjects[tpl] || subjects.rent_reminder;
    const text = bodies[tpl] || bodies.rent_reminder;


    console.log('REMINDER_DEBUG_START', { tenant: String(t._id), to: t.email, property: String(pty._id), template: tpl });
