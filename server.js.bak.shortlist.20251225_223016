function genApplyToken(){
  return crypto.randomBytes(16).toString('hex');
}
function buildApplyUrl(req, token){
  const proto = (req.headers['x-forwarded-proto'] ? String(req.headers['x-forwarded-proto']).split(',')[0].trim() : req.protocol) || "https";
  const host = req.headers['x-forwarded-host'] || req.get('host');
  return `${proto}://${host}/apply.html?token=${encodeURIComponent(token)}`;
}

