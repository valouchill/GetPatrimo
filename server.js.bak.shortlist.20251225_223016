});


// --- RGPD: purge automatique des candidatures ---
async function purgeOldCandidatures(){
  const days = Number(process.env.CANDIDATURE_RETENTION_DAYS || 30);
  const cutoff = new Date(Date.now() - days * 24 * 60 * 60 * 1000);

  try{
    const old = await Candidature.find({ createdAt: { $lt: cutoff } }).lean();
    if(!old.length) return;

    for(const c of old){
      for(const d of (c.docs || [])){
        try{
          const abs = safeJoinUploads(d.relPath);
          if(abs && fs.existsSync(abs)) fs.unlinkSync(abs);
        }catch(_){}
      }
    }

    await Candidature.deleteMany({ createdAt: { $lt: cutoff } });
    console.log(`[RGPD] Purge candidatures: ${old.length} supprimée(s) (>${days}j)`);
  }catch(e){
    console.error("[RGPD] purgeOldCandidatures error:", e && e.message);
  }
}

