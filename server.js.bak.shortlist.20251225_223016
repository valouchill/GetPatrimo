app.get('/api/alerts/overview', auth, async (req, res) => {
  try {
    const now = new Date();
    const startMonth = new Date(now.getFullYear(), now.getMonth(), 1);
    const day = now.getDate();

    const props = await Property.find({ user: req.user.id }).lean();
    const tenants = await Tenant.find({ user: req.user.id }).select('property firstName lastName email').lean();

    // tenants by property
    const tenantByProp = new Map();
    for (const t of tenants) {
      if (t.property) tenantByProp.set(String(t.property), t);
    }

    // docs by property (bail / edl / diag)
    const docTypesByProp = new Map(); // propId -> Set(types)
    try {
      const propIds = props.map(pr => pr._id);
      const docs = await Document.find({
        user: req.user.id,
        property: { $in: propIds },
        type: { $in: ['bail', 'edl', 'diag'] }
      }).select('property type').lean();

      for (const d of docs) {
        if (!d.property) continue;
        const k = String(d.property);
        if (!docTypesByProp.has(k)) docTypesByProp.set(k, new Set());
        docTypesByProp.get(k).add(String(d.type || ''));
      }
    } catch (e) {
      // si le modèle/collection docs diffère, on ne bloque jamais l’app
      console.error("alerts docs map warning:", e && e.message);
    }

    // events: quittance envoyée ce mois (par bien)
    const evMonth = await Event.find({
      user: req.user.id,
      type: 'email_quittance_sent',
      createdAt: { $gte: startMonth }
    }).select('property createdAt').lean();

    const lastQuittanceThisMonth = new Map(); // propId -> Date
    for (const e of evMonth) {
      if (!e.property) continue;
      const k = String(e.property);
      const d = new Date(e.createdAt);
      const prev = lastQuittanceThisMonth.get(k);
      if (!prev || d > prev) lastQuittanceThisMonth.set(k, d);
    }

    // events: dernière relance (14 jours) par bien
    const since14 = new Date(now.getTime() - 14 * 24 * 60 * 60 * 1000);
    const evRem = await Event.find({
      user: req.user.id,
      type: 'reminder_sent',
      createdAt: { $gte: since14 }
    }).select('property createdAt meta tenant').lean();

    const lastReminder = new Map(); // propId -> { date, template, tenantId }
    for (const e of evRem) {
      if (!e.property) continue;
      const k = String(e.property);
      const d = new Date(e.createdAt);
      const prev = lastReminder.get(k);
      if (!prev || d > prev.date) {
        lastReminder.set(k, {
          date: d,
          template: e?.meta?.template || null,
          tenantId: e?.tenant ? String(e.tenant) : null
        });
      }
    }

    const alerts = [];

    const add = (a) => alerts.push(a);

    // helper: severity order
    const sevRank = { critical: 0, warning: 1, info: 2 };

    for (const pr of props) {
      const pid = String(pr._id);
      const t = tenantByProp.get(pid);

      const propName = pr.name || "Sans nom";
      const hasTenant = !!t;
      const tenantEmail = (t && t.email) ? String(t.email).trim() : "";
      const rent = Number(pr.rentAmount || 0);
      const hasRent = Number.isFinite(rent) && rent > 0;

      const hasAddrV2 = !!(pr.addressLine && pr.zipCode && pr.city);
      const hasAddrLegacy = !!pr.address;

      // 1) Locataire manquant
      if (!hasTenant) {
        add({
          severity: "warning",
          code: "NO_TENANT",
          title: "Locataire manquant",
          message: `Le bien “${propName}” n’a pas de locataire associé.`,
          action: { label: "Ouvrir le bien", href: `/property.html?id=${pid}` },
          propertyId: pid
        });
      }

      // 2) Email locataire manquant
      if (hasTenant && !tenantEmail) {
        add({
          severity: "critical",
          code: "TENANT_NO_EMAIL",
          title: "Email locataire manquant",
          message: `Impossible d’envoyer quittance / relance pour “${propName}”.`,
          action: { label: "Ouvrir le locataire", href: `/tenant.html?id=${t._id}` },
          propertyId: pid,
          tenantId: String(t._id)
        });
      }

      // 3) Loyer non renseigné
      if (!hasRent) {
        add({
          severity: "critical",
          code: "MISSING_RENT",
          title: "Loyer non renseigné",
          message: `Renseigne le loyer du bien “${propName}” pour générer les quittances.`,
          action: { label: "Ouvrir le bien", href: `/property.html?id=${pid}` },
          propertyId: pid
        });
      }

      // 4) Adresse incomplète (utile pour propreté et futur encaissement)
      if (!hasAddrV2 && !hasAddrLegacy) {
        add({
          severity: "warning",
          code: "MISSING_ADDRESS",
          title: "Adresse manquante",
          message: `Complète l’adresse du bien “${propName}” (utile pour documents & automatisations).`,
          action: { label: "Ouvrir le bien", href: `/property.html?id=${pid}` },
          propertyId: pid
        });
      }

      // 5) Dossier incomplet (bail / edl / diag) — seulement si bien occupé
      if (hasTenant) {
        const types = docTypesByProp.get(pid) || new Set();
        const missing = [];
        if (!types.has("bail")) missing.push("bail");
        if (!types.has("edl")) missing.push("EDL");
        if (!types.has("diag")) missing.push("diagnostics");

        if (missing.length > 0) {
          add({
            severity: (missing.length >= 2 ? "warning" : "info"),
            code: "DOSSIER_INCOMPLETE",
            title: "Dossier incomplet",
            message: `Il manque ${missing.join(", ")} pour “${propName}”.`,
            action: { label: "Ouvrir le bien", href: `/property.html?id=${pid}` },
            propertyId: pid
          });
        }
      }

      // 6) Intelligence temps : quittance pas envoyée ce mois (si occupé + email + loyer)
      if (hasTenant && tenantEmail && hasRent) {
        const hasQuittance = lastQuittanceThisMonth.has(pid);

        // après le 5 → warning, après le 10 → critical
        if (!hasQuittance) {
          let sev = "info";
          if (day >= 10) sev = "critical";
          else if (day >= 5) sev = "warning";

          add({
            severity: sev,
            code: "QUITTANCE_NOT_SENT_THIS_MONTH",
            title: "Quittance à envoyer",
            message: `Aucune quittance email envoyée ce mois pour “${propName}”.`,
            action: { label: "Ouvrir le bien", href: `/property.html?id=${pid}` },
            propertyId: pid,
            tenantId: String(t._id)
          });

          // 7) Relance recommandée : si pas de quittance ce mois + pas de relance depuis 7 jours
          const lastR = lastReminder.get(pid);
          const since7 = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
          const okRecent = lastR && lastR.date && (lastR.date >= since7);

          if (day >= 8 && !okRecent) {
            add({
              severity: (day >= 12 ? "warning" : "info"),
              code: "REMINDER_RECOMMENDED",
              title: "Relance recommandée",
              message: `Relance conseillée (aucune quittance envoyée ce mois + pas de relance récente) pour “${propName}”.`,
              action: { label: "Ouvrir le locataire", href: `/tenant.html?id=${t._id}` },
              propertyId: pid,
              tenantId: String(t._id)
            });
          }
        }
      }
    }

    // tri : critical -> warning -> info
    alerts.sort((a,b) => {
      const ra = sevRank[a.severity] ?? 9;
      const rb = sevRank[b.severity] ?? 9;
      if (ra != rb) return ra - rb;
      return String(a.title||"").localeCompare(String(b.title||""), "fr");
    });

    const counts = {
      critical: alerts.filter(a=>a.severity==="critical").length,
      warning: alerts.filter(a=>a.severity==="warning").length,
      info: alerts.filter(a=>a.severity==="info").length
    };

    // tips globaux simples
    const occupied = props.filter(pr => tenantByProp.has(String(pr._id))).length;
    const tips = [];
    if (occupied >= 2) tips.push("Astuce: active les automatisations mensuelles pour ne plus jamais oublier une quittance.");
    if (counts.critical > 0) tips.push("Priorité: corrige d’abord les alertes critiques (email locataire / loyer).");

    return res.json({
      computedAt: now.toISOString(),
      overview: { properties: props.length, tenants: tenants.length, occupied },
      counts,
      alerts: alerts.slice(0, 50),
      top: alerts.slice(0, 5),
      tips
    });
  } catch (e) {
    console.error("alerts overview error:", e && (e.stack || e));
    return res.status(500).json({ msg: "Erreur serveur" });
  }
});


