app.get('/api/onboarding/status', auth, async (req, res) => {
  try {
    const userId = req.user.id;

    const [propertiesCount, tenantsCount] = await Promise.all([
      Property.countDocuments({ user: userId }),
      Tenant.countDocuments({ user: userId })
    ]);

    const firstProperty = await Property.findOne({ user: userId }).sort({ createdAt: 1 }).select('_id');

    const start = new Date(new Date().getFullYear(), new Date().getMonth(), 1, 0, 0, 0, 0);
    const receiptsSentThisMonth = await Event.countDocuments({
      user: userId,
      type: 'email_quittance_sent',
      createdAt: { $gte: start }
    });

    const hasProperty = propertiesCount > 0;
    const hasTenant = tenantsCount > 0;
    const hasSentReceipt = receiptsSentThisMonth > 0;

    let next = { action: 'DONE' };
    if (!hasProperty) next = { action: 'CREATE_PROPERTY' };
    else if (!hasTenant) next = { action: 'ASSIGN_TENANT', propertyId: firstProperty ? String(firstProperty._id) : null };
    else if (!hasSentReceipt) next = { action: 'SEND_RECEIPT', propertyId: firstProperty ? String(firstProperty._id) : null };
    else next = { action: 'DONE' };

    return res.json({
      hasProperty,
      hasTenant,
      hasSentReceipt,
      counts: {
        properties: propertiesCount,
        tenants: tenantsCount,
        receiptsSentThisMonth
      },
      next
    });
  } catch (e) {
    console.error(e);
    return res.status(500).json({ msg: 'Erreur serveur' });
  }
});

