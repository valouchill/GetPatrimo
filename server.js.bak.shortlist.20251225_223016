function sanitizeFileName(name){
  const base = path.basename(String(name || '')).replace(/[\r\n\t]/g,' ').trim();
  const cleaned = base.replace(/[\\/]/g, '-').replace(/[^a-zA-Z0-9._ -]/g, '');
  return cleaned.slice(0, 120) || 'document';
}

function safeJoinUploads(relPath){
  const rel = String(relPath || '');
  const abs = path.resolve(uploadsDir, rel);
  const root = path.resolve(uploadsDir) + path.sep;
  if (!abs.startsWith(root)) return null;
  return abs;
}

// --- SIMPLE RATE LIMIT (memory) ---
function createRateLimiter({ windowMs, max, keyFn }){
  const store = new Map(); // key -> {count, reset}
  return (req, res, next) => {
    const now = Date.now();
    const key = (keyFn ? keyFn(req) : req.ip) || 'unknown';
    const cur = store.get(key);
    if (!cur || now > cur.reset){
      store.set(key, { count: 1, reset: now + windowMs });
      return next();
    }
    cur.count += 1;
    if (cur.count > max){
      const retry = Math.max(1, Math.floor((cur.reset - now) / 1000));
      res.setHeader('Retry-After', String(retry));
      return res.status(429).json({ msg: 'Trop de requêtes — réessayez plus tard.' });
    }
    return next();
  };
}

