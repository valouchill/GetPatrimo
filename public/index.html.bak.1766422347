<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Doc2Loc — Choisis le bon locataire, puis automatise tes loyers</title>
  <meta name="description" content="Collecte des dossiers candidats + scoring, coffre-fort (bail, état des lieux, diagnostics), quittances et relances. Commence gratuitement en 2 minutes."/>
  <link rel="canonical" href="https://doc2loc.com/"/>
  <meta property="og:title" content="Doc2Loc — Choisis le bon locataire, puis automatise tes loyers"/>
  <meta property="og:description" content="Scoring + shortlist, coffre-fort documents, quittances & relances. Commence gratuitement."/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content="https://doc2loc.com/"/>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap">

  <style>
    :root{
      --bg:#0B1220;
      --bg2:#0F172A;
      --card:#111B2E;
      --card2:#0D1526;
      --text:#E5E7EB;
      --muted:#94A3B8;
      --border:rgba(148,163,184,.18);
      --accent:#4F46E5;
      --accent2:#22C55E;
      --danger:#F87171;
      --shadow:0 20px 60px rgba(0,0,0,.35);
      --r:22px;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,sans-serif;background:radial-gradient(1200px 500px at 20% 0%, rgba(79,70,229,.25), transparent 60%), radial-gradient(1000px 600px at 90% 10%, rgba(34,197,94,.18), transparent 55%), linear-gradient(180deg,var(--bg),var(--bg2)); color:var(--text)}
    a{color:inherit}
    .container{max-width:1150px;margin:0 auto;padding:22px}
    .nav{display:flex;align-items:center;justify-content:space-between;gap:12px;position:sticky;top:0;background:linear-gradient(180deg,rgba(11,18,32,.95),rgba(11,18,32,.65));backdrop-filter: blur(10px);border-bottom:1px solid var(--border);z-index:50}
    .brand{display:flex;align-items:center;gap:10px;font-weight:900;letter-spacing:-.02em}
    .logo{width:34px;height:34px;border-radius:12px;background:linear-gradient(135deg,var(--accent),#818CF8);box-shadow:0 10px 30px rgba(79,70,229,.25)}
    .navlinks{display:flex;align-items:center;gap:14px;flex-wrap:wrap}
    .pill{padding:10px 12px;border:1px solid var(--border);border-radius:999px;background:rgba(255,255,255,.04);font-weight:800;font-size:13px;text-decoration:none}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:12px 14px;border-radius:14px;border:1px solid var(--border);background:rgba(255,255,255,.04);color:var(--text);font-weight:900;cursor:pointer;text-decoration:none}
    .btn.primary{background:var(--accent);border-color:rgba(79,70,229,.35)}
    .btn.green{background:rgba(34,197,94,.16);border-color:rgba(34,197,94,.35);color:#D1FAE5}
    .btn:hover{transform:translateY(-1px)}
    .hero{padding:48px 0 10px}
    .grid{display:grid;grid-template-columns:1.1fr .9fr;gap:18px;align-items:stretch}
    @media (max-width: 980px){.grid{grid-template-columns:1fr}.navlinks{gap:8px}}
    h1{margin:0;font-size:44px;line-height:1.06;letter-spacing:-.04em}
    @media (max-width: 540px){h1{font-size:34px}}
    .sub{margin-top:14px;color:var(--muted);font-size:15px;line-height:1.65}
    .card{background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03)); border:1px solid var(--border); border-radius:var(--r); box-shadow:var(--shadow); padding:18px}
    .hero-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}
    .micro{margin-top:10px;color:var(--muted);font-weight:700;font-size:12px}
    .proof{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:18px}
    @media (max-width: 980px){.proof{grid-template-columns:1fr}}
    .proof .p{border:1px solid var(--border);border-radius:16px;background:rgba(255,255,255,.03);padding:14px;font-weight:900}
    .p small{display:block;color:var(--muted);font-weight:700;margin-top:6px;line-height:1.45}
    .section{padding:34px 0}
    .h2{font-size:22px;font-weight:900;letter-spacing:-.02em;margin:0 0 12px 0}
    .muted{color:var(--muted);font-weight:700}
    .twocol{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    @media (max-width: 980px){.twocol{grid-template-columns:1fr}}
    .box{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:20px;padding:16px}
    .box h3{margin:0 0 6px 0;font-size:16px}
    ul{margin:10px 0 0 18px;color:var(--muted);font-weight:700}
    .steps{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    @media (max-width: 980px){.steps{grid-template-columns:1fr}}
    .step{border:1px solid var(--border);border-radius:20px;background:rgba(255,255,255,.03);padding:14px}
    .step b{display:block;margin-bottom:6px}
    .pricing{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    @media (max-width: 980px){.pricing{grid-template-columns:1fr}}
    .price{border:1px solid var(--border);border-radius:22px;background:rgba(255,255,255,.03);padding:16px;display:flex;flex-direction:column;gap:10px}
    .price .tag{display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:900;color:var(--muted)}
    .price .big{font-size:26px;font-weight:900}
    .badge{display:inline-flex;padding:6px 10px;border-radius:999px;background:rgba(79,70,229,.18);border:1px solid rgba(79,70,229,.35);font-weight:900;font-size:12px}
    .badge.best{background:rgba(34,197,94,.14);border-color:rgba(34,197,94,.35);color:#D1FAE5}
    details{border:1px solid var(--border);border-radius:18px;background:rgba(255,255,255,.03);padding:12px}
    summary{cursor:pointer;font-weight:900}
    footer{padding:30px 0;color:var(--muted);font-weight:700}
    footer a{color:var(--muted);text-decoration:none}
    footer a:hover{text-decoration:underline}

    /* Sticky topbar (progress) */
    .topbar{
      position:fixed;left:12px;right:12px;top:12px;z-index:60;
      display:none;align-items:center;justify-content:space-between;gap:10px;
      background:rgba(17,27,46,.92);border:1px solid var(--border);border-radius:18px;
      padding:10px 12px;backdrop-filter: blur(10px);box-shadow:var(--shadow)
    }
    .topbar b{font-weight:900}
    .topbar .row{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .topbar .ghost{background:transparent}

    /* Modal */
    .modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.65);display:none;align-items:center;justify-content:center;z-index:80;padding:16px}
    .modal{max-width:820px;width:100%;background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.04));border:1px solid var(--border);border-radius:26px;box-shadow:var(--shadow);overflow:hidden}
    .modal header{padding:14px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:10px}
    .modal header .title{font-weight:900}
    .modal main{padding:16px}
    .modal footer{padding:14px 16px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap}
    .x{border:1px solid var(--border);background:rgba(255,255,255,.04);color:var(--text);border-radius:12px;padding:8px 10px;cursor:pointer;font-weight:900}
    .wizard{display:grid;grid-template-columns:1fr .9fr;gap:14px}
    @media(max-width:980px){.wizard{grid-template-columns:1fr}}
    .panel{border:1px solid var(--border);border-radius:20px;background:rgba(255,255,255,.03);padding:14px}
    .panel h4{margin:0 0 6px 0}
    .assistant{display:flex;flex-direction:column;gap:10px}
    .msg{padding:10px 12px;border-radius:16px;border:1px solid var(--border);background:rgba(255,255,255,.03);font-weight:800}
    .msg small{display:block;color:var(--muted);font-weight:700;margin-top:6px;line-height:1.45}
    .form{display:grid;gap:10px}
    label{font-weight:900;font-size:12px;color:var(--muted)}
    input,select{width:100%;padding:12px 12px;border-radius:14px;border:1px solid var(--border);background:rgba(15,23,42,.55);color:var(--text);font-weight:800}
    .row{display:flex;gap:10px;flex-wrap:wrap}
    .row > div{flex:1;min-width:160px}
    .hint{color:var(--muted);font-weight:700;font-size:12px;line-height:1.45}
    .err{color:#fecaca;font-weight:900;font-size:12px}
    .toast{position:fixed;right:16px;bottom:16px;display:none;background:#0B1220;border:1px solid var(--border);border-radius:16px;padding:10px 12px;box-shadow:var(--shadow);z-index:90;font-weight:900}
  </style>
</head>
<body>

<div class="topbar" id="topbar">
  <div class="row">
    <b>Votre brouillon est prêt ✅</b>
    <span class="muted" id="topbarHint">Finalisez en 1 clic.</span>
  </div>
  <div class="row">
    <button class="btn primary" onclick="openFlowFromTopbar()">Finaliser</button>
    <button class="btn ghost" onclick="dismissTopbar()">Plus tard</button>
  </div>
</div>

<div class="nav">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;gap:10px">
    <div class="brand">
      <div class="logo"></div>
      <div>doc2loc</div>
      <span class="pill" style="opacity:.9">Bailleur • Dossier • Quittances</span>
    </div>
    <div class="navlinks">
      <a class="pill" href="#pricing">Tarifs</a>
      <a class="pill" href="#faq">FAQ</a>
      <a class="btn" href="/login.html">Se connecter</a>
      <a class="btn primary" href="/register.html">Créer un compte</a>
    </div>
  </div>
</div>

<div class="container hero">
  <div class="grid">
    <div class="card">
      <h1>Choisis le bon locataire,<br/>puis automatise tes loyers.</h1>
      <div class="sub">
        Centralise ton bien, collecte les dossiers candidats, utilise le scoring pour trier en minutes,
        puis active l’encaissement automatique : <b>quittances, relances et historique inclus.</b>
      </div>

      <div class="hero-actions">
        <button class="btn primary" onclick="openFlow('quittance')">Générer une quittance (gratuit)</button>
        <button class="btn green" onclick="openFlow('candidature')">Créer un lien de candidature</button>
      </div>

      <div class="micro">Aperçu instantané • Sans carte bancaire • Annulable en 2 clics • Export à tout moment</div>

      <div class="proof">
        <div class="p">Scoring + shortlist<br><small>Choisir sereinement, sans boîte noire.</small></div>
        <div class="p">Coffre-fort documents<br><small>Bail, état des lieux, diagnostics, quittances.</small></div>
        <div class="p">Automatisation mensuelle<br><small>Encaissement + quittance + relances.</small></div>
      </div>
    </div>

    <div class="card" style="background:linear-gradient(180deg,rgba(79,70,229,.14),rgba(255,255,255,.03));">
      <div class="h2">Que veux-tu faire en premier ?</div>
      <div class="muted">Tu pourras tout activer plus tard, sans perdre tes infos.</div>

      <div style="margin-top:12px" class="twocol">
        <div class="box">
          <h3>✅ Bien déjà loué</h3>
          <div class="muted">Encaissement + quittances + relances.</div>
          <div style="margin-top:10px">
            <button class="btn primary" style="width:100%" onclick="openFlow('quittance')">Démarrer</button>
          </div>
          <div class="hint" style="margin-top:8px">Objectif : gagner du temps dès ce mois-ci.</div>
        </div>
        <div class="box">
          <h3>🔎 Recherche locataire</h3>
          <div class="muted">Dossiers + scoring + shortlist.</div>
          <div style="margin-top:10px">
            <button class="btn green" style="width:100%" onclick="openFlow('candidature')">Créer le lien</button>
          </div>
          <div class="hint" style="margin-top:8px">Les candidats déposent, tu reçois une shortlist.</div>
        </div>
      </div>

      <div style="margin-top:14px" class="box">
        <b>Astuce conversion (anti-friction)</b>
        <div class="hint" style="margin-top:6px">
          Tu peux commencer ici, on sauvegarde tout. On te demande le compte uniquement quand c’est prêt (PDF/lien).
        </div>
        <div class="row" style="margin-top:10px">
          <button class="btn" onclick="resumeIfAny()">Reprendre ma dernière action</button>
          <a class="btn" href="/dashboard.html" onclick="return allowDashboardOrLogin(event)">Ouvrir mon dashboard</a>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="container section">
  <div class="h2">Simple, clair, et prêt à l’emploi</div>
  <div class="steps">
    <div class="step"><b>1) Ajoute ton bien</b><div class="muted">adresse, loyer, charges</div></div>
    <div class="step"><b>2) Ajoute ton locataire</b><div class="muted">ou crée un lien candidature</div></div>
    <div class="step"><b>3) Génère & stocke</b><div class="muted">bail, état des lieux, quittances</div></div>
    <div class="step"><b>4) Automatise</b><div class="muted">encaissement → quittance → relances</div></div>
  </div>
</div>

<div class="container section" id="pricing">
  <div class="h2">Des offres simples. Tu commences gratuitement.</div>
  <div class="pricing">
    <div class="price">
      <div class="tag"><span class="badge">Gratuit</span> Pour tester</div>
      <div class="big">0€</div>
      <div class="muted">1 document • aperçu instantané • stockage basique</div>
      <button class="btn primary" onclick="openFlow('quittance')">Commencer gratuitement</button>
      <div class="hint">Sans carte bancaire.</div>
    </div>
    <div class="price">
      <div class="tag"><span class="badge">Pro Docs</span> Pour gérer tes documents</div>
      <div class="big">12,90€ / mois</div>
      <div class="muted">Docs illimités • coffre-fort • modèles à jour • 3 logements inclus</div>
      <button class="btn" onclick="openFlow('quittance')">Passer à Pro Docs</button>
      <div class="hint">Sans engagement. Annulable à tout moment.</div>
    </div>
    <div class="price">
      <div class="tag"><span class="badge best">⭐ Meilleur choix</span> Pro Encaissement</div>
      <div class="big">19,90€ / mois</div>
      <div class="muted">SEPA récurrent • quittances auto • relances • export</div>
      <button class="btn green" onclick="openFlow('quittance')">Activer l’encaissement</button>
      <div class="hint">Active en 2 minutes. Pause quand tu veux.</div>
    </div>
    <div class="price">
      <div class="tag"><span class="badge">One-shot</span> Mise en location</div>
      <div class="big">14,90€</div>
      <div class="muted">Lien candidature • collecte • scoring + shortlist • export dossier</div>
      <button class="btn green" onclick="openFlow('candidature')">Créer mon annonce</button>
      <div class="hint">Idéal si tu reloues maintenant.</div>
    </div>
  </div>
</div>

<div class="container section" id="faq">
  <div class="h2">FAQ</div>
  <div style="display:grid;gap:10px">
    <details>
      <summary>Le scoring est-il fiable ?</summary>
      <div class="muted" style="margin-top:10px">Le scoring s’appuie sur des critères factuels. Tu vois les raisons du score et tu peux ajuster tes règles.</div>
    </details>
    <details>
      <summary>Puis-je exporter mes documents et mes données ?</summary>
      <div class="muted" style="margin-top:10px">Oui. Export possible à tout moment.</div>
    </details>
    <details>
      <summary>Puis-je annuler facilement ?</summary>
      <div class="muted" style="margin-top:10px">Oui, sans engagement et annulable en 2 clics.</div>
    </details>
    <details>
      <summary>Encaissement : comment ça marche ?</summary>
      <div class="muted" style="margin-top:10px">Tu actives l’encaissement, le locataire signe le mandat, tu suis les paiements et tes quittances sont générées automatiquement.</div>
    </details>
  </div>
</div>

<div class="container">
  <footer>
    © 2025 doc2loc • <a href="/login.html">Connexion</a> • <a href="/register.html">Créer un compte</a> • <a href="/dashboard.html" onclick="return allowDashboardOrLogin(event)">Dashboard</a>
  </footer>
</div>

<!-- MODAL WIZARD -->
<div class="modal-bg" id="modalBg" role="dialog" aria-modal="true">
  <div class="modal">
    <header>
      <div class="title" id="modalTitle">Démarrer</div>
      <button class="x" onclick="closeModal()">✕</button>
    </header>
    <main>
      <div class="wizard">
        <div class="panel">
          <div class="form" id="formArea"></div>
          <div id="formError" class="err" style="display:none"></div>
          <div class="hint" id="formHint" style="margin-top:8px"></div>
        </div>

        <div class="panel">
          <div class="assistant" id="assistant">
            <div class="msg" id="msg1"></div>
            <div class="msg" id="msg2"></div>
            <div class="msg" id="msg3" style="display:none"></div>
          </div>
        </div>
      </div>
    </main>
    <footer>
      <div class="hint" id="stepHint">Sauvegarde automatique activée.</div>
      <div class="row">
        <button class="btn" id="backBtn" onclick="prevStep()" style="display:none">Retour</button>
        <button class="btn primary" id="nextBtn" onclick="nextStep()">Continuer</button>
      </div>
    </footer>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  // -----------------------------
  // Conversion mechanics
  // -----------------------------
  const DRAFT_KEY = "doc2loc_draft_v1";
  let flow = { mode: null, step: 1 };
  let draft = loadDraft() || {};

  function toast(msg){
    const t = document.getElementById("toast");
    t.textContent = msg;
    t.style.display = "block";
    setTimeout(()=>t.style.display="none", 2100);
  }

  function saveDraft(){
    try{
      localStorage.setItem(DRAFT_KEY, JSON.stringify(draft));
      maybeShowTopbar();
    }catch(e){}
  }
  function loadDraft(){
    try{
      const raw = localStorage.getItem(DRAFT_KEY);
      return raw ? JSON.parse(raw) : null;
    }catch(e){ return null; }
  }
  function clearDraft(){
    try{ localStorage.removeItem(DRAFT_KEY); }catch(e){}
  }

  function allowDashboardOrLogin(e){
    const tok = localStorage.getItem("token");
    if(!tok){
      e.preventDefault();
      draft.lastIntent = draft.lastIntent || "dashboard";
      saveDraft();
      location.href = "/login.html";
      return false;
    }
    return true;
  }

  function resumeIfAny(){
    const d = loadDraft();
    if(!d){ toast("Aucun brouillon trouvé"); return; }
    openFlow(d.mode || "quittance");
  }

  function dismissTopbar(){
    const tb = document.getElementById("topbar");
    tb.style.display = "none";
    draft.topbarDismissed = Date.now();
    saveDraft();
  }

  function openFlowFromTopbar(){
    openFlow((draft && draft.mode) ? draft.mode : "quittance");
  }

  function maybeShowTopbar(){
    const tb = document.getElementById("topbar");
    const hint = document.getElementById("topbarHint");
    const hasProgress = !!(draft && draft.property && draft.property.zipCode && draft.property.city && draft.property.rentAmount);
    const dismissedRecently = draft.topbarDismissed && (Date.now() - draft.topbarDismissed < 1000*60*10);
    if(hasProgress && !dismissedRecently){
      hint.textContent = (draft.mode === "candidature") ? "Ton lien est prêt. Débloque-le." : "Ta quittance est prête. Débloque-la.";
      tb.style.display = "flex";
    }
  }
  maybeShowTopbar();

  // -----------------------------
  // Wizard UI
  // -----------------------------
  function openFlow(mode){
    flow = { mode, step: 1 };
    draft.mode = mode;
    draft.property = draft.property || {};
    draft.tenant = draft.tenant || {};
    saveDraft();

    document.getElementById("modalBg").style.display = "flex";
    renderStep();
  }
  function closeModal(){
    document.getElementById("modalBg").style.display = "none";
  }

  function setAssistant(a,b,c=null){
    const m1 = document.getElementById("msg1");
    const m2 = document.getElementById("msg2");
    const m3 = document.getElementById("msg3");
    m1.innerHTML = a;
    m2.innerHTML = b;
    if(c){
      m3.style.display="block";
      m3.innerHTML = c;
    }else{
      m3.style.display="none";
    }
  }

  function showError(msg){
    const el = document.getElementById("formError");
    el.style.display = "block";
    el.textContent = msg;
  }
  function clearError(){
    const el = document.getElementById("formError");
    el.style.display = "none";
    el.textContent = "";
  }

  function setButtons(){
    document.getElementById("backBtn").style.display = (flow.step > 1) ? "inline-flex" : "none";
    document.getElementById("nextBtn").textContent =
      (flow.step === 3) ? "Créer mon compte & accéder" :
      (flow.step === 2 && flow.mode === "candidature") ? "Voir le lien" :
      "Continuer";
  }

  // Autocomplete communes
  async function fetchCommunes(zip){
    const z = String(zip||"").trim();
    if(!/^\d{5}$/.test(z)) return [];
    try{
      const url = "https://geo.api.gouv.fr/communes?codePostal=" + encodeURIComponent(z) + "&fields=nom&format=json&geometry=centre";
      const r = await fetch(url);
      if(!r.ok) return [];
      const arr = await r.json();
      return Array.isArray(arr) ? arr.map(x=>x.nom).filter(Boolean) : [];
    }catch(e){ return []; }
  }

  function renderStep(){
    clearError();
    setButtons();

    const title = document.getElementById("modalTitle");
    const form = document.getElementById("formArea");
    const hint = document.getElementById("formHint");
    const stepHint = document.getElementById("stepHint");

    const mode = flow.mode;
    const step = flow.step;

    // Step 1 = bien
    if(step === 1){
      title.textContent = (mode === "candidature") ? "Créer un lien de candidature" : "Générer une quittance (brouillon)";
      hint.textContent = "Tu peux modifier plus tard. Montants en €.";
      stepHint.textContent = "Étape 1/3 — Bien (sauvegarde auto)";

      setAssistant(
        "<b>Je te guide.</b><small>On commence par le bien. Ensuite on te propose le PDF / le lien.</small>",
        (mode === "candidature")
          ? "Objectif : un lien unique à partager. <small>Les candidats déposent, tu reçois une shortlist.</small>"
          : "Objectif : quittance prête en 30 secondes. <small>Tu peux aussi l’envoyer par email après.</small>"
      );

      form.innerHTML = `
        <div>
          <label>Dénomination du bien</label>
          <input id="p_name" placeholder="Appartement T2, Studio…" value="${esc(draft.property.name||"")}">
        </div>

        <div class="row">
          <div>
            <label>Loyer mensuel HC</label>
            <input id="p_rent" type="number" placeholder="850" value="${esc(draft.property.rentAmount||"")}">
          </div>
          <div>
            <label>Charges (optionnel)</label>
            <input id="p_charges" type="number" placeholder="50" value="${esc(draft.property.chargesAmount||"")}">
          </div>
        </div>

        <div>
          <label>Adresse (rue)</label>
          <input id="p_line" placeholder="12 rue Victor Hugo" value="${esc(draft.property.addressLine||"")}">
        </div>

        <div class="row">
          <div>
            <label>Code postal</label>
            <input id="p_zip" placeholder="75015" value="${esc(draft.property.zipCode||"")}">
          </div>
          <div>
            <label>Commune</label>
            <input id="p_city" placeholder="Paris" value="${esc(draft.property.city||"")}">
            <div class="hint" id="cityHint" style="margin-top:6px"></div>
          </div>
        </div>

        <div class="hint">Anti-erreurs : on te propose les communes possibles selon le code postal.</div>
      `;

      // autosave bindings
      bindAutosaveBien();
      return;
    }

    // Step 2 = locataire / email de contact
    if(step === 2){
      title.textContent = (mode === "candidature") ? "Coordonnées (pour recevoir la shortlist)" : "Locataire (optionnel)";
      stepHint.textContent = "Étape 2/3 — " + ((mode === "candidature") ? "Contact" : "Locataire");

      if(mode === "candidature"){
        setAssistant(
          "<b>Parfait.</b><small>Dernière étape avant de générer le lien.</small>",
          "Où t’envoie-t-on l’accès ? <small>Pas de spam. Uniquement pour ton lien + shortlist.</small>"
        );
        hint.textContent = "On s’en sert pour te donner l’accès au lien et aux dossiers.";
        form.innerHTML = `
          <div>
            <label>Ton email (bailleur)</label>
            <input id="lead_email" type="email" placeholder="nom@domaine.com" value="${esc(draft.leadEmail||"")}">
          </div>
          <div class="hint">Tu pourras ajuster les critères après.</div>
        `;
        document.getElementById("lead_email").addEventListener("input", (e)=>{
          draft.leadEmail = e.target.value;
          saveDraft();
        });
      }else{
        setAssistant(
          "<b>Optionnel mais conseillé.</b><small>Pour envoyer quittances et relances.</small>",
          "Email recommandé <small>Tu peux le renseigner maintenant ou plus tard.</small>"
        );
        hint.textContent = "On s’en sert pour pré-remplir les quittances et automatiser l’envoi.";
        form.innerHTML = `
          <div class="row">
            <div>
              <label>Prénom</label>
              <input id="t_fn" placeholder="Alice" value="${esc(draft.tenant.firstName||"")}">
            </div>
            <div>
              <label>Nom</label>
              <input id="t_ln" placeholder="Durand" value="${esc(draft.tenant.lastName||"")}">
            </div>
          </div>
          <div>
            <label>Email (recommandé)</label>
            <input id="t_email" type="email" placeholder="alice@domaine.com" value="${esc(draft.tenant.email||"")}">
          </div>
          <div class="hint">Tu pourras activer l’envoi automatique plus tard.</div>
        `;
        ["t_fn","t_ln","t_email"].forEach(id=>{
          document.getElementById(id).addEventListener("input",(e)=>{
            const map={t_fn:"firstName",t_ln:"lastName",t_email:"email"};
            draft.tenant[map[id]] = e.target.value;
            saveDraft();
          });
        });
      }

      // lead capture soft (progress)
      softLeadCapture("step2");
      return;
    }

    // Step 3 = aha moment + gate account
    if(step === 3){
      title.textContent = (mode === "candidature") ? "Lien prêt ✅" : "Quittance prête ✅";
      stepHint.textContent = "Étape 3/3 — Débloquer (compte gratuit)";

      setAssistant(
        "<b>✅ C’est prêt.</b><small>Tu as fait le plus dur. On a sauvegardé ton brouillon.</small>",
        (mode === "candidature")
          ? "Pour accéder au lien + coffre-fort dossiers : <small>crée ton compte (30 secondes).</small>"
          : "Pour télécharger le PDF + historique : <small>crée ton compte (30 secondes).</small>",
        "Micro-rassurance : <small>Sans carte bancaire. Export possible à tout moment.</small>"
      );

      hint.textContent = "On te crée l’accès et on importe automatiquement ce que tu viens de remplir.";
      form.innerHTML = `
        <div class="box" style="border-radius:16px">
          <b>${mode === "candidature" ? "Ton lien de candidature est prêt." : "Ton PDF est prêt."}</b>
          <div class="hint" style="margin-top:6px">${mode === "candidature" ? "Débloque l’accès en créant ton compte." : "Débloque le téléchargement + l’historique."}</div>
        </div>

        <div style="margin-top:10px" class="row">
          <div>
            <label>Email</label>
            <input id="acc_email" type="email" placeholder="nom@domaine.com" value="${esc((draft.leadEmail||draft.tenant.email||""))}">
          </div>
          <div>
            <label>Mot de passe</label>
            <input id="acc_pass" type="password" placeholder="••••••••">
          </div>
        </div>

        <div class="hint">Pas de spam. Uniquement pour ton document / lien.</div>

        <div class="row" style="margin-top:8px">
          <button class="btn" type="button" onclick="switchToLogin()">J'ai déjà un compte</button>
          <button class="btn primary" type="button" onclick="registerInline()">Créer mon compte</button>
        </div>

        <div id="loginInline" style="display:none; margin-top:10px">
          <div class="row">
            <button class="btn primary" type="button" onclick="loginInline()">Se connecter</button>
            <a class="btn" href="/register.html" onclick="saveDraft();">Ouvrir la page inscription</a>
          </div>
        </div>
      `;

      softLeadCapture("step3");
      return;
    }
  }

  function bindAutosaveBien(){
    const name = document.getElementById("p_name");
    const rent = document.getElementById("p_rent");
    const charges = document.getElementById("p_charges");
    const line = document.getElementById("p_line");
    const zip = document.getElementById("p_zip");
    const city = document.getElementById("p_city");
    const cityHint = document.getElementById("cityHint");

    const upd = ()=>{
      draft.property.name = name.value;
      draft.property.rentAmount = rent.value;
      draft.property.chargesAmount = charges.value;
      draft.property.addressLine = line.value;
      draft.property.zipCode = zip.value;
      draft.property.city = city.value;
      saveDraft();
    };

    [name,rent,charges,line,zip,city].forEach(el => el.addEventListener("input", upd));

    zip.addEventListener("input", async ()=>{
      upd();
      const communes = await fetchCommunes(zip.value);
      if(communes.length){
        cityHint.innerHTML = "Suggestions : " + communes.slice(0,5).map(c=>`<a href="#" onclick="pickCity('${escAttr(c)}');return false;">${esc(c)}</a>`).join(" • ");
      }else{
        cityHint.textContent = "";
      }
    });

    window.pickCity = (c)=>{
      city.value = c;
      upd();
      toast("Commune sélectionnée ✅");
    };

    // lead capture soft dès qu'il y a un progrès utile
    softLeadCapture("step1");
  }

  function validateStep(){
    const mode = flow.mode;
    const step = flow.step;

    if(step === 1){
      const p = draft.property || {};
      if(!p.name) return "Dénomination obligatoire.";
      const rent = Number(p.rentAmount);
      if(!Number.isFinite(rent) || rent<=0) return "Loyer invalide.";
      if(!p.addressLine) return "Adresse (rue) obligatoire.";
      if(!/^\d{5}$/.test(String(p.zipCode||"").trim())) return "Code postal invalide (5 chiffres).";
      if(!String(p.city||"").trim()) return "Commune obligatoire.";
      return null;
    }

    if(step === 2 && mode === "candidature"){
      if(!draft.leadEmail || !String(draft.leadEmail).includes("@")) return "Email invalide.";
      return null;
    }

    return null;
  }

  function prevStep(){
    flow.step = Math.max(1, flow.step - 1);
    renderStep();
  }
  function nextStep(){
    const err = validateStep();
    if(err){ showError(err); return; }
    flow.step = Math.min(3, flow.step + 1);
    renderStep();
  }

  function switchToLogin(){
    document.getElementById("loginInline").style.display = "block";
    toast("Connecte-toi pour reprendre ✅");
  }

  async function registerInline(){
    clearError();
    const email = document.getElementById("acc_email").value.trim();
    const password = document.getElementById("acc_pass").value;

    if(!email || !email.includes("@")){ showError("Email invalide."); return; }
    if(!password || password.length < 6){ showError("Mot de passe trop court (min 6)."); return; }

    try{
      const r = await fetch("/api/auth/register", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body: JSON.stringify({ email, password })
      });
      const j = await r.json().catch(()=>({}));
      if(!r.ok){
        // email déjà utilisé => propose login
        showError(j.msg || "Erreur inscription.");
        document.getElementById("loginInline").style.display = "block";
        return;
      }

      // auto-login
      const r2 = await fetch("/api/auth/login", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body: JSON.stringify({ email, password })
      });
      const j2 = await r2.json().catch(()=>({}));
      if(!r2.ok){ showError(j2.msg || "Connexion impossible."); return; }

      localStorage.setItem("token", j2.token);
      await importDraftAndRedirect();
    }catch(e){
      showError("Erreur réseau.");
    }
  }

  async function loginInline(){
    clearError();
    const email = document.getElementById("acc_email").value.trim();
    const password = document.getElementById("acc_pass").value;

    if(!email || !email.includes("@")){ showError("Email invalide."); return; }

    try{
      const r = await fetch("/api/auth/login", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body: JSON.stringify({ email, password })
      });
      const j = await r.json().catch(()=>({}));
      if(!r.ok){ showError(j.msg || "Identifiants invalides."); return; }

      localStorage.setItem("token", j.token);
      await importDraftAndRedirect();
    }catch(e){
      showError("Erreur réseau.");
    }
  }

  async function importDraftAndRedirect(){
    const tok = localStorage.getItem("token");
    if(!tok){ location.href="/login.html"; return; }

    // Capture lead (soft)
    softLeadCapture("import");

    // Create property from draft
    const p = draft.property || {};
    const payload = {
      name: p.name,
      rentAmount: p.rentAmount,
      chargesAmount: p.chargesAmount,
      addressLine: p.addressLine,
      zipCode: p.zipCode,
      city: p.city
    };

    try{
      const r = await fetch("/api/properties", {
        method:"POST",
        headers:{"Content-Type":"application/json","x-auth-token":tok},
        body: JSON.stringify(payload)
      });
      const created = await r.json().catch(()=>({}));
      if(!r.ok){
        // si validation commune échoue, on renvoie vers dashboard mais sans perdre le draft
        showError(created.msg || "Impossible de créer le bien.");
        return;
      }

      // Create tenant if email present
      const t = draft.tenant || {};
      if(t.email && String(t.email).includes("@")){
        await fetch("/api/tenants", {
          method:"POST",
          headers:{"Content-Type":"application/json","x-auth-token":tok},
          body: JSON.stringify({
            firstName: t.firstName || "Locataire",
            lastName: t.lastName || "",
            email: t.email,
            property: created._id
          })
        }).catch(()=>{});
      }

      clearDraft();
      location.href = "/property.html?id=" + encodeURIComponent(created._id);
    }catch(e){
      showError("Erreur serveur.");
    }
  }

  // -----------------------------
  // Lead capture (soft)
  // -----------------------------
  function utmObj(){
    const q = new URLSearchParams(location.search);
    const keys = ["utm_source","utm_medium","utm_campaign","utm_content","utm_term"];
    const o = {};
    keys.forEach(k=>{ if(q.get(k)) o[k]=q.get(k); });
    return o;
  }

  let leadSent = false;
  async function softLeadCapture(stage){
    if(leadSent) return;

    const emailCandidate = (draft.leadEmail || (draft.tenant && draft.tenant.email) || "").trim();
    // On n'envoie que si email valide OU si progrès utile (bien rempli) pour futur retarget
    const hasProgress = !!(draft.property && draft.property.zipCode && draft.property.city && draft.property.rentAmount);

    if(!emailCandidate && !hasProgress) return;

    try{
      await fetch("/api/public/lead", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body: JSON.stringify({
          email: emailCandidate || ("anon+" + Date.now() + "@doc2loc.local"),
          source: "landing:" + (draft.mode || "unknown") + ":" + stage,
          utm: utmObj()
        })
      });
      leadSent = true;
    }catch(e){}
  }

  // -----------------------------
  // Utils
  // -----------------------------
  function esc(s){ return String(s||"").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }
  function escAttr(s){ return String(s||"").replace(/'/g,"\\'").replace(/"/g,"&quot;"); }

  // Exit intent (bonus conversion)
  let exitShown=false;
  document.addEventListener("mouseout",(e)=>{
    if(exitShown) return;
    if(e.clientY <= 0){
      exitShown=true;
      if(loadDraft() && (draft.property && draft.property.rentAmount)) maybeShowTopbar();
    }
  });
</script>
</body>
</html>
