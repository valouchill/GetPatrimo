        .insight-dot { width:10px; height:10px; border-radius:999px; margin-top:6px; flex:0 0 auto; }
        .dot-critical { background: var(--danger); }
        .dot-warning { background: #f59e0b; }
        .dot-info { background: var(--primary); }

        .insight-title { font-weight: 700; font-size: 14px; margin:0; }
        .insight-meta { color: var(--text-gray); font-size: 13px; margin-top: 2px; }
        .insight-actions { display:flex; gap:10px; flex-wrap:wrap; margin-top: 10px; }

        .pill { padding: 8px 10px; border-radius: 999px; border:1px solid var(--border); background: var(--bg); color: var(--text-dark); font-weight: 600; font-size: 13px; text-decoration:none; display:inline-flex; align-items:center; gap:8px; }
        .pill:hover { background: var(--primary-light); color: var(--primary); }

        .pill-primary { background: var(--primary); color: #fff; border-color: transparent; }
        .pill-primary:hover { background: var(--primary); color:#fff; filter:brightness(.95); }

        .pill-ghost { background:#fff; }

        .tiny { font-size: 12px; color: var(--text-gray); font-weight: 600; }

        .chips-row { display:flex; gap:10px; flex-wrap:wrap; margin-top: 8px; }
        .chip { border:1px solid var(--border); background: #fff; padding: 6px 10px; border-radius: 999px; font-size: 12px; font-weight: 700; color: var(--text-dark); }
        .chip.crit { border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.08); color:#991b1b; }
        .chip.warn { border-color: rgba(245,158,11,.35); background: rgba(245,158,11,.10); color:#92400e; }
        .chip.info { border-color: rgba(79,70,229,.25); background: rgba(79,70,229,.08); color:#3730a3; }
    
    
        /* --- INSIGHTS MODAL --- */
        .insight-head { display:flex; justify-content:space-between; align-items:center; gap:12px; }
        .tiny-link { color: var(--primary); text-decoration:none; font-weight:700; }
