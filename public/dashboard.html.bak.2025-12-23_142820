// --- Dashboard: Fil d'actualité + Overview ---
(function(){
  const tok = localStorage.getItem("token");
  if(!tok){ location.href="/login.html"; return; }

  const $ = (id)=>document.getElementById(id);

  function esc(x){ return String(x||"").replace(/[&<>"']/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m])); }
  function fmtDT(d){ try{ return new Date(d).toLocaleString("fr-FR"); }catch(e){ return "—"; } }

  async function apiJson(url, opts={}){
    const r = await fetch(url, {
      ...opts,
      headers: { "x-auth-token": tok, ...(opts.headers||{}) }
    });
    const ct = (r.headers.get("content-type")||"").toLowerCase();
    const data = ct.includes("application/json") ? await r.json().catch(()=>null) : await r.text().catch(()=>null);
    if(r.status===401 || r.status===403){ localStorage.clear(); location.href="/login.html"; return { ok:false, status:r.status, data }; }
    return { ok:r.ok, status:r.status, data };
  }

  function label(e){
    const t = e && e.type;
    if(t==='email_quittance_sent') return "Quittance envoyée";
    if(t==='pdf_quittance_generated') return "PDF quittance généré";
    if(t==='document_uploaded') return "Document ajouté";
    if(t==='document_deleted') return "Document supprimé";
    if(t==='reminder_sent') return "Relance envoyée";
    return t || "Événement";
  }

  function metaLine(e){
    const propName = e?.property?.name;
    const tenantName = [e?.tenant?.firstName, e?.tenant?.lastName].filter(Boolean).join(" ").trim();
    const to = e?.meta?.to || e?.tenant?.email;

    const parts = [];
    if(tenantName) parts.push("à " + tenantName);
    if(to) parts.push("("+to+")");
    if(propName) parts.push("• " + propName);
    if(e?.meta?.template){
      const map = { rent_reminder:"Rappel loyer", missing_docs:"Docs manquants", late_payment:"Paiement en attente" };
      parts.push("• " + (map[e.meta.template] || e.meta.template));
    }
    return parts.length ? parts.join(" ") : "—";
  }

  function chips(e){
    const out = [];
    if(e?.property?._id) out.push(`<a class="btn-secondary" style="text-decoration:none;padding:6px 10px;border-radius:999px;border:1px solid rgba(148,163,184,.18)" href="/property.html?id=${encodeURIComponent(e.property._id)}">Voir bien</a>`);
    if(e?.tenant?._id) out.push(`<a class="btn-secondary" style="text-decoration:none;padding:6px 10px;border-radius:999px;border:1px solid rgba(148,163,184,.18)" href="/tenant.html?id=${encodeURIComponent(e.tenant._id)}">Voir locataire</a>`);
    return out.join(" ");
  }

  function renderShell(){
    const c = $("cockpit");
    if(!c) return;

    c.innerHTML = `
      <div style="padding:14px;border:1px solid rgba(148,163,184,.18);border-radius:16px;background:rgba(16,26,47,.75)">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap">
          <div>
            <div style="font-weight:800;font-size:16px">Fil d’actualité</div>
            <div style="color:#94a3b8;font-size:13px">Ce qui s’est passé récemment sur ton compte</div>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button id="btnFeedRefresh" class="btn-secondary" style="padding:10px 12px;border-radius:12px">Rafraîchir</button>
            <select id="feedFilter" style="padding:10px 12px;border-radius:12px;border:1px solid rgba(148,163,184,.18);background:#0b1326;color:#e5e7eb">
              <option value="all">Tout</option>
              <option value="quittance">Quittances</option>
              <option value="reminder">Relances</option>
              <option value="docs">Documents</option>
              <option value="pdf">PDF</option>
            </select>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin-top:12px">
          <div style="padding:12px;border:1px solid rgba(148,163,184,.18);border-radius:14px;background:rgba(11,19,38,.55)">
            <div style="color:#94a3b8;font-size:12px">Quittances email (mois)</div>
            <div id="stEmail" style="font-size:18px;font-weight:900">—</div>
          </div>
          <div style="padding:12px;border:1px solid rgba(148,163,184,.18);border-radius:14px;background:rgba(11,19,38,.55)">
            <div style="color:#94a3b8;font-size:12px">PDF générés (mois)</div>
            <div id="stPdf" style="font-size:18px;font-weight:900">—</div>
          </div>
          <div style="padding:12px;border:1px solid rgba(148,163,184,.18);border-radius:14px;background:rgba(11,19,38,.55)">
            <div style="color:#94a3b8;font-size:12px">Docs ajoutés (mois)</div>
            <div id="stDocs" style="font-size:18px;font-weight:900">—</div>
          </div>
          <div style="padding:12px;border:1px solid rgba(148,163,184,.18);border-radius:14px;background:rgba(11,19,38,.55)">
            <div style="color:#94a3b8;font-size:12px">Relances (mois)</div>
            <div id="stRem" style="font-size:18px;font-weight:900">—</div>
          </div>
        </div>

        <div style="margin-top:12px;border:1px solid rgba(148,163,184,.18);border-radius:14px;overflow:hidden">
          <div style="padding:10px 12px;color:#94a3b8;font-size:12px;border-bottom:1px solid rgba(148,163,184,.18)">Activité récente</div>
          <div id="feedList">
            <div style="padding:12px;color:#94a3b8">Chargement…</div>
          </div>
        </div>
      </div>
    `;
  }

  function filterMatch(e, f){
    const t = e?.type || "";
    if(f==="all") return True;
    if(f==="quittance") return t==="email_quittance_sent";
    if(f==="reminder") return t==="reminder_sent";
    if(f==="docs") return (t==="document_uploaded" || t==="document_deleted");
    if(f==="pdf") return t==="pdf_quittance_generated";
    return True;
  }

  // Fix Python -> JS True typo protection
  // (we don't want dashboard to ever crash)
  const True = true;

  async function loadFeed(){
    const list = $("feedList");
    if(list) list.innerHTML = `<div style="padding:12px;color:#94a3b8">Chargement…</div>`;

    const r = await apiJson("/api/events/summary?limit=30");
    if(!r.ok){
      const msg = (r.data && r.data.msg) ? r.data.msg : ("Erreur API ("+r.status+")");
      if(list) list.innerHTML = `<div style="padding:12px;color:#94a3b8">Impossible de charger : ${esc(msg)}</div>`;
      return;
    }

    const j = r.data || {};
    $("stEmail").textContent = j?.month?.email_quittance_sent ?? 0;
    $("stPdf").textContent   = j?.month?.pdf_quittance_generated ?? 0;
    $("stDocs").textContent  = j?.month?.document_uploaded ?? 0;
    $("stRem").textContent   = j?.month?.reminder_sent ?? 0;

    const f = $("feedFilter")?.value || "all";
    const arr = Array.isArray(j.last) ? j.last : [];
    const items = arr.filter(e => filterMatch(e, f));

    if(items.length===0){
      if(list) list.innerHTML = `<div style="padding:12px;color:#94a3b8">Aucune activité pour ce filtre.</div>`;
      return;
    }

    if(list) list.innerHTML = items.map(e=>`
      <div style="display:flex;gap:12px;align-items:flex-start;padding:12px;border-top:1px solid rgba(148,163,184,.18)">
        <div style="width:10px;height:10px;border-radius:999px;background:rgba(79,70,229,.9);margin-top:6px"></div>
        <div style="flex:1;min-width:0">
          <div style="display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap">
            <div style="font-weight:800">${esc(label(e))}</div>
            <div style="color:#94a3b8;font-size:12px">${esc(fmtDT(e.createdAt))}</div>
          </div>
          <div style="color:#94a3b8;font-size:13px;margin-top:4px">${esc(metaLine(e))}</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px">${chips(e)}</div>
        </div>
      </div>
    `).join("");
  }

  function init(){
    renderShell();
    $("btnFeedRefresh")?.addEventListener("click", loadFeed);
    $("feedFilter")?.addEventListener("change", loadFeed);
    loadFeed();
  }

  // Run after DOM is ready
  if(document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
  else init();
})();

</script>
    <style>
        :root {
            --primary: #4F46E5;
            --primary-light: #EEF2FF;
            --success: #10B981;
            --danger: #EF4444;
