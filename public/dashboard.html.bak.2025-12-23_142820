    // --- INSIGHTS (Alerts & Activity) ---
    function dotClass(sev){
      if(sev === 'critical') return 'insight-dot dot-critical';
      if(sev === 'warning') return 'insight-dot dot-warning';
      return 'insight-dot dot-info';
    }
    function esc(x){
      return String(x||'').replace(/[&<>"']/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]));
    }
    function fmtDT(d){ try{ return new Date(d).toLocaleString('fr-FR'); }catch(e){ return '—'; } }

    async function quickSendQuittance(propertyId, btn){
      const prev = btn?.innerHTML;
      try{
        if(btn){ btn.disabled = true; btn.innerHTML = '…'; }
        const r = await fetch('/api/documents/email/' + encodeURIComponent(propertyId), { method:'POST', headers:{'x-auth-token':tok} });
        const j = await r.json().catch(()=>({}));
        if(!r.ok){ showToast(j.msg || 'Envoi impossible'); return; }
        showToast(j.msg || 'Quittance envoyée ✅');
        await loadInsights();

    // --- INSIGHTS MODAL (Voir tout) ---
    let __alertsCache = null;
    let __eventsCache = null;

    function ensureInsightsModal(){
      if(document.getElementById("insModalBackdrop")) return;
      const b = document.createElement("div");
      b.id = "insModalBackdrop";
      b.className = "ins-modal-backdrop";
      b.innerHTML = `
        <div class="ins-modal" role="dialog" aria-modal="true" aria-labelledby="insModalTitle">
          <div class="ins-modal-header">
            <div>
              <div class="ins-modal-title" id="insModalTitle">—</div>
              <div class="ins-modal-sub" id="insModalSub">—</div>
            </div>
            <div class="ins-modal-actions">
              <select id="insModalFilter">
                <option value="all">Tout</option>
                <option value="critical">Critiques</option>
                <option value="warning">À surveiller</option>
                <option value="info">Infos</option>
              </select>
              <button class="ins-modal-close" id="insModalClose" type="button"><i data-lucide="x"></i> Fermer</button>
            </div>
          </div>
          <div class="ins-modal-body">
            <div class="ins-modal-list" id="insModalList"></div>
          </div>
          <div class="ins-modal-footer">
            <div class="tiny">Astuce : <span class="kbd">Esc</span> pour fermer</div>
            <button class="btn-secondary" id="insModalRefresh" type="button">Rafraîchir</button>
          </div>
        </div>
      `;
      document.body.appendChild(b);

      b.addEventListener("click", (e)=>{ if(e.target === b) closeInsightsModal(); });
      document.getElementById("insModalClose").addEventListener("click", closeInsightsModal);
      document.addEventListener("keydown", (e)=>{ if(e.key === "Escape") closeInsightsModal(); });

      lucide.createIcons();
    }

    function openInsightsModal(mode){
      ensureInsightsModal();
      const b = document.getElementById("insModalBackdrop");
      b.style.display = "flex";
      b.setAttribute("data-mode", mode);
      document.getElementById("insModalFilter").style.display = (mode==="alerts") ? "inline-block" : "none";

      if(mode==="alerts"){
        document.getElementById("insModalTitle").textContent = "Toutes les alertes";
        document.getElementById("insModalSub").textContent = "Priorisées (critiques → à surveiller → infos)";
        document.getElementById("insModalFilter").value = "all";
        renderAlertsModal();
      }else{
        document.getElementById("insModalTitle").textContent = "Toute l’activité";
        document.getElementById("insModalSub").textContent = "Actions récentes sur ton compte";
        renderActivityModal();
      }

      document.getElementById("insModalRefresh").onclick = async ()=>{
        if(mode==="alerts"){ __alertsCache = null; await renderAlertsModal(true); }
        else { __eventsCache = null; await renderActivityModal(true); }
      };

      document.getElementById("insModalFilter").onchange = ()=>renderAlertsModal(false);
      lucide.createIcons();
    }

    function closeInsightsModal(){
      const b = document.getElementById("insModalBackdrop");
      if(!b) return;
      b.style.display = "none";
      b.removeAttribute("data-mode");
    }

    function severityDot(sev){
      if(sev==="critical") return "insight-dot dot-critical";
      if(sev==="warning") return "insight-dot dot-warning";
      return "insight-dot dot-info";
    }

    async function renderAlertsModal(forceFetch=false){
      const list = document.getElementById("insModalList");
      list.innerHTML = "<div class='insight-item'><div class='insight-meta'>Chargement…</div></div>";

      const filter = document.getElementById("insModalFilter").value || "all";

      let data = __alertsCache;
      if(!data || forceFetch){
        const r = await fetch("/api/alerts/overview", { headers: { "x-auth-token": tok }});
        const j = await r.json().catch(()=>null);
        if(!r.ok || !j){
          list.innerHTML = "<div class='insight-item'><div class='insight-meta'>Impossible de charger les alertes.</div></div>";
          return;
        }
        data = j;
        __alertsCache = j;
      }

      const arr = Array.isArray(data.alerts) ? data.alerts : [];
      const items = arr.filter(a => (filter==="all" ? true : a.severity===filter));

      if(!items.length){
        list.innerHTML = "<div class='insight-item'><div class='insight-meta'>Aucune alerte ✅</div></div>";
        return;
      }

      list.innerHTML = items.slice(0, 50).map(a=>{
        const openHref = a.action && a.action.href ? a.action.href : null;

        // 1 seule action principale
        let primary = "";
        if(a.code === "QUITTANCE_NOT_SENT_THIS_MONTH" && a.propertyId){
          primary = `<button class='pill pill-primary' onclick="quickSendQuittance('${esc(a.propertyId)}', this)">Envoyer quittance</button>`;
        } else if(a.code === "REMINDER_RECOMMENDED" && a.tenantId){
          primary = `<button class='pill pill-primary' onclick="quickReminder('${esc(a.tenantId)}', this)">Relancer</button>`;
        } else if(openHref){
          primary = `<a class='pill pill-primary' href='${esc(openHref)}'>Ouvrir</a>`;
        }

        const detail = (openHref && primary && primary.includes("onclick")) ? `<a class='tiny-link' href='${esc(openHref)}'>Voir le détail</a>` : "";

        return `
          <div class='insight-item'>
            <div class='${severityDot(a.severity)}'></div>
            <div style='flex:1;min-width:0'>
              <div class='insight-title'>${esc(a.title || 'Alerte')}</div>
              <div class='insight-meta'>${esc(a.message || '')}</div>
              <div class='insight-actions'>${primary}</div>
              ${detail ? `<div class='tiny' style='margin-top:6px'>${detail}</div>` : ``}
            </div>
          </div>
        `;
      }).join("");

      lucide.createIcons();
    }

    async function renderActivityModal(forceFetch=false){
      const list = document.getElementById("insModalList");
      list.innerHTML = "<div class='insight-item'><div class='insight-meta'>Chargement…</div></div>";

      let data = __eventsCache;
      if(!data || forceFetch){
        const r = await fetch("/api/events/summary?limit=50", { headers: { "x-auth-token": tok }});
        const j = await r.json().catch(()=>null);
        if(!r.ok || !j){
          list.innerHTML = "<div class='insight-item'><div class='insight-meta'>Impossible de charger l’activité.</div></div>";
          return;
        }
        data = j;
        __eventsCache = j;
      }

      const ev = Array.isArray(data.last) ? data.last : [];
      if(!ev.length){
        list.innerHTML = "<div class='insight-item'><div class='insight-meta'>Aucune activité.</div></div>";
        return;
      }

      const mapLabel = (t)=>(
        t==='email_quittance_sent'?'Quittance envoyée':
        t==='pdf_quittance_generated'?'PDF généré':
        t==='document_uploaded'?'Document ajouté':
        t==='document_deleted'?'Document supprimé':
        t==='reminder_sent'?'Relance envoyée':'Événement'
      );

      list.innerHTML = ev.map(e=>{
        const prop = e.property && e.property._id ? `<a class='pill' href='/property.html?id=${encodeURIComponent(e.property._id)}'>Bien</a>` : "";
        const ten  = e.tenant && e.tenant._id ? `<a class='pill' href='/tenant.html?id=${encodeURIComponent(e.tenant._id)}'>Locataire</a>` : "";
        const name = (e.property && e.property.name) ? ("• " + e.property.name) : "";
        return `
          <div class='insight-item'>
            <div class='insight-dot dot-info'></div>
            <div style='flex:1;min-width:0'>
              <div class='insight-title'>${esc(mapLabel(e.type))} <span class='tiny'>${esc(name)}</span></div>
              <div class='insight-meta'>${esc(fmtDT(e.createdAt))}</div>
              <div class='insight-actions'>${prop} ${ten}</div>
            </div>
          </div>
        `;
      }).join("");

      lucide.createIcons();
    }

      } finally {
        if(btn){ btn.disabled = false; btn.innerHTML = prev; lucide.createIcons(); }
      }
    }

    async function quickReminder(tenantId, btn){
      const prev = btn?.innerHTML;
      try{
        if(btn){ btn.disabled = true; btn.innerHTML = '…'; }
        const r = await fetch('/api/reminders/tenant/' + encodeURIComponent(tenantId), {
          method:'POST',
          headers:{'x-auth-token':tok,'Content-Type':'application/json'},
          body: JSON.stringify({ template:'rent_reminder' })
        });
        const j = await r.json().catch(()=>({}));
        if(!r.ok){ showToast(j.msg || 'Relance impossible'); return; }
        showToast(j.msg || 'Relance envoyée ✅');
        await loadInsights();
      } finally {
        if(btn){ btn.disabled = false; btn.innerHTML = prev; lucide.createIcons(); }
      }
    }

    async function loadInsights(){
      const aBox = document.getElementById('alertsBox');
      const eBox = document.getElementById('activityBox');
      if(aBox) aBox.innerHTML = "<div class='insight-item'><div class='insight-meta'>Chargement…</div></div>";
      if(eBox) eBox.innerHTML = "<div class='insight-item'><div class='insight-meta'>Chargement…</div></div>";

      // Alerts
      try{
        const rA = await fetch('/api/alerts/overview', { headers: {'x-auth-token': tok}});
        const jA = await rA.json().catch(()=>null);
        if(rA.ok && jA){
          document.getElementById('insCrit').textContent = (jA.counts && jA.counts.critical) || 0;
          document.getElementById('insWarn').textContent = (jA.counts && jA.counts.warning) || 0;
          document.getElementById('insInfo').textContent = (jA.counts && jA.counts.info) || 0;
          document.getElementById('insComputed').textContent = jA.computedAt ? ("Calculé " + fmtDT(jA.computedAt)) : "—";

          const alerts = Array.isArray(jA.top) ? jA.top : (Array.isArray(jA.alerts) ? jA.alerts.slice(0,3) : []);
          if(!alerts.length){
            if(aBox) aBox.innerHTML = "<div class='insight-item'><div class='insight-meta'>Aucune alerte ✅</div></div>";
          } else {
            if(aBox) aBox.innerHTML = alerts.slice(0,3).map(a=>{
              const openHref = a.action && a.action.href ? a.action.href : null;
              // CTA unique (réduction friction)
              let primary = "";
              let detail = "";
              if(a.code === "QUITTANCE_NOT_SENT_THIS_MONTH" && a.propertyId){
                primary = `<button class='pill pill-primary' onclick="quickSendQuittance('${esc(a.propertyId)}', this)">Envoyer quittance</button>`;
              } else if(a.code === "REMINDER_RECOMMENDED" && a.tenantId){
                primary = `<button class='pill pill-primary' onclick="quickReminder('${esc(a.tenantId)}', this)">Relancer</button>`;
              } else if(openHref){
                primary = `<a class='pill pill-primary' href='${esc(openHref)}'>Ouvrir</a>`;
              }
              if(openHref && primary && "onclick" in primary){
                detail = `<a class='tiny-link' href='${esc(openHref)}'>Voir le détail</a>`;
              }
              return `
                <div class='insight-item'>
                  <div class='${dotClass(a.severity)}'></div>
                  <div style='flex:1;min-width:0'>
                    <div class='insight-title'>${esc(a.title || 'Alerte')}</div>
                    <div class='insight-meta'>${esc(a.message || '')}</div>
                    <div class='insight-actions'>${primary}</div>${detail ? `<div class='tiny' style='margin-top:6px'>${detail}</div>` : ``}
                  </div>
                </div>
              `;
            }).join("");
          }
        } else {
          if(aBox) aBox.innerHTML = "<div class='insight-item'><div class='insight-meta'>Impossible de charger les alertes.</div></div>";
        }
      }catch(e){
        if(aBox) aBox.innerHTML = "<div class='insight-item'><div class='insight-meta'>Impossible de charger les alertes (réseau).</div></div>";
      }

      // Events summary
      try{
        const rE = await fetch('/api/events/summary?limit=8', { headers: {'x-auth-token': tok}});
        const jE = await rE.json().catch(()=>null);
        if(rE.ok && jE){
          document.getElementById('mEmail').textContent = (jE.month && jE.month.email_quittance_sent) || 0;
          document.getElementById('mPdf').textContent   = (jE.month && jE.month.pdf_quittance_generated) || 0;
          document.getElementById('mDocs').textContent  = (jE.month && jE.month.document_uploaded) || 0;
          document.getElementById('mRem').textContent   = (jE.month && jE.month.reminder_sent) || 0;

          const ev = Array.isArray(jE.last) ? jE.last : [];
          if(!ev.length){
            if(eBox) eBox.innerHTML = "<div class='insight-item'><div class='insight-meta'>Aucune activité.</div></div>";
          } else {
            if(eBox) eBox.innerHTML = ev.slice(0,5).map(e=>{
              const prop = e.property && e.property._id ? `<a class='pill' href='/property.html?id=${encodeURIComponent(e.property._id)}'>Bien</a>` : "";
              const ten  = e.tenant && e.tenant._id ? `<a class='pill' href='/tenant.html?id=${encodeURIComponent(e.tenant._id)}'>Locataire</a>` : "";
              const label = (e.type==='email_quittance_sent'?'Quittance envoyée':
                             e.type==='pdf_quittance_generated'?'PDF généré':
                             e.type==='document_uploaded'?'Document ajouté':
                             e.type==='document_deleted'?'Document supprimé':
                             e.type==='reminder_sent'?'Relance envoyée':'Événement');
              const meta = (e.property && e.property.name) ? ("• " + e.property.name) : "";
              return `
                <div class='insight-item'>
                  <div class='insight-dot dot-info'></div>
                  <div style='flex:1;min-width:0'>
                    <div class='insight-title'>${esc(label)} <span class='tiny'>${esc(meta)}</span></div>
                    <div class='insight-meta'>${esc(fmtDT(e.createdAt))}</div>
                    <div class='insight-actions'>${prop} ${ten}</div>
                  </div>
                </div>
              `;
            }).join("");
          }
        } else {
          if(eBox) eBox.innerHTML = "<div class='insight-item'><div class='insight-meta'>Impossible de charger l’activité.</div></div>";
        }
      }catch(e){
        if(eBox) eBox.innerHTML = "<div class='insight-item'><div class='insight-meta'>Impossible de charger l’activité (réseau).</div></div>";
      }

      lucide.createIcons();
    }

    load();
    loadInsights();


async function isAdmin() {
  try {
    const token = localStorage.getItem("token");
    if (!token) return false;

    // On réutilise ton endpoint admin (protégé)
    const r = await fetch("/api/admin/leads?limit=1", {
      headers: { "x-auth-token": token }
    });

    return r.ok; // si OK => admin, sinon 403/401 => pas admin
  } catch (e) {
    return false;
  }
}

(async () => {
  const btn = document.getElementById("adminBtn");
  if (!btn) return;

  const ok = await isAdmin();
  if (ok) {
    btn.style.display = "inline-block";
    btn.addEventListener("click", () => {
      window.location.href = "/admin-leads.html";
    });
  }
})();




function openProperty(id){ window.location.href = '/property.html?id=' + encodeURIComponent(id); }
