<script>
    lucide.createIcons();

    // Insights modals
    document.getElementById('btnAlertsAll')?.addEventListener('click', ()=>openInsightsModal('alerts'));
    document.getElementById('btnActivityAll')?.addEventListener('click', ()=>openInsightsModal('activity'));

    const tok = localStorage.getItem('token');
