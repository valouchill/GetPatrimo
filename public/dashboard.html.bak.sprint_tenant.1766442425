<html lang='fr'>
<head>
    <meta charset='UTF-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <title>Doc2Loc Premium | Dashboard</title>
    <link href='https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap' rel='stylesheet'>
    <script src='https://unpkg.com/lucide@latest'>

function openProperty(id){ window.location.href = '/property.html?id=' + encodeURIComponent(id); }
</script>
    <style>
        :root {
            --primary: #4F46E5;
            --primary-light: #EEF2FF;
            --success: #10B981;
            --danger: #EF4444;
            --bg: #F9FAFB;
            --sidebar: #FFFFFF;
            --card: #FFFFFF;
            --text-dark: #111827;
            --text-gray: #6B7280;
            --border: #E5E7EB;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        * { box-sizing: border-box; transition: all 0.2s ease-in-out; }
        body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text-dark); display: flex; height: 100vh; }

        /* --- SIDEBAR --- */
        nav { width: 280px; background: var(--sidebar); border-right: 1px solid var(--border); display: flex; flex-direction: column; padding: 32px 24px; }
        .logo { font-size: 24px; font-weight: 800; color: var(--primary); display: flex; align-items: center; gap: 12px; margin-bottom: 48px; text-decoration: none; }
        .nav-link { display: flex; align-items: center; gap: 12px; padding: 12px 16px; text-decoration: none; color: var(--text-gray); font-weight: 500; border-radius: 12px; margin-bottom: 8px; }
        .nav-link:hover, .nav-link.active { background: var(--primary-light); color: var(--primary); }
        .logout { margin-top: auto; color: var(--danger); opacity: 0.8; }

        /* --- MAIN CONTENT --- */
        main { flex: 1; overflow-y: auto; padding: 48px 64px; }
        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
        h1 { font-size: 32px; font-weight: 700; margin: 0; letter-spacing: -0.02em; }
        .user-pill { background: #fff; padding: 8px 16px; border-radius: 100px; border: 1px solid var(--border); display: flex; align-items: center; gap: 10px; font-weight: 600; box-shadow: var(--shadow); }

        /* --- STATS --- */
        .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 48px; }
        .stat-card { background: var(--card); padding: 24px; border-radius: 20px; border: 1px solid var(--border); box-shadow: var(--shadow); }
        .stat-label { color: var(--text-gray); font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
        .stat-value { font-size: 28px; font-weight: 700; color: var(--text-dark); }

        /* --- GRID LAYOUT --- */
        .content-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 32px; }
        .section-title { font-size: 20px; font-weight: 700; margin-bottom: 24px; display: flex; align-items: center; gap: 10px; }

        /* --- CARDS & FORMS --- */
        .glass-card { background: var(--card); border-radius: 24px; border: 1px solid var(--border); padding: 32px; box-shadow: var(--shadow); }
        .form-group { margin-bottom: 20px; }
        label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 8px; color: var(--text-dark); }
        input, select { width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid var(--border); font-family: inherit; font-size: 15px; outline: none; }
        input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px var(--primary-light); }
        
        button { cursor: pointer; border: none; font-family: inherit; font-weight: 600; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { background: var(--primary); color: white; padding: 12px 24px; border-radius: 12px; width: 100%; font-size: 16px; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.4); }

        /* --- PROPERTY LIST --- */
        .property-item { background: #fff; border-radius: 16px; padding: 20px; border: 1px solid var(--border); margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between; }
        .prop-info { display: flex; flex-direction: column; gap: 4px; }
        .prop-name { font-weight: 700; font-size: 17px; }
        .prop-addr { color: var(--text-gray); font-size: 13px; }
        .actions { display: flex; gap: 12px; }
        .btn-icon { width: 42px; height: 42px; border-radius: 10px; background: var(--bg); color: var(--text-dark); border: 1px solid var(--border); }
        .btn-icon:hover { background: var(--primary-light); color: var(--primary); }
        .btn-email { background: var(--primary); color: white; border: none; }

        /* --- AI BADGE --- */
        .ai-badge { background: linear-gradient(135deg, #6366F1, #A855F7); color: white; padding: 4px 10px; border-radius: 100px; font-size: 11px; font-weight: 700; text-transform: uppercase; }

        /* --- TOAST --- */
        #toast { position: fixed; bottom: 32px; right: 32px; background: var(--text-dark); color: white; padding: 16px 24px; border-radius: 16px; display: none; z-index: 1000; animation: slideUp 0.3s ease-out; }
        @keyframes slideUp { from { transform: translateY(100px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    </style>
</head>
<body>

<nav>
    <a href='#' class='logo'><i data-lucide='layers'></i> Doc2Loc</a>
    <div class='nav-nav'>
        <a href='#' class='nav-link active'><i data-lucide='layout-dashboard'></i> Dashboard</a>
        <a href='#' class='nav-link'><i data-lucide='home'></i> Mes Biens</a>
        <a href='#' class='nav-link'><i data-lucide='users'></i> Locataires</a>
        <a href='#' class='nav-link'><i data-lucide='sparkles'></i> Analyse AI</a>
        <a href='/admin-leads.html' class='nav-link' id='adminLink' style='display:none;'><i data-lucide='shield'></i> Admin (Leads)</a>
        <button id="adminBtn" style="display:none;">Admin (Leads)</button>
    </div>
    <a href='#' onclick='logout()' class='nav-link logout'><i data-lucide='log-out'></i> Déconnexion</a>
</nav>

<main>
    <header>
        <h1>Vue d'ensemble</h1>
        <div class='user-pill'>
            <i data-lucide='user-circle'></i>
            <span id='user-name'>Bailleur</span>
            <span id="plan-badge" class="ai-badge" style="display:none; margin-left:8px;"></span>
          </div>
          
    </header>

    <div class='stats-grid'>
        <div class='stat-card'>
            <div class='stat-label'>Revenus Estimés</div>
            <div class='stat-value' id='total-revenue'>0 €</div>
        </div>
        <div class='stat-card'>
            <div class='stat-label'>Biens Sous Gestion</div>
            <div class='stat-value' id='count-properties'>0</div>
        </div>
        <div class='stat-card'>
            <div class='stat-label'>Dossiers Locataires</div>
            <div class='stat-value' id='count-tenants'>0</div>
        </div>
    </div>

    <div class='content-grid'>
        <div>
            <div class='section-title'><i data-lucide='list-checks'></i> Portefeuille Immobilier</div>
            <div id='lP'>
                </div>
        </div>

        <div style='display: flex; flex-direction: column; gap: 32px;'>
            <div class='glass-card'>
                <div class='section-title'><i data-lucide='plus-circle'></i> Nouveau Bien</div>
                <form id='fP'>
                    <div class='form-group'>
                        <label>Dénomination du bien</label>
                        <input id='pn' placeholder='Appartement T3, Loft…' required>
                    </div>

                    <div style='display:grid; grid-template-columns: 1fr 1fr; gap: 16px;'>
                      <div class='form-group'>
                        <label>Loyer Mensuel HC (€)</label>
                        <input id='pr' type='number' placeholder='850' required>
                      </div>
                      <div class='form-group'>
                        <label>Charges (€) (optionnel)</label>
                        <input id='pch' type='number' placeholder='50'>
                      </div>
                    </div>

                    <div class='form-group'>
                        <label>Adresse (rue + numéro)</label>
                        <input id='pal' placeholder='12 rue de la Paix' required>
                    </div>

                    <div style='display:grid; grid-template-columns: 1fr 1fr; gap: 16px;'>
                      <div class='form-group'>
                        <label>Code postal</label>
                        <input id='pzip' placeholder='75015' required>
                      </div>
                      <div class='form-group'>
                        <label>Commune</label>
                        <select id='pcity' required>
                          <option value=''>-- Choisir une commune --</option>
                        </select>
                        <div style='margin-top:8px; color: var(--text-gray); font-size: 12px; font-weight: 600;' id='pcityHelp'></div>
                      </div>
                    </div>

                    <button type='submit' class='btn-primary'>Créer le bien</button>
</form>
            </div>

            <div class='glass-card' style='border-top: 4px solid var(--primary);'>
                <div class='section-title'><i data-lucide='user-plus'></i> Assigner un Locataire</div>
                <form id='fT'>
                    <div style='display: grid; grid-template-columns: 1fr 1fr; gap: 16px;'>
                        <div class='form-group'><label>Prénom</label><input id='tfn' required></div>
                        <div class='form-group'><label>Nom</label><input id='tln' required></div>
                    </div>
                    <div class='form-group'><label>Email de contact</label><input id='tem' type='email' required></div>
                    <div class='form-group'><label>Bien associé</label><select id='ts' required></select></div>
                    <button type='submit' class='btn-primary' style='background: #111827;'>Lier le dossier</button>
                </form>
            </div>
        </div>
    </div>
</main>

<div id='toast'></div>

<script>
    lucide.createIcons();
    const tok = localStorage.getItem('token');

    function showToast(msg) {
        const t = document.getElementById('toast');
        t.innerText = msg; t.style.display = 'block';
        setTimeout(() => { t.style.display = 'none'; }, 3000);
    }


    // --- Communes auto (anti-erreurs) ---
    async function loadCommunes(zip){
        const help = document.getElementById('pcityHelp');
        const select = document.getElementById('pcity');

        help.innerText = '';
        select.innerHTML = "<option value=''>-- Choisir une commune --</option>";

        if(!/^\d{5}$/.test(zip)){
          help.innerText = "Entre un code postal valide (5 chiffres).";
          return;
        }

        try{
          const url = "https://geo.api.gouv.fr/communes?codePostal=" + encodeURIComponent(zip) + "&fields=nom&format=json&geometry=centre";
          const r = await fetch(url);
          const arr = await r.json();
          if(!Array.isArray(arr) || arr.length === 0){
            help.innerText = "Aucune commune trouvée pour ce code postal.";
            return;
          }
          arr.sort((a,b)=>String(a.nom).localeCompare(String(b.nom)));
          for(const c of arr){
            const opt = document.createElement('option');
            opt.value = c.nom;
            opt.textContent = c.nom;
            select.appendChild(opt);
          }
          help.innerText = arr.length + " commune(s) trouvée(s).";
        }catch(e){
          help.innerText = "Impossible de charger les communes (réseau).";
        }
    }

    async function load() {
        try {
            const rU = await fetch('/api/auth/profile', {headers: {'x-auth-token': tok}});
            const u = await rU.json();
            document.getElementById('user-name').innerText = (u.firstName || 'Bailleur');
            try {
  const rB = await fetch('/api/billing/status', { headers: { 'x-auth-token': tok } });
  const b = await rB.json();
  const badge = document.getElementById('plan-badge');
  if (badge) {
    badge.style.display = 'inline-block';
    if (b.plan === 'PRO') badge.innerText = 'PRO';
    else badge.innerText = `FREE • ${(b.usage && b.usage.receiptsSent) || 0}/${(b.limits && b.limits.receiptEmailPerMonth && b.limits.receiptEmailPerMonth.FREE) || 3}`;
  }
} catch(e) {
  console.warn('billing badge fail', e);
}


            const ps = await(await fetch('/api/properties', {headers: {'x-auth-token': tok}})).json();
            const ts2 = await(await fetch('/api/tenants', {headers: {'x-auth-token': tok}})).json();
            
            const lP = document.getElementById('lP'), ts = document.getElementById('ts');
            lP.innerHTML = ''; ts.innerHTML = '<option value="">-- Sélectionner un bien --</option>';
            
            let rev = 0;
            ps.forEach(p => {
                rev += p.rentAmount;
                lP.innerHTML += `
                <div class='property-item'>
                    <div class='prop-info'>
                        <div style='display:flex; align-items:center; gap:8px'>
                            <span class='prop-name'>${p.name}</span>
                            <span class='ai-badge'>Check OK</span>
                        </div>
                        <span class='prop-addr'>${(p.addressLine || p.address || '')}${(p.zipCode && p.city) ? (' • ' + p.zipCode + ' ' + p.city) : ''} • <strong>${p.rentAmount}€</strong>${p.chargesAmount ? (' + ' + p.chargesAmount + '€ charges') : ''}</span>
                    </div>
                    <div class='actions'>
                        <button class='btn-icon' onclick="openProperty('${p._id}')" title='Détails'><i data-lucide='layout'></i></button>
                        <button class='btn-icon' onclick="pdf('${p._id}')" title='Voir PDF'><i data-lucide='file-text'></i></button>
                        <button class='btn-icon btn-email' onclick="email('${p._id}', this)" title='Envoyer par mail'><i data-lucide='send'></i></button>
                        <button class='btn-icon' style='color:var(--danger)' onclick="del('properties', '${p._id}')"><i data-lucide='trash-2'></i></button>
                    </div>
                </div>`;
                ts.innerHTML += `<option value='${p._id}'>${p.name}</option>`;
            });
            
            document.getElementById('total-revenue').innerText = rev.toLocaleString() + ' €';
            document.getElementById('count-properties').innerText = ps.length;
            document.getElementById('count-tenants').innerText = ts2.length;
            lucide.createIcons();

        } catch(e) { console.error(e); }
    }

    async function pdf(id){
        const r = await fetch('/api/documents/quittance/'+id, {headers: {'x-auth-token': tok}});
        if(r.ok){
            const b = await r.blob(); const u = URL.createObjectURL(b);
            const a = document.createElement('a'); a.href=u; a.download='quittance.pdf'; a.click();
            showToast('PDF généré avec succès');
        }
    }

    async function email(id, btn){
        const original = btn.innerHTML;
        btn.innerHTML = '<i data-lucide="refresh-cw" class="spin"></i>';
        try{ 
            const r = await fetch('/api/documents/email/'+id, {method:'POST', headers:{'x-auth-token':tok}});
            const d = await r.json();
            showToast(d.msg);
        } catch(e){ showToast('Erreur d\'envoi'); }
        btn.innerHTML = original; lucide.createIcons();
    }

    async function del(type, id) {
        await fetch('/api/'+type+'/'+id, {method:'DELETE', headers:{'x-auth-token':tok}});
        load();
        showToast('Supprimé');
    }

    document.getElementById('fP').onsubmit = async(e) => {
        e.preventDefault();

        const name = document.getElementById('pn').value.trim();
        const rentAmount = document.getElementById('pr').value;
        const chargesAmount = document.getElementById('pch').value;
        const addressLine = document.getElementById('pal').value.trim();
        const zipCode = document.getElementById('pzip').value.trim();
        const city = document.getElementById('pcity').value;

        if(!/^\d{5}$/.test(zipCode)){
          showToast('Code postal invalide (5 chiffres)');
          return;
        }
        if(!city){
          showToast('Choisis une commune (liste auto)');
          return;
        }

        const address = `${addressLine}, ${zipCode} ${city}`;

        const r = await fetch('/api/properties', {
          method:'POST',
          headers:{'Content-Type':'application/json','x-auth-token':tok},
          body: JSON.stringify({ name, rentAmount, chargesAmount, addressLine, zipCode, city, address })
        });

        const d = await r.json().catch(()=>({}));
        if(!r.ok){
          showToast(d.msg || 'Erreur création bien');
          return;
        }

        load();
        e.target.reset();
        // reset select
        document.getElementById('pcity').innerHTML = "<option value=''>-- Choisir une commune --</option>";
        document.getElementById('pcityHelp').innerText = "";
        showToast('Bien ajouté');
    };

document.getElementById('fT').onsubmit = async (e) => {
  e.preventDefault();

  try {
    const r = await fetch('/api/tenants', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-auth-token': tok },
      body: JSON.stringify({
        firstName: document.getElementById('tfn').value,
        lastName: document.getElementById('tln').value,
        email: document.getElementById('tem').value,
        property: document.getElementById('ts').value
      })
    });

    let d = {};
    try { d = await r.json(); } catch (_) {}

    if (!r.ok) {
      // ✅ affiche le message backend (ex: "Ce bien a déjà un locataire")
      showToast(d.msg || "Erreur lors de la liaison du locataire");
      return;
    }

    await load();
    e.target.reset();
    showToast('Locataire lié');
  } catch (err) {
    console.error(err);
    showToast("Erreur réseau");
  }
};

    function logout(){ localStorage.clear(); location.href='/login.html'; }
async function setupAdminLink() {
        try {
            if (!tok) return;
            const r = await fetch('/api/admin/leads?limit=1', {
                headers: { 'x-auth-token': tok }
            });
            if (r.ok) {
                const link = document.getElementById('adminLink');
                if (link) {
                    link.style.display = 'flex'; // .nav-link = display:flex
                    lucide.createIcons(); // pour afficher l'icône shield
                }
            }
        } catch (e) {
            // pas admin / token invalide / erreur réseau -> on ne montre rien
        }
    }
    setupAdminLink();

    
    // Bind CP => communes
    const zipEl = document.getElementById('pzip');
    if(zipEl){
      zipEl.addEventListener('input', (e)=>{
        loadCommunes(e.target.value.trim());
      });
    }

    load();

async function isAdmin() {
  try {
    const token = localStorage.getItem("token");
    if (!token) return false;

    // On réutilise ton endpoint admin (protégé)
    const r = await fetch("/api/admin/leads?limit=1", {
      headers: { "x-auth-token": token }
    });

    return r.ok; // si OK => admin, sinon 403/401 => pas admin
  } catch (e) {
    return false;
  }
}

(async () => {
  const btn = document.getElementById("adminBtn");
  if (!btn) return;

  const ok = await isAdmin();
  if (ok) {
    btn.style.display = "inline-block";
    btn.addEventListener("click", () => {
      window.location.href = "/admin-leads.html";
    });
  }
})();




function openProperty(id){ window.location.href = '/property.html?id=' + encodeURIComponent(id); }
</script>
</body>
</html>
