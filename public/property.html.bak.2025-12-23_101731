<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Doc2Loc — Fiche bien</title>
  <style>
    :root{
      --bg:#0b1220; --card:#101a2f; --muted:#94a3b8; --text:#e5e7eb;
      --border:rgba(148,163,184,.18); --shadow:0 18px 50px rgba(0,0,0,.35);
      --blue:#4F46E5; --green:#22c55e; --red:#ef4444;
    }
    *{box-sizing:border-box}
    body{margin:0;background:radial-gradient(900px 600px at 20% -10%,rgba(79,70,229,.35),transparent 55%),
                    radial-gradient(900px 700px at 120% 10%,rgba(34,197,94,.18),transparent 55%),var(--bg);
         color:var(--text);font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial}
    a{color:inherit}
    .wrap{max-width:1100px;margin:28px auto;padding:0 16px}
    .top{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px}
    h1{margin:0;font-size:20px}
    .pill{font-size:12px;padding:6px 10px;border:1px solid var(--border);border-radius:999px;color:var(--muted)}
    .grid{display:grid;grid-template-columns:1.1fr .9fr;gap:14px}
    @media(max-width:900px){.grid{grid-template-columns:1fr}}
    .card{background:linear-gradient(180deg,rgba(16,26,47,.92),rgba(16,26,47,.80));
          border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow);padding:16px}
    .head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:10px}
    h2{margin:0;font-size:15px}
    .muted{color:var(--muted);font-size:13px}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    @media(max-width:600px){.row{grid-template-columns:1fr}}
    label{display:block;font-size:12px;color:var(--muted);margin:0 0 6px 0}
    input,select{width:100%;padding:10px 12px;border-radius:12px;border:1px solid var(--border);
                 background:#0b1326;color:var(--text);outline:none}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 12px;border-radius:12px;
         border:1px solid var(--border);background:#0b1326;color:var(--text);cursor:pointer;text-decoration:none}
    .btn.primary{background:var(--blue);border-color:var(--blue)}
    .btn.green{background:var(--green);border-color:var(--green);color:#06210f}
    .btn.red{background:transparent;border-color:rgba(239,68,68,.45);color:#fecaca}
    .btn:disabled{opacity:.45;cursor:not-allowed}
    .actions{display:flex;flex-wrap:wrap;gap:10px}
    .hr{height:1px;background:var(--border);margin:14px 0}
    .kv{display:flex;flex-direction:column;gap:3px}
    .kv b{font-size:14px}
    table{width:100%;border-collapse:collapse}
    th,td{padding:10px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:top}
    th{color:var(--muted);font-weight:600;text-align:left}
    .toast{position:fixed;right:18px;bottom:18px;background:#111827;border:1px solid var(--border);
           padding:10px 12px;border-radius:12px;display:none;max-width:360px}
    .small{font-size:12px}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <div style="display:flex;align-items:center;gap:10px">
        <h1>Fiche bien</h1>
        <span id="status" class="pill">Chargement…</span>
        <span id="dirty" class="pill" style="display:none;border-color:rgba(239,68,68,.35);color:#fecaca">Non enregistré</span>
      </div>
      <div class="actions">
        <a class="btn" href="/dashboard.html">← Dashboard</a>
        <a class="btn" id="btnTenant" href="#" style="display:none">Fiche locataire</a>
      </div>
    </div>

    <div class="grid">
      <!-- LEFT -->
      <div class="card">
        <div class="head">
          <h2>Résumé</h2>
          <div class="actions">
            <button class="btn" id="btnEdit">Modifier</button>
            <button class="btn" id="btnPdf" disabled>PDF quittance</button>
            <button class="btn green" id="btnEmail" disabled>Envoyer quittance</button>
          </div>
        </div>

        <div class="kv">
          <b id="p_name">Chargement…</b>
          <div class="muted" id="p_addr">Chargement…</div>
          <div class="muted" id="p_amounts">Chargement…</div>
        </div>

        <div class="hr"></div>

        <div id="tenantBox">
          <div class="muted">Chargement…</div>
        </div>

        <div id="editCard" class="card" style="margin-top:14px;display:none">
          <div class="head">
            <h2>Modifier le bien</h2>
            <span class="muted small">Adresse v2 + loyer + charges</span>
          </div>

          <div class="row">
            <div>
              <label>Nom</label>
              <input id="editName" placeholder="Nom du bien">
            </div>
            <div>
              <label>Surface (m²)</label>
              <input id="editSurface" type="number" step="0.1" placeholder="Optionnel">
            </div>
          </div>

          <div class="row" style="margin-top:10px">
            <div>
              <label>Rue</label>
              <input id="editAddressLine" placeholder="12 rue de ...">
            </div>
            <div>
              <label>Code postal</label>
              <input id="editZip" maxlength="5" placeholder="75001">
            </div>
          </div>

          <div class="row" style="margin-top:10px">
            <div>
              <label>Commune</label>
              <select id="editCity">
                <option value="">—</option>
              </select>
              <div class="muted small" id="cityHint" style="margin-top:6px"></div>
            </div>
            <div></div>
          </div>

          <div class="row" style="margin-top:10px">
            <div>
              <label>Loyer HC (€)</label>
              <input id="editRent" type="number" step="0.01" placeholder="0.00">
            </div>
            <div>
              <label>Charges (€)</label>
              <input id="editCharges" type="number" step="0.01" placeholder="0.00">
            </div>
          </div>

          <div class="actions" style="justify-content:flex-end;margin-top:12px">
            <button class="btn" id="btnCancelEdit">Annuler</button>
            <button class="btn primary" id="btnSaveEdit">Enregistrer</button>
          </div>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="card">
        <div class="head">
          <h2>Documents du bien</h2>
          <div class="muted" id="docCount">—</div>
        </div>

        <div class="muted" style="margin-bottom:10px">
          Bail, état des lieux, diagnostics, quittances, dossier locataire…
        </div>

        <div class="row">
          <div>
            <label>Type</label>
            <select id="docType">
              <option value="bail">Bail</option>
              <option value="edl">État des lieux</option>
              <option value="diag">Diagnostics</option>
              <option value="quittance">Quittance</option>
              <option value="dossier_locataire">Dossier locataire</option>
              <option value="autre">Autre</option>
            </select>
          </div>
          <div>
            <label>Fichier</label>
            <input id="file" type="file">
          </div>
        </div>

        <div class="actions" style="margin-top:10px">
          <button class="btn primary" id="btnUpload" disabled>Uploader</button>
        </div>

        <div style="overflow:auto;border:1px solid var(--border);border-radius:12px;margin-top:12px">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Fichier</th>
                <th>Taille</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="docsTbody">
              <tr><td colspan="5" class="muted">Chargement…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

<script>
  const tok = localStorage.getItem("token");
  if(!tok) location.href="/login.html";

  const qs = new URLSearchParams(location.search);
  const propertyId = qs.get("id");
  if(!propertyId) location.href="/dashboard.html";

  const $ = (id)=>document.getElementById(id);

  function toast(msg, ok=true){
    const t = $("toast");
    t.textContent = msg;
    t.style.background = ok ? "#111827" : "#7f1d1d";
    t.style.display = "block";
    setTimeout(()=>t.style.display="none", 2400);
  }

  window.addEventListener("error", (e)=>{
    console.error("JS error", e && (e.error||e.message));
  });

  async function apiJson(url, opts={}){
    const r = await fetch(url, {
      ...opts,
      headers: { "x-auth-token": tok, ...(opts.headers||{}) }
    });
    const ct = (r.headers.get("content-type")||"").toLowerCase();
    const data = ct.includes("application/json") ? await r.json().catch(()=>null) : await r.text().catch(()=>null);

    if(r.status===401 || r.status===403){
      localStorage.clear();
      location.href="/login.html";
      return { ok:false, status:r.status, data };
    }
    return { ok:r.ok, status:r.status, data };
  }

  function fmtDate(d){
    try{ return new Date(d).toLocaleDateString("fr-FR"); }catch(e){ return "—"; }
  }
  function fmtBytes(n){
    n = Number(n||0);
    if(n < 1024) return n+" B";
    if(n < 1024*1024) return (n/1024).toFixed(1)+" KB";
    return (n/1024/1024).toFixed(1)+" MB";
  }
  function esc(s){ return String(s||"").replace(/[&<>"']/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m])); }

  let currentProperty = null;
  let isDirty = false;

  function setDirty(v){
    isDirty = !!v;
    const el = document.getElementById('dirty');
    if(!el) return;
    el.style.display = isDirty ? 'inline-block' : 'none';
  }

  window.addEventListener('beforeunload', (e)=>{
    if(!isDirty) return;
    e.preventDefault();
    e.returnValue = '';
  });

  function setStatus(txt){ $("status").textContent = txt; }

  function addrStr(p){
    const v2 = [p?.addressLine, p?.zipCode, p?.city].filter(Boolean).join(", ");
    return (v2 && v2.includes(",")) ? v2 : (p?.address || v2 || "—");
  }

  async function loadProperty(){
    setStatus("Chargement…");
    const r = await apiJson("/api/properties/" + propertyId);
    if(!r.ok){
      toast((r.data && r.data.msg) || "Bien introuvable", false);
      setStatus("Erreur");
      return;
    }
    currentProperty = r.data;

    $("p_name").textContent = currentProperty?.name || "—";
    $("p_addr").textContent = addrStr(currentProperty);

    const rent = Number(currentProperty?.rentAmount||0);
    const charges = Number(currentProperty?.chargesAmount||0);
    $("p_amounts").textContent = `Loyer: ${rent.toFixed(2)}€ • Charges: ${charges.toFixed(2)}€ • Total: ${(rent+charges).toFixed(2)}€`;

    // enable actions only if we have property
    $("btnPdf").disabled = false;
    $("btnEmail").disabled = false;
    $("btnUpload").disabled = false;

    fillEditForm(currentProperty);
    setStatus("OK ✅");
  }

  async function loadTenant(){
    const r = await apiJson("/api/tenants/by-property/" + propertyId);
    if(r.status === 404){
      $("tenantBox").innerHTML = `
        <div class="muted">Aucun locataire lié à ce bien.</div>
        <div style="margin-top:10px">
          <a class="btn" href="/dashboard.html">Assigner un locataire</a>
        </div>`;
      $("btnTenant").style.display = "none";
      return;
    }
    if(!r.ok){
      $("tenantBox").innerHTML = `<div class="muted">Erreur chargement locataire</div>`;
      $("btnTenant").style.display = "none";
      return;
    }
    const t = r.data;
    $("tenantBox").innerHTML = `
      <div><b>${esc((t.firstName||"") + " " + (t.lastName||""))}</b></div>
      <div class="muted">${esc(t.email || "Email non renseigné")}</div>`;
    $("btnTenant").href = "/tenant.html?id=" + encodeURIComponent(t._id);
    $("btnTenant").style.display = "inline-flex";
  }

  async function loadDocs(){
    const r = await apiJson("/api/property-documents/" + propertyId);
    if(!r.ok){
      $("docsTbody").innerHTML = `<tr><td colspan="5" class="muted">Erreur chargement documents</td></tr>`;
      $("docCount").textContent = "—";
      return;
    }
    const docs = Array.isArray(r.data) ? r.data : [];
    $("docCount").textContent = docs.length + " doc(s)";

    if(docs.length===0){
      $("docsTbody").innerHTML = `<tr><td colspan="5" class="muted">Aucun document. Uploade ton premier fichier.</td></tr>`;
      return;
    }

    $("docsTbody").innerHTML = docs.map(d=>`
      <tr>
        <td>${fmtDate(d.createdAt)}</td>
        <td class="muted">${esc(d.type || "—")}</td>
        <td><b>${esc(d.originalName || d.filename || "document")}</b></td>
        <td class="muted">${fmtBytes(d.size)}</td>
        <td style="text-align:right;white-space:nowrap">
          <button class="btn" onclick="downloadDoc('${d._id}','${esc(d.originalName||"document")}')">Télécharger</button>
          <button class="btn red" onclick="deleteDoc('${d._id}')">Suppr.</button>
        </td>
      </tr>
    `).join("");
  }

  async function downloadBlob(url, filename){
    const r = await fetch(url, { headers: { "x-auth-token": tok } });
    if(!r.ok){ toast("Téléchargement impossible", false); return; }
    const blob = await r.blob();
    const u = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = u;
    a.download = filename || "document";
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(()=>URL.revokeObjectURL(u), 15000);
  }

  window.downloadDoc = async (id, name)=>{
    await downloadBlob("/api/property-documents/file/" + id, name);
  };

  window.deleteDoc = async (id)=>{
    if(!confirm("Supprimer ce document ?")) return;
    const r = await apiJson("/api/property-documents/" + id, { method:"DELETE" });
    if(r.ok){ toast("Document supprimé ✅"); loadDocs(); }
    else toast((r.data && r.data.msg) || "Erreur suppression", false);
  };

  // --- Edit helpers ---
  function toggleEdit(show){
    $("editCard").style.display = show ? "block" : "none";
    if(show) $("editCard").scrollIntoView({behavior:"smooth", block:"start"});
  }

  function guessParts(p){
    const line = String(p?.addressLine||"").trim();
    const zip = String(p?.zipCode||"").trim();
    const city = String(p?.city||"").trim();
    if(line && zip && city) return { line, zip, city };

    const a = String(p?.address||"").trim();
    const m = a.match(/^(.*?),\s*(\d{5})\s+(.+)$/);
    if(m) return { line:m[1].trim(), zip:m[2].trim(), city:m[3].trim() };
    return { line:a, zip:"", city:"" };
  }

  async function refreshCity(zip, selected){
    $("editCity").innerHTML = `<option value="">—</option>`;
    $("cityHint").textContent = "";
    if(!/^\d{5}$/.test(zip||"")) return;

    try{
      const url = "https://geo.api.gouv.fr/communes?codePostal="+encodeURIComponent(zip)+"&fields=nom&format=json&geometry=centre";
      const rr = await fetch(url);
      const arr = await rr.json().catch(()=>[]);
      const names = (Array.isArray(arr)?arr:[]).map(x=>x.nom).filter(Boolean);
      names.forEach(n=>{
        const opt = document.createElement("option");
        opt.value = n; opt.textContent = n;
        $("editCity").appendChild(opt);
      });
      if(selected) $("editCity").value = selected;
      $("cityHint").textContent = names.length ? "Sélectionne ta commune" : "Aucune commune trouvée";
    }catch(e){
      $("cityHint").textContent = "Suggestion communes indisponible (réseau).";
    }
  }

  function fillEditForm(p){
    const parts = guessParts(p||{});
    $("editName").value = p?.name || "";
    $("editSurface").value = (p?.surfaceM2 ?? "");
    $("editAddressLine").value = parts.line || "";
    $("editZip").value = parts.zip || "";
    $("editRent").value = (p?.rentAmount ?? "");
    $("editCharges").value = (p?.chargesAmount ?? 0);
    refreshCity(parts.zip || "", parts.city || "");
  }
  // form filled from server -> clean
  setDirty(false);


  async function saveEdit(){
    const btn = $("btnSaveEdit");
    btn.disabled = true;

    try{
      const name = $("editName").value.trim();
      const addressLine = $("editAddressLine").value.trim();
      const zipCode = $("editZip").value.trim();
      const city = $("editCity").value || "";
      const rentAmount = Number($("editRent").value);
      const chargesAmount = Number($("editCharges").value || 0);
      const surfaceM2 = $("editSurface").value ? Number($("editSurface").value) : null;

      if(!name){ toast("Nom requis", false); return; }
      if(!addressLine){ toast("Rue requise", false); return; }
      if(!/^\d{5}$/.test(zipCode)){ toast("Code postal invalide", false); return; }
      if(!city){ toast("Choisis une commune", false); return; }
      if(!Number.isFinite(rentAmount) || rentAmount<=0){ toast("Loyer invalide", false); return; }
      if(!Number.isFinite(chargesAmount) || chargesAmount<0){ toast("Charges invalides", false); return; }

      const payload = { name, addressLine, zipCode, city, rentAmount, chargesAmount, surfaceM2 };

      const r = await apiJson("/api/properties/" + propertyId, {
        method:"PUT",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify(payload)
      });

      if(!r.ok){ toast((r.data && r.data.msg) || "Sauvegarde impossible", false); return; }

      toast("Bien mis à jour ✅");
      setDirty(false);
      toggleEdit(false);
      await loadProperty();
    } finally {
      btn.disabled = false;
    }
  }

  // --- Actions PDF/email/upload ---
  $("btnPdf").addEventListener("click", async ()=>{
    const btn = $("btnPdf");
    btn.disabled = true;
    try{
      const r = await fetch("/api/documents/quittance/" + propertyId, { headers:{ "x-auth-token": tok } });
      if(!r.ok){
        const j = await r.json().catch(()=>({}));
        toast(j.msg || "PDF impossible", false);
        return;
      }
      const blob = await r.blob();
      const u = URL.createObjectURL(blob);
      window.open(u, "_blank");
      setTimeout(()=>URL.revokeObjectURL(u), 60000);
    } finally {
      btn.disabled = false;
    }
  });

  $("btnEmail").addEventListener("click", async ()=>{
    const btn = $("btnEmail");
    btn.disabled = true;
    try{
      const r = await apiJson("/api/documents/email/" + propertyId, { method:"POST" });
      if(r.ok) toast((r.data && r.data.msg) || "Email envoyé ✅");
      else toast((r.data && r.data.msg) || "Email impossible", false);
    } finally {
      btn.disabled = false;
    }
  });

  $("btnUpload").addEventListener("click", async ()=>{
    const btn = $("btnUpload");
    const f = $("file").files[0];
    if(!f){ toast("Choisis un fichier", false); return; }

    btn.disabled = true;
    try{
      const fd = new FormData();
      fd.append("file", f);
      fd.append("type", $("docType").value || "autre");

      const r = await fetch("/api/property-documents/upload/" + propertyId, {
        method:"POST",
        headers:{ "x-auth-token": tok },
        body: fd
      });
      const j = await r.json().catch(()=>({}));

      if(!r.ok){ toast(j.msg || "Upload impossible", false); return; }

      toast("Upload OK ✅");
      $("file").value = "";
      await loadDocs();
    hookDirty();
    } finally {
      btn.disabled = false;
    }
  });

  $("btnEdit").addEventListener("click", ()=>toggleEdit(true));
  $("btnCancelEdit").addEventListener("click", ()=>toggleEdit(false));
  $("btnSaveEdit").addEventListener("click", saveEdit);

  // debounce simple pour zip -> communes
  let zipTimer = null;
  $("editZip").addEventListener("input", ()=>{
    clearTimeout(zipTimer);
    zipTimer = setTimeout(()=>refreshCity($("editZip").value.trim(), $("editCity").value), 350);
  });

  
  function hookDirty(){
    const ids = ["editName","editSurface","editAddressLine","editZip","editCity","editRent","editCharges"];
    ids.forEach(id=>{
      const el = document.getElementById(id);
      if(!el) return;
      el.addEventListener("input", ()=>setDirty(true));
      el.addEventListener("change", ()=>setDirty(true));
    });
  }

  (async ()=>{
    await loadProperty();
    await loadTenant();
    await loadDocs();
  })();
</script>
</body>
</html>
