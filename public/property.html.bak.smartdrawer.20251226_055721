async function loadCandidatures(){
    const body = $("candTbody");
    if(!body) return;

    body.innerHTML = `<tr><td colspan="5" class="muted">Chargement…</td></tr>`;
    $("candCount").textContent = "—";

    const r = await apiJson("/api/properties/" + propertyId + "/candidatures");
    if(!r.ok){
      const msg = (r.data && r.data.msg) ? r.data.msg : ("Erreur API ("+r.status+")");
      body.innerHTML = `<tr><td colspan="5" class="muted">Candidatures indisponibles : ${esc(msg)}</td></tr>`;
      $("candCount").textContent = "—";
      return;
    }

    const items = Array.isArray(r.data) ? r.data : [];
    $("candCount").textContent = items.length + " candidature(s)";

    if(items.length === 0){
      body.innerHTML = `<tr><td colspan="5" class="muted">Aucune candidature pour le moment.</td></tr>`;
      return;
    }

    body.innerHTML = items.map(c=>{
      const name = ((c.firstName||"") + " " + (c.lastName||"")).trim() || "Candidat";
      const docs = Array.isArray(c.docs) ? c.docs : [];
      const buttons = docs.slice(0,4).map(d => (
        `<button class="btn" data-cdl="1" data-cand="${c._id}" data-doc="${d._id}" data-name="${escAttr(d.originalName||"document")}">${esc(shortDocName(d.originalName||"doc"))}</button>`
      )).join(" ");
      const more = (docs.length > 4) ? `<span class="muted">+${docs.length-4}</span>` : "";
      return `
        <tr>
          <td class="muted">${fmtDate(c.createdAt)}</td>
          <td><b>${esc(name)}</b></td>
          <td class="muted">${esc(c.email||"—")}</td>
          <td style="white-space:nowrap">${buttons} ${more}</td>
          <td style="text-align:right;white-space:nowrap">
            <button class="btn" data-cdet="1" data-cand="${c._id}">Détails</button> <button class="btn" data-call="all" data-cand="${c._id}">Tout</button>
          </td>
        </tr>
      `;
    }).join("");

    document.querySelectorAll("[data-cdl='1']").forEach(b=>{
      b.addEventListener("click", ()=>{
        const url = "/api/candidatures/file/" + encodeURIComponent(b.dataset.cand) + "/" + encodeURIComponent(b.dataset.doc);
        downloadBlob(url, b.dataset.name || "document");
      });
    });

    
    document.querySelectorAll("[data-cdet='1']").forEach(b=>{
      b.addEventListener("click", async ()=>{
        const candId = b.dataset.cand;
        // Utilise les données déjà en mémoire si présentes, sinon fetch détail
        let cand = items.find(x=>String(x._id)===String(candId));
        if(!cand || !cand.scoring){
          const r = await apiJson("/api/candidatures/" + encodeURIComponent(candId));
          if(!r.ok){ toast((r.data && r.data.msg) || "Détails indisponibles", false); return; }
          cand = r.data;
        }
        const sc = cand.scoring || {};
        const lines = [];
        lines.push("Score: " + (sc.grade || "—") + (typeof sc.total==="number" ? (" ("+sc.total+")") : ""));
        if (typeof sc.ratio === "number" && sc.ratio > 0) lines.push("Ratio loyer/revenus: " + sc.ratio.toFixed(2));
        lines.push("");
        (sc.breakdown || []).forEach(x=>{
          lines.push((x.label||x.key) + " : " + (x.points>=0?"+":"") + x.points + (x.detail ? (" — " + x.detail) : ""));
        });
        if((sc.flags||[]).length){
          lines.push("");
          lines.push("Flags: " + sc.flags.join(", "));
        }
        openCandDrawer(candId, cand);
      });
    });

document.querySelectorAll("[data-call='all']").forEach(b=>{
      b.addEventListener("click", ()=>{
        const candId = b.dataset.cand;
        const cand = items.find(x=>String(x._id)===String(candId));
        if(!cand) return;
