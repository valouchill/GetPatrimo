<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Doc2Loc — Fiche bien</title>
  
    <link rel='stylesheet' href='/ui.css?v=10'>
<style>
    :root{
      --bg:#0b1220; --card:#101a2f; --muted:#94a3b8; --text:#e5e7eb;
      --border:rgba(148,163,184,.18); --shadow:0 18px 50px rgba(0,0,0,.35);
      --blue:#4F46E5; --green:#22c55e; --red:#ef4444;
    }
    *{box-sizing:border-box}
    body{margin:0;background:radial-gradient(900px 600px at 20% -10%,rgba(79,70,229,.35),transparent 55%),
                    radial-gradient(900px 700px at 120% 10%,rgba(34,197,94,.18),transparent 55%),var(--bg);
         color:var(--text);font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial}
    a{color:inherit}
    .wrap{max-width:1100px;margin:28px auto;padding:0 16px}
    .top{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px}
    h1{margin:0;font-size:20px}
    .pill{font-size:12px;padding:6px 10px;border:1px solid var(--border);border-radius:999px;color:var(--muted)}
    .grid{display:grid;grid-template-columns:1.1fr .9fr;gap:14px}
    @media(max-width:900px){.grid{grid-template-columns:1fr}}
    .card{background:linear-gradient(180deg,rgba(16,26,47,.92),rgba(16,26,47,.80));
          border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow);padding:16px}
    .head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:10px}
    h2{margin:0;font-size:15px}
    .muted{color:var(--muted);font-size:13px}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    @media(max-width:600px){.row{grid-template-columns:1fr}}
    label{display:block;font-size:12px;color:var(--muted);margin:0 0 6px 0}
    input,select{width:100%;padding:10px 12px;border-radius:12px;border:1px solid var(--border);
                 background:#0b1326;color:var(--text);outline:none}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 12px;border-radius:12px;
         border:1px solid var(--border);background:#0b1326;color:var(--text);cursor:pointer;text-decoration:none}
    .btn.primary{background:var(--blue);border-color:var(--blue)}
    .btn.green{background:var(--green);border-color:var(--green);color:#06210f}
    .btn.red{background:transparent;border-color:rgba(239,68,68,.45);color:#fecaca}
    .btn:disabled{opacity:.45;cursor:not-allowed}
    .actions{display:flex;flex-wrap:wrap;gap:10px}
    .hr{height:1px;background:var(--border);margin:14px 0}
    .kv{display:flex;flex-direction:column;gap:3px}
    .kv b{font-size:14px}
    table{width:100%;border-collapse:collapse}
    th,td{padding:10px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:top}
    th{color:var(--muted);font-weight:600;text-align:left}
    .toast{position:fixed;right:18px;bottom:18px;background:#111827;border:1px solid var(--border);
           padding:10px 12px;border-radius:12px;display:none;max-width:360px}
    .small{font-size:12px}
  </style>

  <link rel="stylesheet" href="/elite.css"/>
    <script defer src='/ui.js?v=10'></script>
    <link rel='stylesheet' href='/harmonize.css?v=6'>
<style>
/* Cand Drawer */
#candDrawerOverlay{position:fixed;inset:0;background:rgba(0,0,0,.35);display:none;z-index:50}
#candDrawer{position:fixed;top:0;right:0;height:100vh;width:min(520px,92vw);background:var(--card,#fff);
  border-left:1px solid var(--border, rgba(15,23,42,.12)); box-shadow: -20px 0 50px rgba(2,8,23,.25);
  transform:translateX(105%); transition:transform .22s ease; z-index:51; display:flex; flex-direction:column}
#candDrawer.open{transform:translateX(0)}
.cd-head{padding:16px;border-bottom:1px solid var(--border, rgba(15,23,42,.12));display:flex;justify-content:space-between;gap:10px}
.cd-title{font-weight:900;letter-spacing:-.02em}
.cd-sub{font-size:12px;color:var(--muted,#5b6476);margin-top:3px}
.cd-body{padding:16px;overflow:auto;display:flex;flex-direction:column;gap:12px}
.cd-card{border:1px solid var(--border, rgba(15,23,42,.12));border-radius:14px;padding:12px;background:rgba(255,255,255,.7)}
.cd-row{display:flex;gap:10px;flex-wrap:wrap}
.cd-kpi{flex:1;min-width:170px}
.cd-kpi b{font-size:18px}
.tag{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border:1px solid var(--border, rgba(15,23,42,.12));
  border-radius:999px;font-size:12px;color:var(--muted,#5b6476);background:#fff;margin:4px 6px 0 0}
.cd-list{margin:0;padding-left:16px}
.cd-actions{padding:14px;border-top:1px solid var(--border, rgba(15,23,42,.12));display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap}
</style>
<style>
/* DrawerV2 */
#candDrawerOverlay{position:fixed;inset:0;background:rgba(0,0,0,.35);display:none;z-index:9998}
#candDrawer{position:fixed;top:0;right:0;height:100vh;width:min(560px,94vw);background:#fff;
  border-left:1px solid rgba(15,23,42,.12); box-shadow:-20px 0 50px rgba(2,8,23,.25);
  transform:translateX(105%); transition:transform .22s ease; z-index:9999; display:flex; flex-direction:column}
#candDrawer.open{transform:translateX(0)}
.cdh{padding:16px;border-bottom:1px solid rgba(15,23,42,.12);display:flex;justify-content:space-between;gap:10px}
.cdt{font-weight:900;letter-spacing:-.02em}
.cds{font-size:12px;color:#5b6476;margin-top:3px}
.cdb{padding:16px;overflow:auto;display:flex;flex-direction:column;gap:12px}
.cdc{border:1px solid rgba(15,23,42,.12);border-radius:14px;padding:12px;background:rgba(255,255,255,.7)}
.cdr{display:flex;gap:10px;flex-wrap:wrap}
.cdk{flex:1;min-width:170px}
.cdk b{font-size:18px}
.tag{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border:1px solid rgba(15,23,42,.12);
  border-radius:999px;font-size:12px;color:#5b6476;background:#fff;margin:4px 6px 0 0}
.cdlist{margin:0;padding-left:16px}
.cda{padding:14px;border-top:1px solid rgba(15,23,42,.12);display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap}
</style>

<style>
/* CompareUI V1 */
#cmpOverlay{position:fixed;inset:0;background:rgba(0,0,0,.35);display:none;z-index:9996}
#cmpModal{position:fixed;left:50%;top:50%;transform:translate(-50%,-50%);width:min(1100px,96vw);max-height:92vh;
  background:#fff;border:1px solid rgba(15,23,42,.12);border-radius:18px;box-shadow:0 30px 80px rgba(2,8,23,.35);
  display:none;z-index:9997;overflow:hidden}
.cmpHead{padding:14px 16px;border-bottom:1px solid rgba(15,23,42,.12);display:flex;justify-content:space-between;gap:12px;align-items:center}
.cmpTitle{font-weight:900;letter-spacing:-.02em}
.cmpBody{padding:16px;overflow:auto;max-height:calc(92vh - 64px)}
.cmpGrid{display:grid;grid-template-columns:1fr;gap:12px}
@media(min-width:920px){.cmpGrid{grid-template-columns:1fr 1fr}}
.cmpCard{border:1px solid rgba(15,23,42,.12);border-radius:14px;padding:12px}
.cmpKpi{display:flex;gap:10px;flex-wrap:wrap;margin-top:8px}
.cmpTag{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border:1px solid rgba(15,23,42,.12);
  border-radius:999px;font-size:12px;color:#5b6476;background:#fff;margin:4px 6px 0 0}
</style>

</head>
<body>
  <div class="wrap">
    <div class="top">
      <div style="display:flex;align-items:center;gap:10px">
        <h1>Fiche bien</h1>
        <span id="status" class="pill">Chargement…</span>
      </div>
      <div class="actions">
        <a class="btn" href="/dashboard.html">← Dashboard</a>
        <a class="btn" id="btnTenant" href="#" style="display:none">Fiche locataire</a>
      </div>
    </div>

    <div class="grid">
      <!-- LEFT -->
      <div class="card">
        <div class="head">
          <h2>Résumé</h2>
          <div class="actions">
            <button class="btn" id="btnEdit">Modifier</button>
            <button class="btn" id="btnPdf" disabled>PDF quittance</button>
            <button class="btn green" id="btnEmail" disabled>Envoyer quittance</button>
          </div>
        </div>

        <div class="kv">
          <b id="p_name">Chargement…</b>
          <div class="muted" id="p_addr">Chargement…</div>
          <div class="muted" id="p_amounts">Chargement…</div>
        </div>

        <div class="hr"></div>

        <div id="tenantBox">
          <div class="muted">Chargement…</div>
        </div>

        <div id="editCard" class="card" style="margin-top:14px;display:none">
          <div class="head">
            <h2>Modifier le bien</h2>
            <span class="muted small">Adresse v2 + loyer + charges</span>
          </div>

          <div class="row">
            <div>
              <label>Nom</label>
              <input id="editName" placeholder="Nom du bien">
            </div>
            <div>
              <label>Surface (m²)</label>
              <input id="editSurface" type="number" step="0.1" placeholder="Optionnel">
            </div>
          </div>

          <div class="row" style="margin-top:10px">
            <div>
              <label>Rue</label>
              <input id="editAddressLine" placeholder="12 rue de ...">
            </div>
            <div>
              <label>Code postal</label>
              <input id="editZip" maxlength="5" placeholder="75001">
            </div>
          </div>

          <div class="row" style="margin-top:10px">
            <div>
              <label>Commune</label>
              <select id="editCity">
                <option value="">—</option>
              </select>
              <div class="muted small" id="cityHint" style="margin-top:6px"></div>
            </div>
            <div></div>
          </div>

          <div class="row" style="margin-top:10px">
            <div>
              <label>Loyer HC (€)</label>
              <input id="editRent" type="number" step="0.01" placeholder="0.00">
            </div>
            <div>
              <label>Charges (€)</label>
              <input id="editCharges" type="number" step="0.01" placeholder="0.00">
            </div>
          </div>

          <div class="actions" style="justify-content:flex-end;margin-top:12px">
            <button class="btn" id="btnCancelEdit">Annuler</button>
            <button class="btn primary" id="btnSaveEdit">Enregistrer</button>
          </div>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="card">
        <div class="head">
          <h2>Documents du bien</h2>
          <div class="muted" id="docCount">—</div>
        </div>

        <div class="muted" style="margin-bottom:10px">
          Bail, état des lieux, diagnostics, quittances, dossier locataire…
        </div>

        <div class="row">
          <div>
            <label>Type</label>
            <select id="docType">
              <option value="bail">Bail</option>
              <option value="edl">État des lieux</option>
              <option value="diag">Diagnostics</option>
              <option value="quittance">Quittance</option>
              <option value="dossier_locataire">Dossier locataire</option>
              <option value="autre">Autre</option>
            </select>
          </div>
          <div>
            <label>Fichier</label>
            <input id="file" type="file">
          </div>
        </div>

        <div class="actions" style="margin-top:10px">
          <button class="btn primary" id="btnUpload" disabled>Uploader</button>
        </div>

        <div style="overflow:auto;border:1px solid var(--border);border-radius:12px;margin-top:12px">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Fichier</th>
                <th>Taille</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="docsTbody">
              <tr><td colspan="5" class="muted">Chargement…</td></tr>
            </tbody>
          </table>
        </div>

        
<div class="hr"></div>

        <div class="head">
          <h2>Candidatures</h2>
          <div class="muted" id="candCount">—</div>
        </div>
        <div class="muted" style="margin-top:-6px;margin-bottom:10px">Génère un lien public et partage-le au candidat pour déposer son dossier.</div>

        <div class="row">
          <div style="flex:1;min-width:220px">
            <label>Lien public</label>
            <input id="applyLinkInput" readonly placeholder="Clique sur Générer…">
          </div>
        </div>
        <div class="actions" style="justify-content:flex-end;margin-top:10px">
          <button class="btn" id="btnApplyLink">Générer</button>
          <button class="btn" id="btnCopyApplyLink" disabled>Copier</button>
          <a class="btn" id="btnOpenApplyLink" target="_blank" style="display:none">Ouvrir</a>
        </div>

        <div style="margin-top:12px;overflow:auto;border:1px solid var(--border);border-radius:12px">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Candidat</th>
                <th>Email</th>
                <th>Docs</th>
                <th style="text-align:right">Actions</th>
              </tr>
            </thead>
            <tbody id="candTbody">
              <tr><td colspan="5" class="muted">Chargement…</td></tr>
            </tbody>
          </table>
        </div>

<div class="hr"></div>

        <div class="head">
          <h2>Historique</h2
          <div class="muted" id="evCount">—</div>
        </div>

        <div style="overflow:auto;border:1px solid var(--border);border-radius:12px;margin-top:12px">
          <table>
            <thead><tr><th>Date</th><th>Événement</th></tr></thead>
            <tbody id="eventsTbody">
              <tr><td colspan="2" class="muted">Chargement…</td></tr>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

<script>
  const tok = localStorage.getItem("token");
  if(!tok) location.href="/login.html";

  const qs = new URLSearchParams(location.search);
  const propertyId = qs.get("id");
  if(!propertyId) location.href="/dashboard.html";

  const $ = (id)=>document.getElementById(id);

  function toast(msg, ok=true){
    const t = $("toast");
    t.textContent = msg;
    t.style.background = ok ? "#111827" : "#7f1d1d";
    t.style.display = "block";
    setTimeout(()=>t.style.display="none", 2400);
  }

  async function apiJson(url, opts={}){
    const r = await fetch(url, {
      ...opts,
      headers: { "x-auth-token": tok, ...(opts.headers||{}) }
    });
    const ct = (r.headers.get("content-type")||"").toLowerCase();
    const data = ct.includes("application/json") ? await r.json().catch(()=>null) : await r.text().catch(()=>null);

    if(r.status===401 || r.status===403){
      localStorage.clear();
      location.href="/login.html";
      return { ok:false, status:r.status, data };
    }
    return { ok:r.ok, status:r.status, data };
  }

  function fmtDate(d){ try{ return new Date(d).toLocaleDateString("fr-FR"); }catch(e){ return "—"; } }
  function fmtDT(d){ try{ return new Date(d).toLocaleString("fr-FR"); }catch(e){ return "—"; } }
  function fmtBytes(n){
    n = Number(n||0);
    if(n < 1024) return n+" B";
    if(n < 1024*1024) return (n/1024).toFixed(1)+" KB";
    return (n/1024/1024).toFixed(1)+" MB";
  }
  function esc(s){ return String(s||"").replace(/[&<>"']/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m])); }

  let currentProperty = null;

  function setStatus(txt){ $("status").textContent = txt; }

  function addrStr(p){
    const v2 = [p?.addressLine, p?.zipCode, p?.city].filter(Boolean).join(", ");
    return (v2 && v2.includes(",")) ? v2 : (p?.address || v2 || "—");
  }

  function eventLabel(e){
    const t = e && e.type;
    if(t==='reminder_sent'){
      const tpl = e && e.meta && e.meta.template;
      const map = { rent_reminder:'Rappel quittance / loyer', missing_docs:'Documents manquants', late_payment:'Paiement en attente' };
      return 'Relance envoyée' + (tpl ? (' — ' + (map[tpl] || tpl)) : '');
    }
    if(t==='pdf_quittance_generated') return 'PDF quittance généré';
    if(t==='reminder_failed') return 'Échec relance (email)';
    if(t==='email_quittance_sent') return 'Quittance envoyée par email';
    if(t==='email_quittance_failed') return 'Échec envoi quittance (email)';
    if(t==='document_uploaded') return 'Document uploadé';
    if(t==='document_deleted') return 'Document supprimé';
    return t || '—';
  }


function eventDetail(e){
  const t = e && e.type;
  const m = (e && e.meta) ? e.meta : {};
  const parts = [];
  if (m.to) parts.push("À: " + m.to);
  if (m.subject) parts.push("Sujet: " + m.subject);
  if (m.messageId) parts.push("ID: " + m.messageId);
  if ((t === 'email_quittance_failed' || t === 'reminder_failed') && m.error) parts.push("Erreur: " + m.error);

  if (!parts.length) return "";
  return `<div class="muted" style="margin-top:2px">${esc(parts.join(" • "))}</div>`;
}

  async function loadEvents(){
    const body = $("eventsTbody");
    if(!body) return;

    body.innerHTML = `<tr><td colspan="2" class="muted">Chargement…</td></tr>`;
    $("evCount").textContent = "—";

    const r = await apiJson("/api/events/property/" + propertyId + "?limit=15");
    if(!r.ok){
      const msg = (r.data && r.data.msg) ? r.data.msg : ("Erreur API ("+r.status+")");
      body.innerHTML = `<tr><td colspan="2" class="muted">Historique indisponible : ${esc(msg)}</td></tr>`;
      $("evCount").textContent = "—";
      return;
    }

    const ev = Array.isArray(r.data) ? r.data : [];
    $("evCount").textContent = ev.length + " evt(s)";

    if(ev.length===0){
      body.innerHTML = `<tr><td colspan="2" class="muted">Aucun événement.</td></tr>`;
      return;
    }

    body.innerHTML = ev.map(e=>`
      <tr>
        <td class="muted">${fmtDT(e.createdAt)}</td>
        <td><b>${esc(eventLabel(e))}</b>${eventDetail(e)}</td>
      </tr>
    `).join("");
  }

  async function loadProperty(){
    setStatus("Chargement…");
    const r = await apiJson("/api/properties/" + propertyId);
    if(!r.ok){
      toast((r.data && r.data.msg) || "Bien introuvable", false);
      setStatus("Erreur");
      return;
    }
    currentProperty = r.data;

    // Prefill lien candidature si existant
    try{
      if(currentProperty && currentProperty.applyToken){
        setApplyLinkUrl(applyUrlFromToken(currentProperty.applyToken));
      }
    }catch(_){ }

    $("p_name").textContent = currentProperty?.name || "—";
    $("p_addr").textContent = addrStr(currentProperty);

    const rent = Number(currentProperty?.rentAmount||0);
    const charges = Number(currentProperty?.chargesAmount||0);
    $("p_amounts").textContent = `Loyer: ${rent.toFixed(2)}€ • Charges: ${charges.toFixed(2)}€ • Total: ${(rent+charges).toFixed(2)}€`;

    $("btnPdf").disabled = false;
    $("btnEmail").disabled = false;
    $("btnUpload").disabled = false;

    fillEditForm(currentProperty);
    setStatus("OK ✅");
  }

  async function loadTenant(){
    const r = await apiJson("/api/tenants/by-property/" + propertyId);
    if(r.status === 404){
      $("tenantBox").innerHTML = `
        <div class="muted">Aucun locataire lié à ce bien.</div>
        <div style="margin-top:10px">
          <a class="btn" href="/dashboard.html">Assigner un locataire</a>
        </div>`;
      $("btnTenant").style.display = "none";
      return;
    }
    if(!r.ok){
      $("tenantBox").innerHTML = `<div class="muted">Erreur chargement locataire</div>`;
      $("btnTenant").style.display = "none";
      return;
    }
    const t = r.data;
    $("tenantBox").innerHTML = `
      <div><b>${esc((t.firstName||"") + " " + (t.lastName||""))}</b></div>
      <div class="muted">${esc(t.email || "Email non renseigné")}</div>`;
    $("btnTenant").href = "/tenant.html?id=" + encodeURIComponent(t._id);
    $("btnTenant").style.display = "inline-flex";
  }

  async function loadDocs(){
    const r = await apiJson("/api/property-documents/" + propertyId);
    if(!r.ok){
      $("docsTbody").innerHTML = `<tr><td colspan="5" class="muted">Erreur chargement documents</td></tr>`;
      $("docCount").textContent = "—";
      return;
    }
    const docs = Array.isArray(r.data) ? r.data : [];
    $("docCount").textContent = docs.length + " doc(s)";

    if(docs.length===0){
      $("docsTbody").innerHTML = `<tr><td colspan="5" class="muted">Aucun document. Uploade ton premier fichier.</td></tr>`;
      return;
    }

    $("docsTbody").innerHTML = docs.map(d=>`
      <tr>
        <td>${fmtDate(d.createdAt)}</td>
        <td class="muted">${esc(d.type || "—")}</td>
        <td><b>${esc(d.originalName || d.filename || "document")}</b></td>
        <td class="muted">${fmtBytes(d.size)}</td>
        <td style="text-align:right;white-space:nowrap">
          <button class="btn" onclick="downloadDoc('${d._id}','${esc(d.originalName||"document")}')">Télécharger</button>
          <button class="btn red" onclick="deleteDoc('${d._id}')">Suppr.</button>
        </td>
      </tr>
    `).join("");
  }

  async function downloadBlob(url, filename){
    const r = await fetch(url, { headers: { "x-auth-token": tok } });
    if(!r.ok){ toast("Téléchargement impossible", false); return; }
    const blob = await r.blob();
    const u = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = u;
    a.download = filename || "document";
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(()=>URL.revokeObjectURL(u), 15000);
  }

  window.downloadDoc = async (id, name)=> downloadBlob("/api/property-documents/file/" + id, name);

  window.deleteDoc = async (id)=>{
    if(!confirm("Supprimer ce document ?")) return;
    const r = await apiJson("/api/property-documents/" + id, { method:"DELETE" });
    if(r.ok){
