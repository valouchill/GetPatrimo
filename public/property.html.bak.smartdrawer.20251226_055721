<script>
/* DrawerV2 JS */
(function(){
  const qs = (id)=>document.getElementById(id);

  function esc(s){
    return String(s??"").replace(/[&<>"]/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[m]));
  }
  function fmtDateSafe(x){
    try{ return (typeof fmtDate==="function") ? fmtDate(x) : new Date(x).toLocaleString(); }catch(_){ return ""; }
  }
  function toastSafe(msg, ok=true){
    try{ return (typeof toast==="function") ? toast(msg, ok) : console.log(msg); }catch(_){ console.log(msg); }
  }
  function token(){ return localStorage.getItem("token") || ""; }

  async function downloadPdfWithToken(url, filename){
    try{
      const t = token();
      if(!t){ toastSafe("Pas de token (déconnecté ?)", false); return; }

      const r = await fetch(url, { headers: { "x-auth-token": t } });
      if(!r.ok){
        const txt = await r.text().catch(()=> "");
        toastSafe("Export PDF impossible (" + r.status + ")", false);
        console.log(txt);
        return;
      }
      const blob = await r.blob();
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = filename || "doc2loc-compare.pdf";
      document.body.appendChild(a);
      a.click();
      setTimeout(()=>{ URL.revokeObjectURL(a.href); a.remove(); }, 800);
    }catch(e){
      toastSafe("Erreur export PDF", false);
      console.error(e);
    }
  }

  async function api(path, opt){
    opt = opt || {};
    opt.headers = opt.headers || {};
    opt.headers["x-auth-token"] = token();
    if(opt.body && typeof opt.body === "object" && !(opt.body instanceof FormData)){
      opt.headers["Content-Type"] = "application/json";
      opt.body = JSON.stringify(opt.body);
    }
    const r = await fetch(path, opt);
    const data = await r.json().catch(()=>null);
    return { ok:r.ok, status:r.status, data };
  }

  async function downloadBlob(path, filename){
    try{
      const r = await fetch(path, { headers: { "x-auth-token": token() } });
      if(!r.ok) return toastSafe("Téléchargement impossible", false);
      const blob = await r.blob();
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = filename || "document";
      document.body.appendChild(a);
      a.click();
      setTimeout(()=>{ URL.revokeObjectURL(a.href); a.remove(); }, 500);
    }catch(e){
      toastSafe("Erreur téléchargement", false);
    }
  }

  function openDrawer(){
    const ov = qs("candDrawerOverlay");
    const dr = qs("candDrawer");
    if(!ov || !dr) return;
    ov.style.display = "block";
    dr.classList.add("open");
    document.body.style.overflow = "hidden";
  }
  function closeDrawer(){
    const ov = qs("candDrawerOverlay");
    const dr = qs("candDrawer");
    if(!ov || !dr) return;
    ov.style.display = "none";
    dr.classList.remove("open");
    document.body.style.overflow = "";
  }

  async function renderDrawer(candId){
    openDrawer();
    qs("cdBody").innerHTML = `<div class="muted">Chargement…</div>`;

    const r = await api("/api/candidatures/" + encodeURIComponent(candId));
    if(!r.ok || !r.data){
      qs("cdBody").innerHTML = `<div class="muted">Détails indisponibles.</div>`;
      return;
    }
    const cand = r.data;

    
        // bind candId to drawer for global action buttons
        try{ const drEl = qs("candDrawer"); if(drEl) drEl.dataset.candId = String(candId); }catch(_){}
let checklist = null;
    const rc = await api("/api/candidatures/" + encodeURIComponent(candId) + "/checklist");
    if(rc.ok) checklist = rc.data;

    const name = ((cand.firstName||"") + " " + (cand.lastName||"")).trim() || "Candidat";
    const sc = cand.scoring || {};
    const grade = sc.grade || "—";
    const total = (typeof sc.total === "number") ? sc.total : null;
    const ratio = (typeof sc.ratio === "number" && sc.ratio>0) ? sc.ratio : null;
    const breakdown = Array.isArray(sc.breakdown) ? sc.breakdown : [];
    const flags = Array.isArray(sc.flags) ? sc.flags : [];

    qs("cdTitle").textContent = name;
    qs("cdSub").textContent = (cand.email||"") + (cand.createdAt ? (" • " + fmtDateSafe(cand.createdAt)) : "");

    const missing = (checklist && Array.isArray(checklist.missing)) ? checklist.missing : [];
    const docs = Array.isArray(cand.docs) ? cand.docs : [];

    qs("cdBody").innerHTML = `
      <div class="cdc">
        <div class="cdr">
          <div class="cdk">
            <div class="muted">Score</div>
            <b>${esc(grade)}${total!==null?` <span class="muted">(${total})</span>`:""}</b>
            ${ratio!==null?`<div class="muted" style="margin-top:4px">Ratio loyer/revenus: ${ratio.toFixed(2)}</div>`:""}
          </div>
          <div class="cdk">
            <div class="muted">Statut</div>
            <select id="cdStatus">
              <option value="NEW" ${cand.status==='NEW'?'selected':''}>Nouveau</option>
              <option value="REVIEWED" ${cand.status==='REVIEWED'?'selected':''}>Vu</option>
              <option value="ACCEPTED" ${cand.status==='ACCEPTED'?'selected':''}>Accepté</option>
              <option value="REJECTED" ${cand.status==='REJECTED'?'selected':''}>Refusé</option>
            </select>
            <div class="muted" style="margin-top:6px">${esc(cand.phone||"")}</div>
          </div>
        </div>
      </div>

      <div class="cdc">
        <b>Checklist documents</b>
        <div class="muted" style="margin-top:6px">${missing.length ? "Manquants :" : "OK (règles V1)"}</div>
        ${missing.length ? `<ul class="cdlist">${missing.map(x=>`<li>${esc(x)}</li>`).join("")}</ul>` : ""}
      </div>

      <div class="cdc">
        <b>Explications du score</b>
        ${breakdown.length ? `<ul class="cdlist">${breakdown.map(x=>`<li><b>${esc(x.label||x.key)}</b> : ${(x.points>=0?'+':'') + String(x.points||0)} <span class="muted">${esc(x.detail||"")}</span></li>`).join("")}</ul>` : `<div class="muted" style="margin-top:6px">—</div>`}
      </div>

      <div class="cdc">
        <b>Flags</b>
        <div style="margin-top:6px">${(flags.length?flags:["—"]).map(f=>`<span class="tag">${esc(f)}</span>`).join("")}</div>
      </div>
    `;

    // Bind status change
    const sel = qs("cdStatus");
    sel && sel.addEventListener("change", async ()=>{
      const up = await api("/api/candidatures/" + encodeURIComponent(candId) + "/status", { method:"PATCH", body:{ status: sel.value } });
      if(!up.ok) return toastSafe((up.data && up.data.msg) || "Statut impossible", false);
      toastSafe("Statut mis à jour ✅");
      try{ if(typeof loadCandidatures==="function") await loadCandidatures(); }catch(_){}
    });

    // Bind download all
    qs("cdDownloadAll").onclick = ()=>{
      if(!docs.length) return toastSafe("Aucun document", false);
      if(!confirm("Télécharger tous les documents ?")) return;
      docs.forEach((d,i)=>{
        setTimeout(()=>{
          const url = "/api/candidatures/" + encodeURIComponent(candId) + "/file/" + encodeURIComponent(d._id);
          downloadBlob(url, d.originalName || ("document-"+(i+1)));
        }, i*350);
      });
    };

    // Bind recompute
    qs("cdRecompute").onclick = async ()=>{
      const rr = await api("/api/candidatures/" + encodeURIComponent(candId) + "/recompute-score", { method:"POST" });
      if(!rr.ok) return toastSafe((rr.data && rr.data.msg) || "Recalcul impossible", false);
      toastSafe("Score recalculé ✅");
      try{ if(typeof loadCandidatures==="function") await loadCandidatures(); }catch(_){}
      renderDrawer(candId);
    };
  }

  // Close hooks
  qs("candDrawerOverlay")?.addEventListener("click", closeDrawer);
  qs("cdClose")?.addEventListener("click", closeDrawer);
  qs("cdClose2")?.addEventListener("click", closeDrawer);
  document.addEventListener("keydown", (e)=>{ if(e.key==="Escape") closeDrawer(); });

  // Event delegation: intercept clicks on Détails / Recalculer
  document.addEventListener("click", async (e)=>{
    const det = e.target.closest("[data-cdet]");
    const rec = e.target.closest("[data-crec]");
    if(det){
      e.preventDefault(); e.stopPropagation(); if(e.stopImmediatePropagation) e.stopImmediatePropagation();
      const candId = det.dataset.cand;
      if(candId) renderDrawer(candId);
      return;
    }
    if(rec){
      e.preventDefault(); e.stopPropagation(); if(e.stopImmediatePropagation) e.stopImmediatePropagation();
      const candId = rec.dataset.cand;
      if(!candId) return;
      const rr = await api("/api/candidatures/" + encodeURIComponent(candId) + "/recompute-score", { method:"POST" });
      if(!rr.ok) return toastSafe((rr.data && rr.data.msg) || "Recalcul impossible", false);
      toastSafe("Score recalculé ✅");
      try{ if(typeof loadCandidatures==="function") await loadCandidatures(); }catch(_){}
      return;
    }
  }, true);
})();
</script>
<script>
/* CandBoard V1 */
(function(){
  const qs = (sel)=>document.querySelector(sel);
  const qsa = (sel)=>Array.from(document.querySelectorAll(sel));
  const byId = (id)=>document.getElementById(id);

  function esc(s){
    return String(s??"").replace(/[&<>"]/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[m]));
  }
  function token(){ return localStorage.getItem("token") || ""; }

  async function api(path, opt){
    opt = opt || {};
    opt.headers = opt.headers || {};
    opt.headers["x-auth-token"] = token();
    if(opt.body && typeof opt.body === "object" && !(opt.body instanceof FormData)){
      opt.headers["Content-Type"] = "application/json";
      opt.body = JSON.stringify(opt.body);
    }
    const r = await fetch(path, opt);
    const data = await r.json().catch(()=>null);
    return { ok:r.ok, status:r.status, data };
  }

  function getPropertyId(){
    try{
      if(typeof propertyId !== "undefined" && propertyId) return propertyId;
    }catch(_){}
    return new URLSearchParams(location.search).get("id") || "";
  }

  function ensureFilterBar(){
    if(byId("candFilterBar")) return;

    const tbody = byId("candTbody");
    if(!tbody) return;

    // remonte au container table
    let container = tbody.closest("div");
    if(!container) container = tbody.parentElement;

    const bar = document.createElement("div");
    bar.id = "candFilterBar";
    bar.style.display = "flex";
    bar.style.gap = "10px";
    bar.style.flexWrap = "wrap";
    bar.style.alignItems = "center";
    bar.style.marginTop = "12px";

    bar.innerHTML = `
      <input id="candSearch" placeholder="Rechercher (nom/email)..." style="min-width:220px;flex:1;padding:10px 12px;border:1px solid var(--border);border-radius:12px">
      <select id="candSort" style="padding:10px 12px;border:1px solid var(--border);border-radius:12px">
        <option value="score_desc">Tri: Score ↓</option>
        <option value="score_asc">Tri: Score ↑</option>
        <option value="date_desc">Tri: Date ↓</option>
      </select>
      <label style="display:flex;gap:8px;align-items:center;color:var(--muted);font-size:12px">
        <input type="checkbox" id="onlyShortlisted"> Shortlist ⭐
      </label>
      <label style="display:flex;gap:8px;align-items:center;color:var(--muted);font-size:12px">
        <input type="checkbox" id="onlyMissing"> Docs manquants
      </label>
      <div style="display:flex;gap:6px;align-items:center;color:var(--muted);font-size:12px">
        Grade:
        ${["A","B","C","D","E"].map(g=>`<label style="display:flex;gap:6px;align-items:center"><input type="checkbox" class="gradeChk" value="${g}" checked> ${g}</label>`).join("")}
      </div>
    `;

    // inject juste au-dessus du tableau (container)
    container.parentElement.insertBefore(bar, container);
  }

  function missingCountFromFlags(sc){
    const flags = (sc && Array.isArray(sc.flags)) ? sc.flags : [];
    return flags.filter(f => String(f).startsWith("missing_")).length;
  }

  function fmtDateSafe(x){
    try{ return (typeof fmtDate==="function") ? fmtDate(x) : new Date(x).toLocaleString(); }catch(_){ return ""; }
  }

  function getFilters(){
    const grades = qsa(".gradeChk").filter(x=>x.checked).map(x=>x.value);
    return {
      q: (byId("candSearch")?.value || "").trim().toLowerCase(),
      sort: byId("candSort")?.value || "score_desc",
      onlyShortlisted: !!byId("onlyShortlisted")?.checked,
      onlyMissing: !!byId("onlyMissing")?.checked,
      grades
    };
  }

  function applyFilters(items){
    const f = getFilters();
    let out = items.slice();

    if(f.q){
      out = out.filter(c=>{
        const name = ((c.firstName||"") + " " + (c.lastName||"")).trim().toLowerCase();
        const email = String(c.email||"").toLowerCase();
        return name.includes(f.q) || email.includes(f.q);
      });
    }

    out = out.filter(c=>{
      const g = (c.scoring && c.scoring.grade) ? c.scoring.grade : "—";
      return f.grades.includes(g);
    });

    if(f.onlyShortlisted){
      out = out.filter(c=>!!c.shortlisted);
    }

    if(f.onlyMissing){
      out = out.filter(c=>missingCountFromFlags(c.scoring) > 0);
    }

    if(f.sort === "score_desc"){
      out.sort((a,b)=>(Number(b.scoring?.total||0) - Number(a.scoring?.total||0)));
    } else if(f.sort === "score_asc"){
      out.sort((a,b)=>(Number(a.scoring?.total||0) - Number(b.scoring?.total||0)));
    } else {
      out.sort((a,b)=>new Date(b.createdAt||0) - new Date(a.createdAt||0));
    }
    return out;
  }

  function shortName(s){
    s = String(s||"doc");
    if(s.length <= 18) return s;
    const dot = s.lastIndexOf(".");
    const ext = dot > 0 ? s.slice(dot) : "";
    return s.slice(0,14) + "…" + ext;
  }

  async function downloadBlob(url, filename){
    try{
      const r = await fetch(url, { headers: { "x-auth-token": token() } });
      if(!r.ok) return (typeof toast==="function" ? toast("Téléchargement impossible", false) : null);
      const blob = await r.blob();
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = filename || "document";
      document.body.appendChild(a);
      a.click();
      setTimeout(()=>{ URL.revokeObjectURL(a.href); a.remove(); }, 600);
    }catch(_){}
  }

  let __candCache = [];

  async function candLoad(){
    ensureFilterBar();
    const pid = getPropertyId();
    const tbody = byId("candTbody");
    if(!pid || !tbody) return;

    tbody.innerHTML = `<tr><td colspan="7" class="muted">Chargement…</td></tr>`;
    const r = await api("/api/properties/" + encodeURIComponent(pid) + "/candidatures");
    if(!r.ok){
      tbody.innerHTML = `<tr><td colspan="7" class="muted">Erreur candidatures</td></tr>`;
      return;
    }
    __candCache = Array.isArray(r.data) ? r.data : [];
    render();
  }

  function render(){
    const tbody = byId("candTbody");
    if(!tbody) return;

    const items = applyFilters(__candCache);
    if(!items.length){
      tbody.innerHTML = `<tr><td colspan="7" class="muted">Aucun résultat.</td></tr>`;
      return;
    }

    tbody.innerHTML = items.map(c=>{
      const name = ((c.firstName||"") + " " + (c.lastName||"")).trim() || "Candidat";
      const sc = c.scoring || {};
      const grade = sc.grade || "—";
      const total = (typeof sc.total==="number") ? sc.total : null;
      const miss = missingCountFromFlags(sc);

      const docs = Array.isArray(c.docs) ? c.docs : [];
      const docBtns = docs.slice(0,3).map(d=>(
        `<button class="btn" data-cdl="1" data-cand="${c._id}" data-doc="${d._id}" data-name="${esc(d.originalName||"document")}">${esc(shortName(d.originalName||"doc"))}</button>`
      )).join(" ");
      const more = docs.length > 3 ? `<span class="muted">+${docs.length-3}</span>` : "";

      const star = c.shortlisted ? "⭐" : "☆";

      return `
        <tr>
          <td class="muted">${fmtDateSafe(c.createdAt)}</td>
          <td><button class="btn" data-star="1" data-cand="${c._id}" title="Shortlist">${star}</button> <b>${esc(name)}</b></td>
          <td class="muted">${esc(c.email||"—")}</td>
          <td style="white-space:nowrap">${docBtns} ${more}</td>
          <td><b>${esc(grade)}</b>${total!==null?` <span class="muted">(${total})</span>`:""}${miss?` <span class="muted">• ${miss} manquant(s)</span>`:""}</td>
          <td>
            <select class="candStatus" data-cand="${c._id}">
              <option value="NEW" ${c.status==='NEW'?'selected':''}>Nouveau</option>
              <option value="REVIEWED" ${c.status==='REVIEWED'?'selected':''}>Vu</option>
              <option value="ACCEPTED" ${c.status==='ACCEPTED'?'selected':''}>Accepté</option>
              <option value="REJECTED" ${c.status==='REJECTED'?'selected':''}>Refusé</option>
            </select>
          </td>
          <td style="text-align:right;white-space:nowrap">
            <button class="btn" data-cdet="1" data-cand="${c._id}">Détails</button>
            <button class="btn" data-crec="1" data-cand="${c._id}">Recalculer</button>
            <button class="btn" data-call="all" data-cand="${c._id}">Tout</button>
          </td>
        </tr>
        <tr>
          <td colspan="7">
            <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
              <span class="muted" style="font-size:12px">Note interne :</span>
              <input class="candNote" data-cand="${c._id}" value="${esc(c.internalNote||"")}" placeholder="Ex: bon profil, attendre garant..." style="flex:1;min-width:240px;padding:10px 12px;border:1px solid var(--border);border-radius:12px">
              <button class="btn" data-save-note="1" data-cand="${c._id}">Enregistrer</button>
            </div>
          </td>
        </tr>
      `;
    }).join("");

    // bind doc download
    qsa("[data-cdl='1']").forEach(b=>{
      b.addEventListener("click", ()=>{
        const url = "/api/candidatures/" + encodeURIComponent(b.dataset.cand) + "/file/" + encodeURIComponent(b.dataset.doc);
        downloadBlob(url, b.dataset.name || "document");
      });
    });

    // bind status
    qsa(".candStatus").forEach(sel=>{
      sel.addEventListener("change", async ()=>{
        const r = await api("/api/candidatures/" + encodeURIComponent(sel.dataset.cand) + "/status", { method:"PATCH", body:{ status: sel.value } });
        if(!r.ok) return (typeof toast==="function" ? toast((r.data&&r.data.msg)||"Statut impossible", false) : null);
        if(typeof toast==="function") toast("Statut mis à jour ✅");
        // update cache
        const it = __candCache.find(x=>String(x._id)===String(sel.dataset.cand));
        if(it) it.status = sel.value;
      });
    });

    // bind download all
    qsa("[data-call='all']").forEach(btn=>{
      btn.addEventListener("click", ()=>{
        const candId = btn.dataset.cand;
        const cand = __candCache.find(x=>String(x._id)===String(candId));
        const docs = cand && Array.isArray(cand.docs) ? cand.docs : [];
        if(!docs.length){ if(typeof toast==="function") toast("Aucun document", false); return; }
        if(!confirm("Télécharger tous les documents ?")) return;
        docs.forEach((d,i)=>{
          setTimeout(()=>{
            const url = "/api/candidatures/" + encodeURIComponent(candId) + "/file/" + encodeURIComponent(d._id);
            downloadBlob(url, d.originalName || ("document-"+(i+1)));
          }, i*350);
        });
      });
    });

    // bind star shortlist
    qsa("[data-star='1']").forEach(btn=>{
      btn.addEventListener("click", async ()=>{
        const candId = btn.dataset.cand;
        const cand = __candCache.find(x=>String(x._id)===String(candId));
        const target = !(cand && cand.shortlisted);
        const r = await api("/api/candidatures/" + encodeURIComponent(candId) + "/shortlist", { method:"PATCH", body:{ shortlisted: target } });
        if(!r.ok) return (typeof toast==="function" ? toast((r.data&&r.data.msg)||"Shortlist impossible", false) : null);
        if(cand) cand.shortlisted = !!r.data.shortlisted;
        if(typeof toast==="function") toast(r.data.msg || "OK");
        render();
      });
    });

    // bind save note
    qsa("[data-save-note='1']").forEach(btn=>{
      btn.addEventListener("click", async ()=>{
        const candId = btn.dataset.cand;
        const inp = qs(".candNote[data-cand='"+candId+"']");
        const note = (inp?.value || "").trim();
        const r = await api("/api/candidatures/" + encodeURIComponent(candId) + "/note", { method:"PATCH", body:{ note } });
        if(!r.ok) return (typeof toast==="function" ? toast((r.data&&r.data.msg)||"Note impossible", false) : null);
        const cand = __candCache.find(x=>String(x._id)===String(candId));
        if(cand) cand.internalNote = note;
        if(typeof toast==="function") toast("Note enregistrée ✅");
      });
    });
  }

  function bindFilters(){
    ["candSearch","candSort","onlyShortlisted","onlyMissing"].forEach(id=>{
      byId(id)?.addEventListener("input", render);
      byId(id)?.addEventListener("change", render);
    });
    qsa(".gradeChk").forEach(chk=>chk.addEventListener("change", render));
  }

  // expose loadCandidatures so other features (drawer) can refresh
  window.loadCandidatures = candLoad;

  // init
  window.addEventListener("load", ()=>{
    setTimeout(()=>{
      ensureFilterBar();
      bindFilters();
      candLoad();
    }, 80);
  });
})();
</script>

