    // Ajoute une checkbox dans chaque ligne "candidat" (si CandBoard rend déjà le tableau)
    const tbody = document.getElementById("candTbody");
    if(!tbody) return;

    // Pour éviter de casser ton rendu, on se contente d’injecter une checkbox dans la cellule NOM si pas déjà présente.
    qsa("tr").forEach(tr=>{
      if(tr.dataset && tr.dataset.cmpRow === "1") return;
      const detBtn = tr.querySelector("[data-cdet]");
      if(!detBtn) return;
      const candId = detBtn.dataset.cand;
      // trouve une cellule contenant le nom : on prend la 2e td si possible
      const tds = tr.querySelectorAll("td");
      if(!tds || tds.length < 2) return;
      const nameCell = tds[1];
      if(nameCell.querySelector("[data-cmpchk='1']")) return;

      const chk = document.createElement("input");
      chk.type = "checkbox";
      chk.setAttribute("data-cmpchk","1");
      chk.dataset.cand = candId;
      chk.style.marginRight = "10px";

      chk.addEventListener("change", ()=>{
        const id = chk.dataset.cand;
        if(chk.checked){
          if(selected.length >= 2){
            chk.checked = false;
            toastSafe("Sélection limitée à 2 candidats", false);
            return;
          }
          selected.push(id);
        }else{
          selected = selected.filter(x=>x!==id);
        }
        updateBar();
      });

      nameCell.prepend(chk);
      tr.dataset.cmpRow = "1";
    });

    syncChecks();
    updateBar();
  }

  async function runCompare(){
    if(selected.length !== 2) return;
    const ids = selected.slice(0,2);
    lastCompareIds = ids.join(",");

    const r = await api("/api/candidatures/compare", { method:"POST", body:{ ids } });
    if(!r.ok){
      toastSafe((r.data && r.data.msg) || "Compare impossible", false);
      return;
    }

    const prop = r.data.property;
    const cands = r.data.candidatures || [];
    if(cands.length !== 2){
      toastSafe("Compare impossible (données)", false);
      return;
    }

    const pName = prop?.name || "Bien";
    byId("cmpSub").textContent = pName;

    function card(c){
      const sc = c.scoring || {};
      const flags = Array.isArray(sc.flags) ? sc.flags : [];
      const missing = flags.filter(f=>String(f).startsWith("missing_"));
      const bd = Array.isArray(sc.breakdown) ? sc.breakdown : [];

      const name = ((c.firstName||"") + " " + (c.lastName||"")).trim() || "Candidat";
      const total = (typeof sc.total==="number") ? sc.total : null;
      const ratio = (typeof sc.ratio==="number" && sc.ratio>0) ? sc.ratio : null;

      return `
        <div class="cmpCard">
          <div style="display:flex;justify-content:space-between;gap:10px;align-items:flex-start">
            <div>
              <div style="font-weight:900">${esc(name)}</div>
              <div class="muted" style="font-size:12px;margin-top:3px">${esc(c.email||"—")} • ${esc(c.phone||"—")}</div>
            </div>
            <div style="text-align:right">
              <div style="font-weight:900;font-size:16px">${esc(sc.grade||"—")}${total!==null?` <span class="muted">(${total})</span>`:""}</div>
              ${ratio!==null?`<div class="muted" style="font-size:12px">Ratio ${ratio.toFixed(2)}</div>`:""}
              <div class="muted" style="font-size:12px">Statut: ${esc(c.status||"—")}</div>
              <div class="muted" style="font-size:12px">Shortlist: ${c.shortlisted ? "⭐" : "—"}</div>
            </div>
          </div>

          <div class="cmpKpi">
            <span class="cmpTag">Docs manquants: <b>${missing.length}</b></span>
            <span class="cmpTag">Docs total: <b>${(c.docs||[]).length}</b></span>
          </div>

          <div style="margin-top:10px">
            <b>Note interne</b>
            <div class="muted" style="margin-top:6px;white-space:pre-wrap">${esc(c.internalNote||"—")}</div>
          </div>

          <div style="margin-top:10px">
            <b>Explications (top)</b>
            ${bd.length ? `<ul style="margin:6px 0 0;padding-left:18px">${bd.slice(0,6).map(x=>`<li><b>${esc(x.label||x.key)}</b> : ${(x.points>=0?'+':'')+String(x.points||0)} <span class="muted">${esc(x.detail||"")}</span></li>`).join("")}</ul>` : `<div class="muted" style="margin-top:6px">—</div>`}
          </div>

          <div style="margin-top:10px">
            <b>Flags</b>
            <div style="margin-top:6px">${(flags.length?flags:["—"]).map(f=>`<span class="cmpTag">${esc(f)}</span>`).join("")}</div>
          </div>
        </div>
      `;
    }

    byId("cmpBody").innerHTML = `<div class="cmpGrid">${card(cands[0])}${card(cands[1])}</div>`;
    openModal();
  }

  byId("cmpOverlay")?.addEventListener("click", closeModal);
  byId("cmpClose")?.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e)=>{ if(e.key==="Escape") closeModal(); });

  byId("cmpExport")?.addEventListener("click", ()=>{
    if(!lastCompareIds){
      toastSafe("Sélectionne 2 candidats", false);
      return;
    }
    const url = "/api/candidatures/compare.pdf?ids=" + encodeURIComponent(lastCompareIds);
    downloadPdfWithToken(url, "doc2loc-compare.pdf");
  });
// hook: après chaque rendu de candidatures, on injecte les checkboxes
  // On poll légèrement car CandBoard refait parfois le DOM.
  window.addEventListener("load", ()=>{
    ensureCompareBar();
    setInterval(()=>{
      attachCheckboxes();
    }, 800);
  });
})();
</script>
<script>
/* ExportPDF Fix V2 */
(function(){
  function getToken(){ return localStorage.getItem("token") || ""; }

  async function downloadPdfWithToken(url, filename){
    const t = getToken();
    if(!t){ alert("Pas de token (déconnecté ?)"); return; }

    const r = await fetch(url, { headers: { "x-auth-token": t } });
    if(!r.ok){
      const txt = await r.text().catch(()=> "");
      console.log("PDF error", r.status, txt);
      alert("Export PDF impossible (" + r.status + ")");
      return;
    }
    const blob = await r.blob();
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = filename || "doc2loc-compare.pdf";
    document.body.appendChild(a);
    a.click();
    setTimeout(()=>{ URL.revokeObjectURL(a.href); a.remove(); }, 800);
  }

  // Capture le clic même si le handler CompareUI a été cassé
  document.addEventListener("click", (e)=>{
    const btn = e.target && (e.target.id === "cmpExport" ? e.target : e.target.closest && e.target.closest("#cmpExport"));
    if(!btn) return;

    e.preventDefault();
    e.stopPropagation();

    // On récupère les 2 IDs sélectionnés depuis l'URL du PDF si CompareUI l'a construite,
    // sinon on lit un cache global "lastCompareIds" si présent.
    let ids = null;

    try{
      if(typeof lastCompareIds !== "undefined" && lastCompareIds) ids = String(lastCompareIds);
    }catch(_){}

    // Fallback : si CompareUI a mis un data-ids (optionnel) — sinon laisse null
    if(!ids && btn.dataset && btn.dataset.ids) ids = String(btn.dataset.ids);

    // Fallback: lis directement les 2 checkboxes cochées (CompareUI coche data-cmpchk="1")
    if(!ids){
      const chks = Array.from(document.querySelectorAll('[data-cmpchk="1"]:checked'));
      if(chks.length === 2){
        ids = chks.map(x => x.dataset.cand).join(',');
      }
    }

    if(!ids){
      alert("Je n'arrive pas à trouver les 2 candidats sélectionnés. Coche 2 candidats puis clique sur Comparer.");
      return;
    }

    const url = "/api/candidatures/compare.pdf?ids=" + encodeURIComponent(ids);
    downloadPdfWithToken(url, "doc2loc-compare.pdf");
  }, true);
})();
</script>
<script>
/* ExportPDF Fix V4 */
(function(){
  function getToken(){ return localStorage.getItem("token") || ""; }

  async function exportPdf(){
    console.log("[ExportPDF] click");
    const ids = Array.from(document.querySelectorAll('[data-cmpchk="1"]:checked')).map(x=>x.dataset.cand);
    console.log("[ExportPDF] selected ids:", ids);

    if(ids.length !== 2){
      alert("Coche 2 candidats (cases à gauche du nom) avant d’exporter.");
      return;
    }

    const t = getToken();
    if(!t){
      alert("Pas de token (déconnecté ?). Reconnecte-toi.");
      return;
    }

    const url = "/api/candidatures/compare.pdf?ids=" + encodeURIComponent(ids.join(","));
    console.log("[ExportPDF] GET", url);

    const r = await fetch(url, { headers: { "x-auth-token": t } });
    console.log("[ExportPDF] status:", r.status, "content-type:", r.headers.get("content-type"));

    if(!r.ok){
      const txt = await r.text().catch(()=> "");
      console.log("[ExportPDF] body:", txt);
      alert("Export PDF impossible (" + r.status + ")");
      return;
    }

    const blob = await r.blob();
    console.log("[ExportPDF] blob bytes:", blob.size);

    const blobUrl = URL.createObjectURL(blob);

    // tentative download
    const a = document.createElement("a");
    a.href = blobUrl;
    a.download = "doc2loc-compare.pdf";
    a.style.display = "none";
    document.body.appendChild(a);
    a.click();
    a.remove();

    // fallback: ouvre dans un nouvel onglet si le navigateur bloque le download
    setTimeout(()=>{
      try{ window.open(blobUrl, "_blank"); }catch(_){}
      setTimeout(()=>{ URL.revokeObjectURL(blobUrl); }, 5000);
    }, 600);
  }

  document.addEventListener("click", (e)=>{
    const btn = e.target && (e.target.id === "cmpExport" ? e.target : (e.target.closest ? e.target.closest("#cmpExport") : null));
    if(!btn) return;
    e.preventDefault();
    e.stopPropagation();
    exportPdf();
  }, true);
})();
</script>
<script>
/* Drawer Actions Fix V2 */
(function(){
  function getToken(){ return localStorage.getItem("token") || ""; }

  async function api(path, method, body){
    const t = getToken();
    const headers = { "x-auth-token": t };
    const opt = { method: method || "GET", headers };
    if(body){
      headers["Content-Type"] = "application/json";
      opt.body = JSON.stringify(body);
    }
    const r = await fetch(path, opt);
    const data = await r.json().catch(()=>null);
    return { ok:r.ok, status:r.status, data };
  }

  function msg(text, ok=true){
    try{ if(typeof toast==="function") return toast(text, ok); }catch(_){}
    alert(text);
  }

  function currentCandId(){
    const dr = document.getElementById("candDrawer");
    return (dr && dr.dataset && dr.dataset.candId) ? String(dr.dataset.candId) : "";
  }

  function clickClose(){
    const b = document.getElementById("cdClose") || document.getElementById("cdClose2");
    if(b) b.click();
  }

  document.addEventListener("click", async (e)=>{
    const btn = e.target && (e.target.closest ? e.target.closest("#cdRequestDocs,#cdReject,#cdAccept") : null);
    if(!btn) return;

    e.preventDefault();
    e.stopPropagation();

    const candId = currentCandId();
    if(!candId){
      msg("Impossible d’identifier la candidature. Ferme/ré-ouvre le drawer puis réessaie.", false);
      return;
    }

    if(btn.id === "cdRequestDocs"){
      if(!confirm("Envoyer un email pour demander les pièces manquantes ?")) return;
      const r = await api("/api/candidatures/" + encodeURIComponent(candId) + "/actions/request-docs", "POST");
      if(!r.ok) return msg((r.data && r.data.msg) || ("Action impossible ("+r.status+")"), false);
      msg(r.data.msg || "Email envoyé ✅");
      try{ if(typeof loadCandidatures==="function") await loadCandidatures(); }catch(_){}
      return;
    }

    if(btn.id === "cdReject"){
      const reason = prompt("Motif (optionnel) :") || "";
      if(!confirm("Refuser la candidature et envoyer un email ?")) return;
      const r = await api("/api/candidatures/" + encodeURIComponent(candId) + "/actions/reject", "POST", { reason });
      if(!r.ok) return msg((r.data && r.data.msg) || ("Refus impossible ("+r.status+")"), false);
      msg(r.data.msg || "Refus ✅");
      try{ if(typeof loadCandidatures==="function") await loadCandidatures(); }catch(_){}
      clickClose();
      return;
    }

    if(btn.id === "cdAccept"){
      if(!confirm("Accepter ce candidat (statut ACCEPTED + shortlist ⭐) ?")) return;
      const r = await api("/api/candidatures/" + encodeURIComponent(candId) + "/actions/accept", "POST");
      if(!r.ok) return msg((r.data && r.data.msg) || ("Acceptation impossible ("+r.status+")"), false);
      msg(r.data.msg || "Accepté ✅");
      try{ if(typeof loadCandidatures==="function") await loadCandidatures(); }catch(_){}
      clickClose();
      return;
    }
  }, true);
})();
</script>
