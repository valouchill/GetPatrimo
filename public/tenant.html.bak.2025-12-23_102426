<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Doc2Loc — Fiche locataire</title>
  <style>
    :root{
      --bg:#0b1220; --card:#101a2f; --muted:#94a3b8; --text:#e5e7eb;
      --border:rgba(148,163,184,.18); --shadow:0 18px 50px rgba(0,0,0,.35);
      --blue:#4F46E5; --green:#22c55e; --red:#ef4444;
    }
    *{box-sizing:border-box}
    body{margin:0;background:radial-gradient(900px 600px at 20% -10%,rgba(79,70,229,.35),transparent 55%),
                    radial-gradient(900px 700px at 120% 10%,rgba(34,197,94,.18),transparent 55%),var(--bg);
         color:var(--text);font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial}
    a{color:inherit}
    .wrap{max-width:1100px;margin:28px auto;padding:0 16px}
    .top{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px}
    .title{display:flex;align-items:center;gap:12px}
    h1{margin:0;font-size:20px;letter-spacing:.2px}
    .pill{font-size:12px;padding:6px 10px;border:1px solid var(--border);border-radius:999px;color:var(--muted)}
    .grid{display:grid;grid-template-columns:1.1fr .9fr;gap:14px}
    @media(max-width:900px){.grid{grid-template-columns:1fr}}
    .card{background:linear-gradient(180deg,rgba(16,26,47,.92),rgba(16,26,47,.80));
          border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow);padding:16px}
    .head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:10px}
    h2{margin:0;font-size:15px;color:#fff}
    .muted{color:var(--muted);font-size:13px}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    @media(max-width:600px){.row{grid-template-columns:1fr}}
    label{display:block;font-size:12px;color:var(--muted);margin:0 0 6px 0}
    input,select{width:100%;padding:10px 12px;border-radius:12px;border:1px solid var(--border);
                 background:#0b1326;color:var(--text);outline:none}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 12px;border-radius:12px;
         border:1px solid var(--border);background:#0b1326;color:var(--text);cursor:pointer;text-decoration:none}
    .btn.primary{background:var(--blue);border-color:var(--blue)}
    .btn.green{background:var(--green);border-color:var(--green);color:#06210f}
    .btn.red{background:transparent;border-color:rgba(239,68,68,.45);color:#fecaca}
    .btn:disabled{opacity:.45;cursor:not-allowed}
    .actions{display:flex;flex-wrap:wrap;gap:10px}
    .hr{height:1px;background:var(--border);margin:14px 0}
    .kv{display:flex;flex-direction:column;gap:3px}
    .kv b{font-size:14px}
    table{width:100%;border-collapse:collapse}
    th,td{padding:10px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:top}
    th{color:var(--muted);font-weight:600;text-align:left}
    .toast{position:fixed;right:18px;bottom:18px;background:#111827;border:1px solid var(--border);
           padding:10px 12px;border-radius:12px;display:none;max-width:320px}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <div class="title">
        <h1>Fiche locataire</h1>
        <span id="pillStatus" class="pill">Chargement…</span>
      </div>
      <div class="actions">
        <a class="btn" href="/dashboard.html">← Dashboard</a>
        <a class="btn" id="btnGoProperty" href="#" style="display:none">Voir le bien</a>
      </div>
    </div>

    <div class="grid">
      <!-- LEFT -->
      <div class="card">
        <div class="head">
          <h2>Identité & rattachement</h2>
          <div class="actions">
            <button class="btn green" id="btnEmail" disabled>Envoyer quittance</button>
            <button class="btn" id="btnPdf" disabled>Ouvrir PDF</button>
          </div>
        </div>

        <div class="row">
          <div>
            <label>Prénom</label>
            <input id="edit_firstName" placeholder="Ex: Sarah">
          </div>
          <div>
            <label>Nom</label>
            <input id="edit_lastName" placeholder="Ex: Martin">
          </div>
        </div>

        <div class="row" style="margin-top:10px">
          <div>
            <label>Email</label>
            <input id="edit_email" placeholder="sarah@email.com">
          </div>
          <div>
            <label>Bien associé</label>
            <select id="edit_property"></select>
          </div>
        </div>

        <div class="actions" style="margin-top:12px">
          <button class="btn primary" id="btnSave">Enregistrer</button>
          <button class="btn red" id="btnDeleteTenant">Supprimer</button>
        </div>

        <div class="hr"></div>

        <div class="kv">
          <div class="muted">Résumé</div>
          <b id="t_name">—</b>
          <div class="muted" id="t_email">—</div>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="card">
        <div class="head">
          <h2>Bien & dossier locataire</h2>
          <div class="muted" id="docCount">—</div>
        </div>

        <div class="kv" style="margin-bottom:10px">
          <div class="muted">Bien</div>
          <b id="p_name">—</b>
          <div class="muted" id="p_addr">—</div>
          <div class="muted" id="p_amounts">—</div>
        </div>

        <div class="hr"></div>

        <div class="muted" style="margin-bottom:8px">
          Ici tu peux déposer les pièces du dossier (CNI, fiches de paie, avis d’imposition…).
          Stockage lié au bien (type: <b>dossier_locataire</b>).
        </div>

        <div class="actions" style="margin:10px 0">
          <input id="file" type="file" />
          <button class="btn primary" id="btnUpload" disabled>Uploader</button>
        </div>

        <div style="overflow:auto;border:1px solid var(--border);border-radius:12px">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Fichier</th>
                <th>Taille</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="docsTbody">
              <tr><td colspan="4" class="muted">Sélectionne un bien pour gérer le dossier.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

<script>
  const qs = new URLSearchParams(location.search);
  const id = qs.get('id');
  const tok = localStorage.getItem('token');
  if(!tok) location.href='/login.html';

  const $ = (x)=>document.getElementById(x);
  const toast = (msg, ok=true)=>{
    const t=$('toast');
    t.textContent = msg;
    t.style.background = ok ? '#111827' : '#7f1d1d';
    t.style.display='block';
    setTimeout(()=>t.style.display='none', 2200);
  };
  const setStatus = (txt)=> $('pillStatus').textContent = txt;

  async function api(url, opts={}){
    const r = await fetch(url, {
      ...opts,
      headers: { 'x-auth-token': tok, ...(opts.headers||{}) }
    });
    const data = await r.json().catch(()=>null);
    if(r.status===401 || r.status===403){
      localStorage.clear();
      location.href='/login.html';
      return { ok:false, status:r.status, data };
    }
    return { ok:r.ok, status:r.status, data };
  }

  function fmtDate(d){
    try { return new Date(d).toLocaleDateString('fr-FR'); } catch(e){ return '—'; }
  }
  function fmtBytes(n){
    n = Number(n||0);
    if(n<1024) return n+' B';
    if(n<1024*1024) return (n/1024).toFixed(1)+' KB';
    return (n/1024/1024).toFixed(1)+' MB';
  }
  function esc(s){ return String(s||'').replace(/[&<>"']/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m])); }

  let tenant = null;
  let props = [];

  function renderPropertyInfo(propId){
    const p = props.find(x=>String(x._id)===String(propId));
    if(!p){
      $('p_name').textContent = "—";
      $('p_addr').textContent = "Aucun bien lié";
      $('p_amounts').textContent = "—";
      $('btnGoProperty').style.display = "none";
      $('btnPdf').disabled = true;
      $('btnEmail').disabled = true;
      $('btnUpload').disabled = true;
      $('docCount').textContent = "—";
      $('docsTbody').innerHTML = `<tr><td colspan="4" class="muted">Sélectionne un bien pour gérer le dossier.</td></tr>`;
      return;
    }

    $('p_name').textContent = p.name || '—';
    $('p_addr').textContent = (p.address || [p.addressLine, p.zipCode, p.city].filter(Boolean).join(', ')) || '—';
    const rent = Number(p.rentAmount||0), charges = Number(p.chargesAmount||0);
    $('p_amounts').textContent = `Loyer: ${rent.toFixed(2)}€ • Charges: ${charges.toFixed(2)}€ • Total: ${(rent+charges).toFixed(2)}€`;

    $('btnGoProperty').href = '/property.html?id=' + encodeURIComponent(p._id);
    $('btnGoProperty').style.display = "inline-flex";

    $('btnPdf').disabled = false;
    $('btnEmail').disabled = false;
    $('btnUpload').disabled = false;

    loadDocs(p._id);
  }

  async function loadDocs(propertyId){
    const r = await api('/api/property-documents/' + propertyId);
    if(!r.ok){
      $('docsTbody').innerHTML = `<tr><td colspan="4" class="muted">Erreur chargement documents</td></tr>`;
      $('docCount').textContent = "—";
      return;
    }
    const docs = (Array.isArray(r.data) ? r.data : []).filter(d=>d && d.type==='dossier_locataire');
    $('docCount').textContent = docs.length + " doc(s)";
    if(docs.length===0){
      $('docsTbody').innerHTML = `<tr><td colspan="4" class="muted">Aucun document dossier. Uploade une pièce (CNI, paie…).</td></tr>`;
      return;
    }

    $('docsTbody').innerHTML = docs.map(d=>`
      <tr>
        <td>${fmtDate(d.createdAt)}</td>
        <td><b>${esc(d.originalName || d.filename || '')}</b></td>
        <td class="muted">${fmtBytes(d.size)}</td>
        <td style="text-align:right;white-space:nowrap">
          <button class="btn" onclick="downloadDoc('${d._id}')">Télécharger</button>
          <button class="btn red" onclick="deleteDoc('${d._id}')">Suppr.</button>
        </td>
      </tr>
    `).join('');
  }

  async function downloadBlob(url, filename){
    const r = await fetch(url, { headers: { 'x-auth-token': tok } });
    if(!r.ok){ toast("Téléchargement impossible", false); return; }
    const blob = await r.blob();
    const u = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = u;
    a.download = filename || 'document';
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(()=>URL.revokeObjectURL(u), 15000);
  }

  window.downloadDoc = async (docId)=>{
    await downloadBlob('/api/property-documents/file/' + docId, 'dossier-locataire');
  };

  window.deleteDoc = async (docId)=>{
    if(!confirm("Supprimer ce document ?")) return;
    const r = await api('/api/property-documents/' + docId, { method:'DELETE' });
    if(r.ok){ toast("Document supprimé"); renderPropertyInfo($('edit_property').value); }
    else toast((r.data && r.data.msg) || "Erreur suppression", false);
  };

  $('btnUpload').addEventListener('click', async ()=>{
    const propertyId = $('edit_property').value;
    if(!propertyId){ toast("Sélectionne un bien", false); return; }
    const f = $('file').files[0];
    if(!f){ toast("Choisis un fichier", false); return; }

    const fd = new FormData();
    fd.append('file', f);
    fd.append('type', 'dossier_locataire');

    const r = await fetch('/api/property-documents/upload/' + propertyId, {
      method:'POST',
      headers: { 'x-auth-token': tok },
      body: fd
    });

    const j = await r.json().catch(()=>({}));
    if(r.ok){ toast("Upload OK"); $('file').value=''; loadDocs(propertyId); }
    else toast(j.msg || "Upload impossible", false);
  });

  async function openPdf(propertyId){
    const r = await fetch('/api/documents/quittance/' + propertyId, { headers:{'x-auth-token': tok} });
    if(!r.ok){ toast("PDF indisponible (vérifie le bien + locataire)", false); return; }
    const blob = await r.blob();
    const u = URL.createObjectURL(blob);
    window.open(u, '_blank');
    setTimeout(()=>URL.revokeObjectURL(u), 60000);
  }

  $('btnPdf').addEventListener('click', async ()=>{
    const propertyId = $('edit_property').value;
    if(!propertyId) return;
    await openPdf(propertyId);
  });

  $('btnEmail').addEventListener('click', async ()=>{
    const propertyId = $('edit_property').value;
    if(!propertyId) return;
    const r = await api('/api/documents/email/' + propertyId, { method:'POST' });
    if(r.ok) toast("Email envoyé ✅");
    else toast((r.data && r.data.msg) || "Erreur email", false);
  });

  $('btnSave').addEventListener('click', async ()=>{
    if(!tenant) return;

    const body = {
      firstName: $('edit_firstName').value.trim(),
      lastName: $('edit_lastName').value.trim(),
      email: $('edit_email').value.trim(),
      property: $('edit_property').value || null
    };

    if(body.email && !body.email.includes('@')){
      toast("Email invalide", false); return;
    }
    if(!body.firstName || !body.lastName){
      toast("Prénom/Nom requis", false); return;
    }

    const r = await api('/api/tenants/' + tenant._id, {
      method:'PUT',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(body)
    });

    if(r.ok){
      toast("Locataire mis à jour ✅");
      await load(); // reload propre
    } else {
      toast((r.data && r.data.msg) || "Erreur sauvegarde", false);
    }
  });

  $('btnDeleteTenant').addEventListener('click', async ()=>{
    if(!tenant) return;
    if(!confirm("Supprimer ce locataire ?")) return;
    const r = await api('/api/tenants/' + tenant._id, { method:'DELETE' });
    if(r.ok){ toast("Supprimé"); location.href="/dashboard.html"; }
    else toast((r.data && r.data.msg) || "Erreur suppression", false);
  });

  async function load(){
    if(!id){ toast("ID locataire manquant", false); location.href="/dashboard.html"; return; }

    setStatus("Chargement…");

    // tenant
    const rT = await api('/api/tenants/' + id);
    if(!rT.ok){
      toast((rT.data && rT.data.msg) || "Locataire introuvable", false);
      setStatus("Erreur");
      return;
    }
    tenant = rT.data;

    // properties for dropdown
    const rP = await api('/api/properties');
    props = Array.isArray(rP.data) ? rP.data : [];

    // fill UI
    $('t_name').textContent = (tenant.firstName||"") + " " + (tenant.lastName||"");
    $('t_email').textContent = tenant.email || "—";

    $('edit_firstName').value = tenant.firstName || '';
    $('edit_lastName').value = tenant.lastName || '';
    $('edit_email').value = tenant.email || '';

    // build select
    const cur = tenant.property && (tenant.property._id || tenant.property);
    $('edit_property').innerHTML =
      `<option value="">— Aucun bien —</option>` +
      props.map(p=>`<option value="${p._id}">${esc(p.name || 'Bien')}</option>`).join('');

    if(cur) $('edit_property').value = String(cur);

    $('edit_property').addEventListener('change', (e)=>{
      renderPropertyInfo(e.target.value);
    });

    renderPropertyInfo($('edit_property').value);

    setStatus("OK ✅");
  }

  load();
</script>
</body>
</html>
