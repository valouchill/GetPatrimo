<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Doc2Loc — Fiche locataire</title>
  
    <link rel='stylesheet' href='/ui.css?v=10'>
<style>
    :root{
      --bg:#0b1220; --card:#101a2f; --muted:#94a3b8; --text:#e5e7eb;
      --border:rgba(148,163,184,.18); --shadow:0 18px 50px rgba(0,0,0,.35);
      --blue:#4F46E5; --green:#22c55e; --red:#ef4444;
    }
    *{box-sizing:border-box}
    body{margin:0;background:radial-gradient(900px 600px at 20% -10%,rgba(79,70,229,.35),transparent 55%),
                    radial-gradient(900px 700px at 120% 10%,rgba(34,197,94,.18),transparent 55%),var(--bg);
         color:var(--text);font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial}
    .wrap{max-width:1100px;margin:28px auto;padding:0 16px}
    .top{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px}
    h1{margin:0;font-size:20px}
    .pill{font-size:12px;padding:6px 10px;border:1px solid var(--border);border-radius:999px;color:var(--muted)}
    .grid{display:grid;grid-template-columns:1.1fr .9fr;gap:14px}
    @media(max-width:900px){.grid{grid-template-columns:1fr}}
    .card{background:linear-gradient(180deg,rgba(16,26,47,.92),rgba(16,26,47,.80));
          border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow);padding:16px}
    .head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:10px}
    h2{margin:0;font-size:15px}
    .muted{color:var(--muted);font-size:13px}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    @media(max-width:600px){.row{grid-template-columns:1fr}}
    label{display:block;font-size:12px;color:var(--muted);margin:0 0 6px 0}
    input,select{width:100%;padding:10px 12px;border-radius:12px;border:1px solid var(--border);
                 background:#0b1326;color:var(--text);outline:none}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 12px;border-radius:12px;
         border:1px solid var(--border);background:#0b1326;color:var(--text);cursor:pointer;text-decoration:none}
    .btn.primary{background:var(--blue);border-color:var(--blue)}
    .btn.green{background:var(--green);border-color:var(--green);color:#06210f}
    .btn.red{background:transparent;border-color:rgba(239,68,68,.45);color:#fecaca}
    .btn:disabled{opacity:.45;cursor:not-allowed}
    .actions{display:flex;flex-wrap:wrap;gap:10px}
    .hr{height:1px;background:var(--border);margin:14px 0}
    table{width:100%;border-collapse:collapse}
    th,td{padding:10px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:top}
    th{color:var(--muted);font-weight:600;text-align:left}
    .toast{position:fixed;right:18px;bottom:18px;background:#111827;border:1px solid var(--border);
           padding:10px 12px;border-radius:12px;display:none;max-width:360px}
    .small{font-size:12px}
  </style>

  <link rel="stylesheet" href="/elite.css"/>
    <script defer src='/ui.js?v=10'></script>
    <link rel='stylesheet' href='/harmonize.css?v=6'>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <div style="display:flex;align-items:center;gap:10px">
        <h1>Fiche locataire</h1>
        <span id="status" class="pill">Chargement…</span>
      </div>
      <div class="actions">
        <a class="btn" href="/dashboard.html">← Dashboard</a>
        <a class="btn" id="btnProperty" href="#" style="display:none">Fiche bien</a>
        <button class="btn red" id="btnDelete">Supprimer</button>
      </div>
    </div>

    <div class="grid">
      <!-- LEFT -->
      <div class="card">
        <div class="head">
          <h2>Infos locataire</h2>
          <div class="actions">
            <button class="btn primary" id="btnSave">Enregistrer</button>
          </div>
        </div>

        <div class="row">
          <div>
            <label>Prénom</label>
            <input id="firstName" placeholder="Prénom">
          </div>
          <div>
            <label>Nom</label>
            <input id="lastName" placeholder="Nom">
          </div>
        </div>

        <div class="row" style="margin-top:10px">
          <div>
            <label>Email</label>
            <input id="email" type="email" placeholder="email@exemple.com">
          </div>
          <div>
            <label>Bien associé</label>
            <select id="propertySelect">
              <option value="">— Aucun —</option>
            </select>
            <div class="muted small" style="margin-top:6px">1 bien ↔ 1 locataire (bloqué automatiquement).</div>
          </div>
        </div>

        <div class="hr"></div>

        <div class="head" style="margin-bottom:6px">
          <h2>Dossier locataire</h2>
          <div class="muted" id="docCount">—</div>
        </div>

        <div class="muted" style="margin-bottom:10px">
          Ici on stocke les pièces du locataire (CNI, fiches de paie, avis d’imposition…).  
          Techniquement, ce sont des documents “du bien” de type <b>dossier_locataire</b>.
        </div>

        <div class="row">
          <div>
            <label>Fichier</label>
            <input id="file" type="file">
          </div>
          <div>
            <label>&nbsp;</label>
            <button class="btn green" id="btnUpload" disabled>Uploader</button>
          </div>
        </div>

        <div style="overflow:auto;border:1px solid var(--border);border-radius:12px;margin-top:12px">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Fichier</th>
                <th>Taille</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="docsTbody">
              <tr><td colspan="4" class="muted">Chargement…</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="card">
        <div class="head">
          <h2>Raccourcis</h2>
          <div class="muted">Actions rapides</div>
        </div>

        <div class="actions">
          <button class="btn" id="btnEmail" disabled>Envoyer quittance</button>
          <button class="btn" id="btnPdf" disabled>PDF quittance</button>
        </div>
        <div class="hr"></div>
        <div class="row">
          <div>
            <label>Relance</label>
            <select id="reminderTpl">
              <option value="rent_reminder">Rappel quittance / loyer</option>
              <option value="missing_docs">Documents manquants</option>
              <option value="late_payment">Paiement en attente</option>
            </select>
          </div>
          <div>
            <label>&nbsp;</label>
            <button class="btn green" id="btnReminder" disabled>Relancer</button>
          </div>
        </div>

        <div class="hr"></div>
        <div class="head"><h2>Historique</h2><div class="muted" id="evCount">—</div></div>
        <div style="overflow:auto;border:1px solid var(--border);border-radius:12px;margin-top:12px">
          <table>
            <thead><tr><th>Date</th><th>Événement</th></tr></thead>
            <tbody id="eventsTbody"><tr><td colspan="2" class="muted">Chargement…</td></tr></tbody>
          </table>
        </div>

        <div class="hr"></div>

        <div class="muted">
          Ces actions utilisent le bien associé. Si aucun bien n’est lié, elles sont désactivées.
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

<script>
  const tok = localStorage.getItem("token");
  if(!tok) location.href="/login.html";

  const qs = new URLSearchParams(location.search);
  const tenantId = qs.get("id");
  if(!tenantId) location.href="/dashboard.html";

  const $ = (id)=>document.getElementById(id);

  function toast(msg, ok=true){
    const t = $("toast");
    t.textContent = msg;
    t.style.background = ok ? "#111827" : "#7f1d1d";
    t.style.display = "block";
    setTimeout(()=>t.style.display="none", 2400);
  }

  async function apiJson(url, opts={}){
    const r = await fetch(url, {
      ...opts,
      headers: { "x-auth-token": tok, ...(opts.headers||{}) }
    });
    const ct = (r.headers.get("content-type")||"").toLowerCase();
    const data = ct.includes("application/json") ? await r.json().catch(()=>null) : await r.text().catch(()=>null);
    if(r.status===401 || r.status===403){
      localStorage.clear();
      location.href="/login.html";
      return { ok:false, status:r.status, data };
    }
    return { ok:r.ok, status:r.status, data };
  }

  function fmtDate(d){ try{ return new Date(d).toLocaleDateString("fr-FR"); }catch(e){ return "—"; } }
  function fmtBytes(n){
    n = Number(n||0);
    if(n < 1024) return n+" B";
    if(n < 1024*1024) return (n/1024).toFixed(1)+" KB";
    return (n/1024/1024).toFixed(1)+" MB";
  }
  function esc(s){ return String(s||"").replace(/[&<>"']/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m])); }

  let tenant = null;
  let properties = [];

  function setStatus(txt){ $("status").textContent = txt; }

  async function loadProperties(){
    const r = await apiJson("/api/properties");
    if(!r.ok) return;
    properties = Array.isArray(r.data) ? r.data : [];
    const sel = $("propertySelect");
    sel.innerHTML = `<option value="">— Aucun —</option>` + properties.map(p=>(
      `<option value="${p._id}">${esc(p.name)} • ${esc((p.addressLine||p.address||"").slice(0,45))}</option>`
    )).join("");
  }

  async function loadTenant(){
    setStatus("Chargement…");
    const r = await apiJson("/api/tenants/" + tenantId);
    if(!r.ok){
      toast((r.data && r.data.msg) || "Locataire introuvable", false);
      setStatus("Erreur");
      return;
    }
    tenant = r.data;

    $("firstName").value = tenant.firstName || "";
    $("lastName").value  = tenant.lastName || "";
    $("email").value     = tenant.email || "";

    const propId = tenant.property && (tenant.property._id || tenant.property);
    $("propertySelect").value = propId ? String(propId) : "";

    refreshPropertyActions();
    await loadTenantDocs();
      await loadEvents();

    setStatus("OK ✅");
  }

  function refreshPropertyActions(){
    const propId = $("propertySelect").value || "";
    const hasProp = !!propId;

    $("btnUpload").disabled = !hasProp;
    $("btnEmail").disabled = !hasProp;
    $("btnPdf").disabled = !hasProp;
    $("btnReminder").disabled = !hasProp;

    const btnP = $("btnProperty");
    if(hasProp){
      btnP.href = "/property.html?id=" + encodeURIComponent(propId);
      btnP.style.display = "inline-flex";
    }else{
      btnP.style.display = "none";
    }
  }

  async function loadTenantDocs(){
    const propId = $("propertySelect").value || "";
    if(!propId){
      $("docsTbody").innerHTML = `<tr><td colspan="4" class="muted">Associe d’abord un bien pour gérer le dossier locataire.</td></tr>`;
      $("docCount").textContent = "—";
      return;
    }

    const r = await apiJson("/api/property-documents/" + propId);
    if(!r.ok){
      $("docsTbody").innerHTML = `<tr><td colspan="4" class="muted">Erreur chargement documents</td></tr>`;
      $("docCount").textContent = "—";
      return;
    }

    const docs = (Array.isArray(r.data)?r.data:[]).filter(d => d.type === "dossier_locataire");
    $("docCount").textContent = docs.length + " doc(s)";

    if(docs.length===0){
      $("docsTbody").innerHTML = `<tr><td colspan="4" class="muted">Aucun document. Uploade une première pièce.</td></tr>`;
      return;
    }

    $("docsTbody").innerHTML = docs.map(d=>`
      <tr>
        <td>${fmtDate(d.createdAt)}</td>
        <td><b>${esc(d.originalName || d.filename || "document")}</b></td>
        <td class="muted">${fmtBytes(d.size)}</td>
        <td style="text-align:right;white-space:nowrap">
          <button class="btn" onclick="downloadDoc('${d._id}','${esc(d.originalName||"document")}')">Télécharger</button>
          <button class="btn red" onclick="deleteDoc('${d._id}')">Suppr.</button>
        </td>
      </tr>
    `).join("");
  }

  async function downloadBlob(url, filename){
    const r = await fetch(url, { headers: { "x-auth-token": tok } });
    if(!r.ok){ toast("Téléchargement impossible", false); return; }
    const blob = await r.blob();
    const u = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = u; a.download = filename || "document";
    document.body.appendChild(a);
    a.click(); a.remove();
    setTimeout(()=>URL.revokeObjectURL(u), 15000);
  }

  window.downloadDoc = async (id, name)=>{
    await downloadBlob("/api/property-documents/file/" + id, name);
  };

  window.deleteDoc = async (id)=>{
    if(!confirm("Supprimer ce document ?")) return;
    const r = await apiJson("/api/property-documents/" + id, { method:"DELETE" });
    if(r.ok){ toast("Document supprimé ✅"); loadTenantDocs(); }
    else toast((r.data && r.data.msg) || "Erreur suppression", false);
  };

  $("propertySelect").addEventListener("change", ()=>{
    refreshPropertyActions();
    loadTenantDocs();
  });

  $("btnUpload").addEventListener("click", async ()=>{
    const propId = $("propertySelect").value || "";
    if(!propId){ toast("Associe un bien", false); return; }

    const f = $("file").files[0];
    if(!f){ toast("Choisis un fichier", false); return; }

    const btn = $("btnUpload");
    btn.disabled = true;
    try{
      const fd = new FormData();
      fd.append("file", f);
      fd.append("type", "dossier_locataire");

      const r = await fetch("/api/property-documents/upload/" + propId, {
        method:"POST",
        headers:{ "x-auth-token": tok },
        body: fd
      });
      const j = await r.json().catch(()=>({}));
      if(!r.ok){ toast(j.msg || "Upload impossible", false); return; }

      toast("Upload OK ✅");
      $("file").value = "";
      await loadTenantDocs();
      await loadEvents();
    } finally {
      btn.disabled = false;
    }
  });

  $("btnSave").addEventListener("click", async ()=>{
    const btn = $("btnSave");
    btn.disabled = true;
    try{
      const payload = {
        firstName: $("firstName").value.trim(),
        lastName: $("lastName").value.trim(),
        email: $("email").value.trim(),
        property: $("propertySelect").value || undefined
      };
      const r = await apiJson("/api/tenants/" + tenantId, {
        method:"PUT",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify(payload)
      });
      if(!r.ok){ toast((r.data && r.data.msg) || "Sauvegarde impossible", false); return; }
      tenant = r.data;
      toast("Locataire mis à jour ✅");
      refreshPropertyActions();
      await loadTenantDocs();
      await loadEvents();
    } finally {
      btn.disabled = false;
    }
  });

  $("btnDelete").addEventListener("click", async ()=>{
    if(!confirm("Supprimer définitivement ce locataire ?")) return;
    const r = await apiJson("/api/tenants/" + tenantId, { method:"DELETE" });
    if(!r.ok){ toast((r.data && r.data.msg) || "Suppression impossible", false); return; }
    toast("Supprimé ✅");
    location.href="/dashboard.html";
  });

  $("btnPdf").addEventListener("click", async ()=>{
    const propId = $("propertySelect").value || "";
    if(!propId) return;

    const r = await fetch("/api/documents/quittance/" + propId, { headers:{ "x-auth-token": tok } });
    if(!r.ok){
      const j = await r.json().catch(()=>({}));
      toast(j.msg || "PDF impossible", false);
      return;
    }
    const blob = await r.blob();
    const u = URL.createObjectURL(blob);
    window.open(u, "_blank");
    setTimeout(()=>URL.revokeObjectURL(u), 60000);
  });

  $("btnEmail").addEventListener("click", async ()=>{
    const propId = $("propertySelect").value || "";
    if(!propId) return;

    const r = await apiJson("/api/documents/email/" + propId, { method:"POST" });
    if(r.ok) toast((r.data && r.data.msg) || "Email envoyé ✅");
    else toast((r.data && r.data.msg) || "Email impossible", false);
  });

  
  function eventLabel(e){
    const t = e && e.type;
    if(t==='reminder_sent'){
      const tpl = e && e.meta && e.meta.template;
      const map = { rent_reminder:'Rappel quittance / loyer', missing_docs:'Documents manquants', late_payment:'Paiement en attente' };
      return 'Relance envoyée' + (tpl ? (' — ' + (map[tpl] || tpl)) : '');
    }
    if(t==='pdf_quittance_generated') return 'PDF quittance généré';
    if(t==='email_quittance_sent') return 'Quittance envoyée par email';
    if(t==='document_uploaded') return 'Document uploadé';
    if(t==='document_deleted') return 'Document supprimé';
    return t || '—';
  }

  async function loadEvents(){
    const r = await apiJson("/api/events/tenant/" + tenantId + "?limit=15");
    if(!r.ok){
      $("eventsTbody").innerHTML = `<tr><td colspan="2" class="muted">Historique indisponible</td></tr>`;
      $("evCount").textContent = "—";
      return;
    }
    const ev = Array.isArray(r.data)?r.data:[];
    $("evCount").textContent = ev.length + " evt(s)";
    if(ev.length===0){
      $("eventsTbody").innerHTML = `<tr><td colspan="2" class="muted">Aucun événement.</td></tr>`;
      return;
    }
    $("eventsTbody").innerHTML = ev.map(e=>`
      <tr>
        <td class="muted">${new Date(e.createdAt).toLocaleString("fr-FR")}</td>
        <td><b>${eventLabel(e)}</b></td>
      </tr>
    `).join("");
  }

  
  $("btnReminder").addEventListener("click", async ()=>{
    const propId = $("propertySelect").value || "";
    if(!propId){ toast("Associe un bien", false); return; }

    const btn = $("btnReminder");
    btn.disabled = true;
    try{
      const tpl = $("reminderTpl").value || "rent_reminder";
      const r = await apiJson("/api/reminders/tenant/" + tenantId, {
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({ template: tpl })
      });
      if(!r.ok){ toast((r.data && r.data.msg) || "Relance impossible", false); return; }
      toast((r.data && r.data.msg) || "Relance envoyée ✅");
      await loadEvents();
    } finally {
      refreshPropertyActions();
    }
  });

  (async ()=>{
    await loadProperties();
    await loadTenant();
    await loadEvents();
  })();
</script>
</body>
</html>
