services:
  app:
    container_name: doc2loc
    build: .
    ports:
      - "3000:3000"
    env_file:
      - .env
    environment:
      - MONGO_URI=${MONGO_URI:-mongodb://mongodb:27017/doc2loc}
      - NODE_ENV=production
    working_dir: /app
    volumes:
      - ./:/app
      - node_modules:/app/node_modules
    networks:
      - doc2loc-net
    restart: unless-stopped

networks:
  doc2loc-net:
    external: true

volumes:
  node_modules:
